{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "index.ts",
    "constants/**/*.ts",
    "enums/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "**/*.spec.ts"]
}
