model SyncChangeLog {
  id String @id @default(uuid())

  deviceId String @map("device_id")
  userId   String @map("user_id")

  // ─── CHANGE ───
  entityName String       @map("entity_name")
  entityId   String       @map("entity_id")
  action     ChangeAction

  changedFields  Json? @map("changed_fields")
  fullRecord     Json? @map("full_record")
  previousValues Json? @map("previous_values")

  clientTimestamp DateTime @map("client_timestamp")
  clientVersion   Int      @default(1) @map("client_version")

  // ─── SYNC STATE ───
  isPushed     Boolean   @default(false) @map("is_pushed")
  pushedAt     DateTime? @map("pushed_at")
  pushResult   String?   @map("push_result")
  conflictId   String?   @map("conflict_id")
  errorMessage String?   @map("error_message")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([userId, deviceId, isPushed])
  @@index([entityName, entityId])
  @@index([tenantId])
  @@map("gv_aud_sync_change_logs")
}

