  // ─── SCOPE ───
  tenantId   String? @map("tenant_id")
  tenantName String? @map("tenant_name")

  // ─── ERROR ───
  errorMessage String? @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text
