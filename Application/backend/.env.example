# ─────────────────────────────────────────────────────────────────────────────
# CRM-SOFT API — Environment Variable Reference
# Copy this file to .env and fill in all values before starting the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft?schema=public

# 4-DB Architecture (DB-1)
IDENTITY_DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft_identity
PLATFORM_DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft_platform
GLOBAL_WORKING_DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft_working

# JWT
JWT_SECRET=                    # min 32 chars, random
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=            # min 32 chars, different from JWT_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# Auth
BCRYPT_SALT_ROUNDS=12

# App
PORT=3000
NODE_ENV=development           # development | production | test

# CORS — comma-separated allowed origins (leave empty to allow all)
CORS_ORIGINS=

# Default Tenant (used for platform admin menu source)
DEFAULT_TENANT_ID=

# Encryption
ENCRYPTION_MASTER_KEY=         # min 32 chars, random, keep secret

# ─── Bootstrap Credentials (required on first boot only) ──────────────────────
# These are used ONCE to create the initial accounts if they don't exist.
# Set strong values. Rotate after first login. NEVER use defaults in production.
PLATFORM_ADMIN_EMAIL=platform@crm.com
PLATFORM_ADMIN_DEFAULT_PASSWORD=   # REQUIRED — set a strong password

VENDOR_DEFAULT_EMAIL=vendor@demo.com
VENDOR_DEFAULT_PASSWORD=           # REQUIRED — set a strong password

# Marketplace (Social Commerce)
MARKETPLACE_DATABASE_URL=postgresql://postgres:password@localhost:5432/crmsoft_marketplace
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=crmsoft-marketplace
R2_PUBLIC_URL=https://marketplace-assets.yourdomain.com
REDIS_URL=redis://localhost:6379

# ─── Platform Console (port 3012) ─────────────────────────────────────────────
PLATFORM_CONSOLE_DATABASE_URL="postgresql://user:pass@localhost:5432/crmsoft_platform_console"

# ─── Additional Databases ─────────────────────────────────────────────────────
DEMO_DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft_demo
GLOBAL_REFERENCE_DATABASE_URL=postgresql://user:password@localhost:5432/crmsoft_global_reference

# ─── App URLs & Versioning ────────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_VERSION=2.0.0
API_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3005
EMAIL_TRACKING_BASE_URL=http://localhost:3000

# ─── Feature Flags ────────────────────────────────────────────────────────────
DISABLE_CRON=false                     # true | false

# ─── Inter-service Auth ───────────────────────────────────────────────────────
INTERNAL_API_TOKEN=                    # shared secret for service-to-service calls; min 32 chars

# ─── OAuth / SSO (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── AI Providers ─────────────────────────────────────────────────────────────
GEMINI_KEY=                            # https://ai.google.dev — regenerate in provider dashboard

# ─── SMS / OTP ────────────────────────────────────────────────────────────────
SARVAN_KEY=                            # https://sarvam.ai — regenerate in provider dashboard

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
WA_MEDIA_UPLOAD_DIR=/tmp/wa-media      # absolute path for WhatsApp media uploads

# ─── Notion (internal integrations) ───────────────────────────────────────────
NOTION_TOKEN=                          # integration token from notion.so/my-integrations
NOTION_API_KEY=                        # alias of NOTION_TOKEN where referenced
NOTION_PARENT_PAGE_ID=                 # page where the integration writes
NOTION_RELEASES_DB_ID=                 # database for release tracking
