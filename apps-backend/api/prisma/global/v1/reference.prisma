// GlobalReferenceDB — reference domain
// Generated by scripts/split-schemas.py
// Models: GlCfgCountry, GlCfgState, GlCfgCity, GlCfgLookupType, GlCfgLookupValue

model GlCfgCountry {
  id           String       @id @default(uuid())
  code         String       @unique                // ISO-3166 alpha-2: "IN", "US"
  code3        String       @unique                // ISO-3166 alpha-3: "IND", "USA"
  name         String
  nameLocal    String?      @map("name_local")     // Local script name: "भारत"
  phoneCode    String?      @map("phone_code")     // "+91"
  currencyCode String?      @map("currency_code")  // "INR"
  isActive     Boolean      @default(true) @map("is_active")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  states       GlCfgState[]

  @@index([isActive])
  @@map("gl_cfg_country")
}

model GlCfgState {
  id           String       @id @default(uuid())
  countryId    String       @map("country_id")
  code         String                               // "MH" for Maharashtra
  name         String
  nameLocal    String?      @map("name_local")      // "महाराष्ट्र"
  gstStateCode String?      @map("gst_state_code")  // "27" — Indian GST state code
  isActive     Boolean      @default(true) @map("is_active")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  country      GlCfgCountry  @relation(fields: [countryId], references: [id])
  cities       GlCfgCity[]
  pincodes     GlCfgPincode[]

  @@unique([countryId, code])
  @@index([countryId])
  @@map("gl_cfg_state")
}

model GlCfgCity {
  id           String       @id @default(uuid())
  stateId      String       @map("state_id")
  name         String
  nameLocal    String?      @map("name_local")      // "मुंबई"
  tier         String?                               // "TIER_1", "TIER_2", "TIER_3"
  isActive     Boolean      @default(true) @map("is_active")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  state        GlCfgState   @relation(fields: [stateId], references: [id])

  @@index([stateId])
  @@index([name])
  @@map("gl_cfg_city")
}

model GlCfgLookupType {
  id           String              @id @default(uuid())
  code         String              @unique           // "GENDER", "MARITAL_STATUS", "BLOOD_GROUP"
  displayName  String              @map("display_name")
  description  String?
  isSystem     Boolean             @default(true) @map("is_system")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  values       GlCfgLookupValue[]

  @@index([isActive])
  @@map("gl_cfg_lookup_type")
}

model GlCfgLookupValue {
  id           String           @id @default(uuid())
  lookupTypeId String           @map("lookup_type_id")
  code         String                                // "MALE", "FEMALE", "OTHER"
  label        String                                // "Male"
  labelHi      String?          @map("label_hi")     // "पुरुष"
  icon         String?
  color        String?
  sortOrder    Int              @default(0) @map("sort_order")
  isActive     Boolean          @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  lookupType   GlCfgLookupType  @relation(fields: [lookupTypeId], references: [id], onDelete: Cascade)

  @@unique([lookupTypeId, code])
  @@index([lookupTypeId, isActive])
  @@map("gl_cfg_lookup_value")
}
