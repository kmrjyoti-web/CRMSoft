// PlatformDB — subscriptions domain
// Generated by scripts/split-schemas.py
// Models: Package, TenantUsageDetail, Wallet, WalletTransaction, RechargePlan, Coupon, SoftwareOffer, LicenseKey, AiPlan, AiSubscription, AiSubscriptionItem, SubscriptionPackage, CouponRedemption, PackageModule

model Package {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  name        String
  code        String
  description String?
  type        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("gv_lic_packages")
}

model TenantUsageDetail {
