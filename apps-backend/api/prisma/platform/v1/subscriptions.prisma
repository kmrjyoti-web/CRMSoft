  currentCount Int      @default(0) @map("current_count")
  monthlyCount Int      @default(0) @map("monthly_count")
  monthYear    String?  @map("month_year")
  lastUpdated  DateTime @default(now()) @map("last_updated")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, resourceKey])
  @@index([tenantId])
  @@map("gv_lic_tenant_usage_details")
}

model Wallet {
  id             String   @id @default(uuid())
  tenantId       String   @unique @map("tenant_id")
  balance        Int      @default(0)
  promoBalance   Int      @default(0) @map("promo_balance")
  lifetimeCredit Int      @default(0) @map("lifetime_credit")
  lifetimeDebit  Int      @default(0) @map("lifetime_debit")
  currency       String   @default("INR")
  tokenRate      Int      @default(100) @map("token_rate")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

