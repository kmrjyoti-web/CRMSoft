  quantity  Int     @default(1)
  unitAmount Decimal @map("unit_amount") @db.Decimal(12, 2)

  // Soft delete
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subscriptionId])
  @@index([itemType, itemRefId])
  @@map("soft_lic_ai_subscription_items")
}

model SubscriptionPackage {
  id          String  @id @default(uuid())
  packageCode String  @unique @map("package_code")
  packageName String  @map("package_name")
  tagline     String?
  description String?
  tier        Int     @default(0) // 0=Free, 1=Basic, 2=Pro, 3=Enterprise

  // Pricing
  priceMonthlyInr   Decimal  @map("price_monthly_inr") @db.Decimal(12, 2)
  quarterlyPrice    Decimal? @map("quarterly_price") @db.Decimal(12, 2)
  priceYearlyInr    Decimal  @map("price_yearly_inr") @db.Decimal(12, 2)
  yearlyDiscountPct Decimal  @default(20) @map("yearly_discount_pct") @db.Decimal(5, 2)
  oneTimeSetupFee   Decimal? @map("one_time_setup_fee") @db.Decimal(12, 2)
  currency          String   @default("INR")

  // Trial
  trialDays Int @default(14) @map("trial_days")

  // Entity limits JSONB { CONTACTS: { limit: 500, extraPricePerUnit: 5 }, ... }
  entityLimits Json @default("{}") @map("entity_limits")

  // Legacy fields kept for compatibility
  applicableTypes Json  @default("[\"ALL\"]") @map("applicable_types")
  includedModules Json  @default("[]") @map("included_modules")
  limits          Json  @default("{}") @map("limits")
  introOfferJson  Json? @map("intro_offer_json")
  featureFlags    Json  @default("{}") @map("feature_flags")
  planLevel       Int   @default(0) @map("plan_level")

  // Database
  hasDedicatedDb Boolean @default(false) @map("has_dedicated_db")
  maxDbSizeMb    Int?    @map("max_db_size_mb")

  // Industry
  industryCode String? @map("industry_code")

  // Display
  isPopular  Boolean  @default(false) @map("is_popular")
  badgeText  String?  @map("badge_text")
  color      String?
  isActive   Boolean  @default(true) @map("is_active")
  isFeatured Boolean  @default(false) @map("is_featured")
  isPublic   Boolean  @default(true) @map("is_public")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  coupons          Coupon[]
  packageModules   PackageModule[]
  industryPackages IndustryPackage[]

  @@index([industryCode, isActive])
  @@map("gv_lic_subscription_packages")
}

model CouponRedemption {
  id              String   @id @default(uuid())
  couponId        String   @map("coupon_id")
  tenantId        String   @map("tenant_id")
  userId          String   @map("user_id")
  discountApplied Decimal  @map("discount_applied") @db.Decimal(12, 2)
  redeemedAt      DateTime @default(now()) @map("redeemed_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([couponId, tenantId, userId])
  @@index([couponId])
  @@index([tenantId])
  @@map("gv_lic_coupon_redemptions")
}

model PackageModule {
  id        String @id @default(uuid())
  packageId String @map("package_id")
  moduleId  String @map("module_id")

  // Pricing for this module in this package
  pricingType ModulePricingType @default(INCLUDED)
  addonPrice  Decimal?          @map("addon_price") @db.Decimal(12, 2)
  oneTimeFee  Decimal?          @map("one_time_fee") @db.Decimal(12, 2)

  // Feature toggles (which features of this module are active in this package)
  // Empty = ALL features enabled
  enabledFeatures  String[] @default([]) @map("enabled_features")
  disabledFeatures String[] @default([]) @map("disabled_features")

  // Trial
  trialAllowed Boolean @default(true) @map("trial_allowed")
  trialDays    Int?    @map("trial_days")

  // Module-specific limit overrides JSONB
  moduleLimits Json? @map("module_limits")

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  module  ModuleDefinition    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([packageId, moduleId])
  @@map("gv_lic_package_modules")
}
