model AiPlan {
  id          String   @id @default(uuid())
  planCode    String   @unique @map("plan_code")
  name        String
  description String?  @db.Text

  // Razorpay integration
  razorpayPlanId String? @unique @map("razorpay_plan_id")

  // Billing configuration
  amount        Decimal @db.Decimal(12, 2)
  currency      String  @default("INR")
  interval      BillingInterval
  intervalCount Int     @default(1) @map("interval_count")

  // Token allocation per billing cycle
  tokensPerCycle      Int @default(0) @map("tokens_per_cycle")
  bonusTokensPerCycle Int @default(0) @map("bonus_tokens_per_cycle")

  // Plan metadata
  features  Json?    @default("[]")
  trialDays Int      @default(0) @map("trial_days")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  // Plan type classification
  planType            PlanType @default(SUBSCRIPTION) @map("plan_type")
  marketplaceModuleId String?  @map("marketplace_module_id")

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  // Audit
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedById   String?  @map("updated_by_id")
  updatedByName String?  @map("updated_by_name")

  // Relations
  aiSubscriptions AiSubscription[]

  @@index([isActive])
  @@index([isDeleted])
  @@index([marketplaceModuleId])
  @@index([razorpayPlanId])
  @@map("soft_lic_ai_plans")
}

model AiSubscription {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Plan reference
  planId String  @map("plan_id")
  aiPlan AiPlan  @relation(fields: [planId], references: [id])

  // Razorpay integration
  razorpaySubscriptionId String? @unique @map("razorpay_subscription_id")
  razorpayPlanId         String? @map("razorpay_plan_id")
  razorpayCustomerId     String? @map("razorpay_customer_id")

  // Status
  status SubscriptionStatus @default(CREATED)

  // Billing period
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  nextBillingAt      DateTime? @map("next_billing_at")

  // Trial
  trialStart DateTime? @map("trial_start")
  trialEnd   DateTime? @map("trial_end")

  // Cancellation
  cancelAtPeriodEnd  Boolean   @default(false) @map("cancel_at_period_end")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  // Billing metadata
  totalCycles     Int? @map("total_cycles")
  completedCycles Int  @default(0) @map("completed_cycles")
  failedPayments  Int  @default(0) @map("failed_payments")

  // Metadata
  metadata Json?   @default("{}")
  notes    String? @db.Text

  // Soft delete
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  // Audit
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by_id")
  updatedById   String?  @map("updated_by_id")
  updatedByName String?  @map("updated_by_name")

  // Relations
  items AiSubscriptionItem[]

  @@index([tenantId])
  @@index([status])
  @@index([razorpaySubscriptionId])
  @@index([nextBillingAt])
  @@index([isDeleted])
  @@index([tenantId, status])
  @@map("soft_lic_ai_subscriptions")
}

model AiSubscriptionItem {
  id             String         @id @default(uuid())
  subscriptionId String         @map("subscription_id")
