  reviewCount      Int                     @default(0) @map("review_count")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  vendor        MarketplaceVendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviews       MarketplaceReview[]
  installations TenantMarketplaceModule[]

  // AI Apps Marketplace extensions
  moduleType             ModuleType    @default(INTEGRATION) @map("module_type")
  capabilities           String[]      @default([])
  aiTaskTypes            String[]      @default([]) @map("ai_task_types")
  aiHandlerKey           String?       @map("ai_handler_key")
  aiHandlerType          AiHandlerType @default(GENERIC) @map("ai_handler_type")
  supportedPaymentModes  String[]      @default(["WALLET_DEDUCT"]) @map("supported_payment_modes")
  minWalletBalance       Decimal?      @map("min_wallet_balance") @db.Decimal(12, 2)
  estimatedTokensPerCall Int?          @map("estimated_tokens_per_call")
  requiresPrivacyMode    Boolean       @default(false) @map("requires_privacy_mode")
  providerSupport        String[]      @default([]) @map("provider_support")
  contentRating          ContentRating @default(GENERAL) @map("content_rating")
  marketplaceNamespace   String?       @map("marketplace_namespace")
  aiHandlerConfig        Json?         @map("ai_handler_config")

  @@index([marketplaceNamespace])
  @@index([marketplaceNamespace, moduleType])
  @@map("gv_mkt_marketplace_modules")
}

