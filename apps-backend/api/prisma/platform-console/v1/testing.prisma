// PlatformConsoleDB — testing domain
// Generated by scripts/split-schemas.py
// Models: PcTestPlan, PcTestSchedule, PcTestExecution, PcTestCoverage

model PcTestPlan {
  id            String   @id @default(uuid())
  name          String
  description   String?
  moduleScope   String?  @map("module_scope")
  verticalScope String?  @map("vertical_scope")
  scenarios     Json     @default("[]")
  createdBy     String   @map("created_by")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  executions    PcTestExecution[]

  @@map("pc_test_plans")
}

model PcTestSchedule {
  id             String    @id @default(uuid())
  planId         String?   @map("plan_id")
  scheduleType   String    @map("schedule_type")
  cronExpression String?   @map("cron_expression")
  moduleScope    String?   @map("module_scope")
  verticalScope  String?   @map("vertical_scope")
  brandScope     String?   @map("brand_scope")
  isActive       Boolean   @default(true) @map("is_active")
  lastRun        DateTime? @map("last_run")
  nextRun        DateTime? @map("next_run")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("pc_test_schedules")
}

model PcTestExecution {
  id            String    @id @default(uuid())
  planId        String?   @map("plan_id")
  scheduleId    String?   @map("schedule_id")
  triggerType   String    @map("trigger_type")
  moduleScope   String?   @map("module_scope")
  verticalScope String?   @map("vertical_scope")
  totalTests    Int       @default(0) @map("total_tests")
  passed        Int       @default(0)
  failed        Int       @default(0)
  skipped       Int       @default(0)
  duration      Int?
  coverage      Float?
  status        String    @default("RUNNING")
  output        String?   @db.Text
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")

  plan          PcTestPlan? @relation(fields: [planId], references: [id])

  @@index([status])
  @@index([startedAt])
  @@map("pc_test_executions")
}

model PcTestCoverage {
  id             String   @id @default(uuid())
  moduleName     String   @map("module_name")
  verticalType   String?  @map("vertical_type")
  specFileCount  Int      @default(0) @map("spec_file_count")
  totalTests     Int      @default(0) @map("total_tests")
  lineCoverage   Float?   @map("line_coverage")
  branchCoverage Float?   @map("branch_coverage")
  lastUpdated    DateTime @default(now()) @map("last_updated")

  @@unique([moduleName, verticalType])
  @@map("pc_test_coverages")
}
