  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@map("gv_sal_return_items")

  @@index([returnId])
}

model SaleMaster {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  name                String
  code                String
  localLedgerId       String?  @map("local_ledger_id")
  centralLedgerId     String?  @map("central_ledger_id")
  igstRate            Decimal  @default(0) @map("igst_rate") @db.Decimal(5, 2)
  cgstRate            Decimal  @default(0) @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate            Decimal  @default(0) @map("sgst_rate") @db.Decimal(5, 2)
  cessRate            Decimal  @default(0) @map("cess_rate") @db.Decimal(5, 2)
  natureOfTransaction String   @default("SALES") @map("nature_of_transaction")
  taxability          String   @default("TAXABLE")
  igstLedgerId        String?  @map("igst_ledger_id")
  cgstLedgerId        String?  @map("cgst_ledger_id")
  sgstLedgerId        String?  @map("sgst_ledger_id")
  cessLedgerId        String?  @map("cess_ledger_id")
  isDefault           Boolean  @default(false) @map("is_default")
  isActive            Boolean  @default(true) @map("is_active")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, code])
  
  @@index([tenantId])
  @@map("gv_sal_masters")
}

model PriceList {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  name        String
  description String?
  currency    String   @default("INR")
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0)
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdById String   @default("") @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       PriceListItem[]

  @@map("gv_sal_price_lists")
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([isDeleted])
}

model PriceListItem {
  id             String   @id @default(uuid())
  priceListId    String   @map("price_list_id")
  productId      String   @map("product_id")
  sellingPrice   Decimal  @map("selling_price") @db.Decimal(14,2)
  minQuantity    Int      @default(1) @map("min_quantity")
  maxQuantity    Int?     @map("max_quantity")
  marginPercent  Decimal? @map("margin_percent") @db.Decimal(5,2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceList      PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@map("gv_sal_price_list_items")
  @@index([priceListId])
  @@index([productId])
  @@unique([priceListId, productId, minQuantity])
}
