// WorkingDB — reports domain
// Generated by scripts/split-schemas.py
// Models: ReportExportLog, ReportDefinition, ReportBookmark, ScheduledReport, ReportTemplate

model ReportExportLog {
  id                String       @id @default(uuid())
  tenantId          String       @default("") @map("tenant_id")
  reportType        ReportType   @map("report_type")
  format            ReportFormat
  filters           Json?
  recordCount       Int          @map("record_count")
  fileUrl           String?      @map("file_url")
  fileSize          Int?         @map("file_size")
  status            String       @default("COMPLETED")
  errorMessage      String?      @map("error_message")
  generatedAt       DateTime     @map("generated_at")
  duration          Int?
  exportedById      String       @map("exported_by_id")
  exportedByName    String       @map("exported_by_name")
  reportCode        String?      @map("report_code")
  reportName        String?      @map("report_name")
  exportSource      String?      @default("MANUAL") @map("export_source")
  scheduledReportId String?      @map("scheduled_report_id")
  generationTimeMs  Int?         @map("generation_time_ms")
  createdAt         DateTime     @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([exportedById, createdAt])
  @@index([reportCode, createdAt])
  @@index([tenantId])
  @@map("gv_rpt_export_logs")
}

model ReportDefinition {
  id                       String         @id @default(uuid())
  tenantId                 String         @default("") @map("tenant_id")
  code                     String
  name                     String
  description              String?
  category                 ReportCategory
  defaultFilters           Json?          @map("default_filters")
  availableFilters         Json?          @map("available_filters")
  availableFormats         String[]       @map("available_formats")
  supportsDrillDown        Boolean        @default(false) @map("supports_drill_down")
  supportsPeriodComparison Boolean        @default(false) @map("supports_period_comparison")
  requiredRole             String?        @map("required_role")
  requiredFeature          String?        @map("required_feature")
  usageCount               Int            @default(0) @map("usage_count")
  lastGeneratedAt          DateTime?      @map("last_generated_at")
  isActive                 Boolean        @default(true) @map("is_active")
  sortOrder                Int            @default(0) @map("sort_order")
  createdAt                DateTime       @default(now()) @map("created_at")

  bookmarks ReportBookmark[]
  schedules ScheduledReport[]
  templates ReportTemplate[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, code])
  @@index([category, isActive])
  @@index([tenantId])
  @@map("gv_rpt_definitions")
}

model ReportBookmark {
  id          String           @id @default(uuid())
  tenantId    String           @default("") @map("tenant_id")
  reportDefId String           @map("report_def_id")
  reportDef   ReportDefinition @relation(fields: [reportDefId], references: [id])
  name        String
  filters     Json?
  isPinned    Boolean          @default(false) @map("is_pinned")
  userId      String           @map("user_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([userId])
  @@index([tenantId])
  @@map("gv_rpt_bookmarks")
}

model ScheduledReport {
  id               String                @id @default(uuid())
  tenantId         String                @default("") @map("tenant_id")
  reportDefId      String                @map("report_def_id")
  reportDef        ReportDefinition      @relation(fields: [reportDefId], references: [id])
  name             String
  filters          Json?
  format           ReportFormat          @default(PDF)
  frequency        ReportFrequency
  dayOfWeek        Int?                  @map("day_of_week")
  dayOfMonth       Int?                  @map("day_of_month")
  timeOfDay        String                @default("08:00") @map("time_of_day")
  timezone         String                @default("Asia/Kolkata")
  recipientEmails  String[]              @map("recipient_emails")
  recipientUserIds String[]              @map("recipient_user_ids")
  status           ScheduledReportStatus @default(ACTIVE)
  lastSentAt       DateTime?             @map("last_sent_at")
  nextScheduledAt  DateTime?             @map("next_scheduled_at")
  lastError        String?               @map("last_error")
  sendCount        Int                   @default(0) @map("send_count")
  createdById      String                @map("created_by_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([status, nextScheduledAt])
  @@index([tenantId])
  @@map("gv_rpt_scheduled_reports")
}

model ReportTemplate {
  id           String            @id @default(uuid())
  tenantId     String            @default("") @map("tenant_id")
  name         String
  description  String?
  reportDefId  String?           @map("report_def_id")
  reportDef    ReportDefinition? @relation(fields: [reportDefId], references: [id])
  layout       Json
  dataSource   Json?             @map("data_source")
  isPublic     Boolean           @default(false) @map("is_public")
  industryCode String?           @map("industry_code")
  createdById  String            @map("created_by_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@index([createdById])
  @@index([industryCode])
  @@map("gv_rpt_templates")
}
