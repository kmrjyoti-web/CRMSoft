model DocumentTemplate {
  id String @id @default(uuid())

  // ─── IDENTITY ───
  code         String
  name         String
  description  String?
  documentType DocumentType @map("document_type")

  // ─── TEMPLATE CONTENT ───
  templateVersion Int     @default(1) @map("template_version") // 1=Handlebars HTML, 2=Canvas JSON
  htmlTemplate    String  @map("html_template") @db.Text
  canvasJson      Json?   @map("canvas_json") // v2 canvas designer JSON
  cssStyles       String? @map("css_styles") @db.Text

  // ─── CUSTOMIZABLE SETTINGS (JSON) ───
  defaultSettings Json @default("{}") @map("default_settings")

  // ─── AVAILABLE DATA FIELDS ───
  availableFields Json @default("[]") @map("available_fields")

  // ─── INDUSTRY ───
  industryCode String? @map("industry_code")

  // ─── OWNERSHIP ───
  isSystem Boolean @default(true) @map("is_system")
  tenantId String? @map("tenant_id")

  // ─── DISPLAY ───
  thumbnailUrl String? @map("thumbnail_url")
  sortOrder    Int     @default(0) @map("sort_order")
  isDefault    Boolean @default(false) @map("is_default")
  isActive     Boolean @default(true) @map("is_active")

  // ─── AUDIT ───
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  tenantCustomizations TenantTemplateCustomization[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([code, tenantId])
  @@index([documentType, industryCode, isActive])
  @@index([tenantId])
  @@map("gv_doc_templates")
}

