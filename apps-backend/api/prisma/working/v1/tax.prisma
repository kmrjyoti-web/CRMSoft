model GstVerificationLog {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  userId             String   @map("user_id")
  gstNumber          String   @map("gst_number")
  verificationMethod String   @map("verification_method")
  apiResponse        Json?    @map("api_response")
  isValid            Boolean  @map("is_valid")
  businessName       String?  @map("business_name")
  businessAddress    String?  @map("business_address")
  gstStatus          String?  @map("gst_status")
  approvedBy         String?  @map("approved_by")
  approvalNotes      String?  @map("approval_notes")
  createdAt          DateTime @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId, userId])
  @@index([gstNumber])
  @@map("gv_tax_gst_verification_logs")
}

