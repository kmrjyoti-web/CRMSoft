model Task {
  id         String @id @default(uuid())
  tenantId   String @default("") @map("tenant_id")
  taskNumber String @map("task_number")

  // ─── TASK DETAILS ───
  title          String       @db.VarChar(500)
  description    String?      @db.Text
  type           TaskType     @default(GENERAL)
  customTaskType String?      @map("custom_task_type")
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)

  // ─── ASSIGNMENT (WHO) ───
  assignedToId          String?             @map("assigned_to_id")
  // [cross-db removed] assignedTo            User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById           String              @map("created_by_id")
  // [cross-db removed] createdBy             User                @relation("TaskCreatedBy", fields: [createdById], references: [id])
  approvedById          String?             @map("approved_by_id")
  approvedAt            DateTime?           @map("approved_at")
  rejectedReason        String?             @map("rejected_reason")
  assignmentScope       TaskAssignmentScope @default(SPECIFIC_USER) @map("assignment_scope")
  assignedDepartmentId  String?             @map("assigned_department_id")
  assignedDesignationId String?             @map("assigned_designation_id")
  assignedRoleId        String?             @map("assigned_role_id")

  // ─── DATES ───
  dueDate     DateTime? @map("due_date")
  dueTime     String?   @map("due_time")
  startDate   DateTime? @map("start_date")
  completedAt DateTime? @map("completed_at")

  // ─── RECURRENCE ───
  recurrence         TaskRecurrence @default(NONE)
  recurrenceConfig   Json?          @map("recurrence_config")
  nextRecurrenceDate DateTime?      @map("next_recurrence_date")
  parentTaskId       String?        @map("parent_task_id")
  parentTask         Task?          @relation("TaskRecurrence", fields: [parentTaskId], references: [id])
  childTasks         Task[]         @relation("TaskRecurrence")

  // ─── LINKED ENTITY (polymorphic) ───
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")

  // ─── METADATA ───
  tags            Json?
  attachments     Json?
  customFields    Json?   @map("custom_fields")
  completionNotes String? @map("completion_notes") @db.Text

  // ─── TRACKING ───
  estimatedMinutes Int? @map("estimated_minutes")
  actualMinutes    Int? @map("actual_minutes")

  // ─── AUDIT ───
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  history   TaskHistory[]
  watchers  TaskWatcher[]
  comments  Comment[]     @relation("TaskComments")
  reminders Reminder[]    @relation("TaskReminders")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, taskNumber])
  @@index([tenantId, assignedToId, status])
  @@index([tenantId, createdById])
  @@index([tenantId, assignedDepartmentId])
  @@index([tenantId, dueDate])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status, priority])
  @@map("gv_crm_tasks")
}

