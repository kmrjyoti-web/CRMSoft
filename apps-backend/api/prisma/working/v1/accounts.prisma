  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, ledgerId])
  @@map("gv_acc_ledger_mappings")
}

model AccountTransaction {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  transactionDate DateTime @map("transaction_date")
  voucherType     String   @map("voucher_type")
  voucherNumber   String   @map("voucher_number")
  referenceType   String?  @map("reference_type")
  referenceId     String?  @map("reference_id")
  debitLedgerId   String   @map("debit_ledger_id")
  creditLedgerId  String   @map("credit_ledger_id")
  amount          Decimal  @db.Decimal(12, 2)
  narration       String?
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now())
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([tenantId, transactionDate])
  @@map("gv_acc_transactions")
}

model BankAccount {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  bankName       String   @map("bank_name")
  accountNumber  String   @map("account_number")
  accountType    String   @map("account_type")
  ifscCode       String   @map("ifsc_code")
  branchName     String?  @map("branch_name")
  ledgerId       String   @map("ledger_id")
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(12, 2)
  currentBalance Decimal  @default(0) @map("current_balance") @db.Decimal(12, 2)
  isDefault      Boolean  @default(false) @map("is_default")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, accountNumber])
  
  @@index([tenantId])
  @@map("gv_acc_bank_accounts")
}

model BankReconciliation {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  bankAccountId      String    @map("bank_account_id")
  reconciliationDate DateTime  @map("reconciliation_date")
  statementBalance   Decimal   @map("statement_balance") @db.Decimal(12, 2)
  bookBalance        Decimal   @map("book_balance") @db.Decimal(12, 2)
  difference         Decimal   @db.Decimal(12, 2)
  unreconciledItems  Json      @default("[]") @map("unreconciled_items")
  status             String    @default("DRAFT")
  reconciledById     String?   @map("reconciled_by_id")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now())

  
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("gv_acc_bank_reconciliations")
}

model DebitNote {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  debitNoteNumber      String   @map("debit_note_number")
  vendorId             String   @map("vendor_id")
  purchaseInvoiceId    String?  @map("purchase_invoice_id")
  goodsReceiptId       String?  @map("goods_receipt_id")
  reason               String
  status               String   @default("DRAFT")
  noteDate             DateTime @default(now()) @map("note_date")
  subtotal             Decimal  @map("subtotal") @db.Decimal(12, 2)
  cgstAmount           Decimal? @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount           Decimal? @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount           Decimal? @map("igst_amount") @db.Decimal(12, 2)
  grandTotal           Decimal  @map("grand_total") @db.Decimal(12, 2)
  inventoryEffect      Boolean  @default(true) @map("inventory_effect")
  accountsEffect       Boolean  @default(true) @map("accounts_effect")
  workflowInstanceId   String?  @map("workflow_instance_id")
  accountTransactionId String?  @map("account_transaction_id")
  createdById          String   @map("created_by_id")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  items DebitNoteItem[]

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, debitNoteNumber])
  
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("gv_acc_debit_notes")
}

model DebitNoteItem {
  id            String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  debitNoteId   String   @map("debit_note_id")
  productId     String   @map("product_id")
  quantity      Decimal  @db.Decimal(10, 3)
  unitId        String   @map("unit_id")
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  taxableAmount Decimal  @map("taxable_amount") @db.Decimal(12, 2)
  cgstAmount    Decimal? @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount    Decimal? @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount    Decimal? @map("igst_amount") @db.Decimal(10, 2)
  hsnCode       String?  @map("hsn_code")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(12, 2)

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  // [cross-db removed] tenant      Tenant   @relation(fields: [tenantId], references: [id])
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@map("gv_acc_debit_note_items")

  @@index([debitNoteId])
}

model AccountGroup {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  name         String
  code         String
  parentId     String?        @map("parent_id")
  primaryGroup String         @map("primary_group")
  nature       String         @default("DEBIT")
  isProhibited Boolean        @default(false) @map("is_prohibited")
  isSystem     Boolean        @default(false) @map("is_system")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  children     AccountGroup[] @relation("GroupTree")
  parent       AccountGroup?  @relation("GroupTree", fields: [parentId], references: [id])
  ledgers      LedgerMaster[]

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, code])
  
  @@index([tenantId])
  @@map("gv_acc_account_groups")
}
