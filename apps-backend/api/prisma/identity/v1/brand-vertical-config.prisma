// IdentityDB — Brand + Vertical + Partner configuration
// Models: GvCfgBrand, GvCfgVertical, GvCfgPartner

model GvCfgBrand {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  domain    String? @unique
  subdomain String? @unique

  theme                 Json    @default("{}")
  layoutCode            String  @default("default") @map("layout_code")
  loginVariant          String  @default("standard") @map("login_variant")
  defaultRedirectByRole Json    @default("{}") @map("default_redirect_by_role")
  menuOverrides         Json?   @map("menu_overrides")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("gv_cfg_brands")
  @@index([code])
  @@index([isActive])
}

model GvCfgVertical {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  iconCode    String? @map("icon_code")

  defaultModules   Json @default("[]") @map("default_modules")
  defaultMenu      Json @default("[]") @map("default_menu")
  terminology      Json @default("{}")
  defaultDashboard Json @default("[]") @map("default_dashboard")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("gv_cfg_verticals")
  @@index([code])
  @@index([isActive])
}

model GvCfgPartner {
  id   String @id @default(uuid())
  code String @unique
  name String
  type String @default("RESELLER")

  whiteLabelConfig  Json     @default("{}") @map("white_label_config")
  commissionPercent Decimal? @db.Decimal(5, 2) @map("commission_percent")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("gv_cfg_partners")
  @@index([code])
  @@index([isActive])
}
