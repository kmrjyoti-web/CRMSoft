// IdentityDB — Brand + Vertical + Partner configuration
// Models: GvCfgBrand (→ pc_brand), GvCfgVertical (→ pc_crm_edition), GvCfgPartner

model GvCfgBrand {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?

  domain    String? @unique
  subdomain String? @unique

  theme                 Json    @default("{}")
  layoutCode            String  @default("default") @map("layout_code")
  loginVariant          String  @default("standard") @map("login_variant")
  defaultRedirectByRole Json    @default("{}") @map("default_redirect_by_role")
  menuOverrides         Json?   @map("menu_overrides")

  // M1 additions
  partnerId    String? @map("partner_id") @db.Uuid
  shortCode    String? @unique @map("short_code") @db.VarChar(10)
  layoutFolder String? @map("layout_folder") @db.VarChar(255)
  themeId      String? @map("theme_id") @db.VarChar(255)
  isPublic     Boolean @default(false) @map("is_public")

  // M6 additions
  logoUrl     String? @map("logo_url") @db.VarChar(500)
  faviconUrl  String? @map("favicon_url") @db.VarChar(500)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("pc_brand")
  @@index([code])
  @@index([isActive])
}

model GvCfgVertical {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  description String?
  iconCode    String? @map("icon_code")

  defaultModules   Json @default("[]") @map("default_modules")
  defaultMenu      Json @default("[]") @map("default_menu")
  terminology      Json @default("{}")
  defaultDashboard Json @default("[]") @map("default_dashboard")

  // M1 additions
  shortCode        String? @unique @map("short_code") @db.VarChar(10)
  defaultModulesV2 Json    @default("[]") @map("default_modules_v2")
  isBuilt          Boolean @default(false) @map("is_built")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("pc_crm_edition")
  @@index([code])
  @@index([isActive])
}

model GvCfgPartner {
  id   String @id @default(uuid())
  code String @unique
  name String
  type String @default("RESELLER")

  whiteLabelConfig  Json     @default("{}") @map("white_label_config")
  commissionPercent Decimal? @db.Decimal(5, 2) @map("commission_percent")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mappings UserCompanyMapping[]

  @@map("gv_cfg_partners")
  @@index([code])
  @@index([isActive])
}
