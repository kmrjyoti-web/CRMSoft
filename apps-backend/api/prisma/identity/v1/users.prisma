  // [cross-db removed] tenantMarketplace    TenantMarketplaceModule[]

  // [cross-db removed] saleOrderItems       SaleOrderItem[]
  // [cross-db removed] saleReturnItems      SaleReturnItem[]
  // [cross-db removed] purchaseInvoiceItems PurchaseInvoiceItem[]
  // [cross-db removed] purchaseOrderItems   PurchaseOrderItem[]
  // [cross-db removed] purchaseQuotationItems PurchaseQuotationItem[]
  // [cross-db removed] purchaseRFQItems     PurchaseRFQItem[]
  // [cross-db removed] goodsReceiptItems    GoodsReceiptItem[]
  // [cross-db removed] debitNoteItems       DebitNoteItem[]
  // [cross-db removed] deliveryChallanItems DeliveryChallanItem[]
  // [cross-db removed] bomFormulaItems      BOMFormulaItem[]

  @@map("gv_usr_tenants")
}

model SuperAdmin {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("gv_usr_super_admins")
}

model TenantProfile {
  id                  String     @id @default(uuid())
  tenantId            String     @unique @map("tenant_id")
  companyLegalName    String?    @map("company_legal_name")
  industry            String?
  website             String?
  supportEmail        String?    @map("support_email")
  dbStrategy          DbStrategy @default(SHARED) @map("db_strategy")
  dbConnectionString  String?    @map("db_connection_string")
  primaryContactName  String?    @map("primary_contact_name")
  primaryContactEmail String?    @map("primary_contact_email")
  primaryContactPhone String?    @map("primary_contact_phone")
  billingAddress      Json?      @map("billing_address")
  gstin               String?
  pan                 String?
  accountManagerId    String?    @map("account_manager_id")
  notes               String?
  tags                String[]   @default([])
  maxDiskQuotaMb      Int        @default(500) @map("max_disk_quota_mb")
  currentDiskUsageMb  Int        @default(0) @map("current_disk_usage_mb")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@map("gv_usr_tenant_profiles")
}

model VerificationOtp {
  id          String     @id @default(uuid())
  tenantId    String?    @map("tenant_id")
  userId      String?    @map("user_id")
  target      String
  targetType  String     @map("target_type")
  otp         String
  purpose     OtpPurpose
  status      OtpStatus  @default(OTP_PENDING)
  attempts    Int        @default(0)
  maxAttempts Int        @default(3) @map("max_attempts")
  expiresAt   DateTime   @map("expires_at")
  verifiedAt  DateTime?  @map("verified_at")
  ipAddress   String?    @map("ip_address")
  userAgent   String?    @map("user_agent")
  createdAt   DateTime   @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([target, purpose, status])
  @@index([userId, purpose])
  @@index([expiresAt])
  @@index([tenantId])
  @@map("gv_usr_verification_otps")
}

model CustomerUser {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")

  // ─── Credentials ───
  email               String
  phone               String?
  passwordHash        String    @map("password_hash")

  // ─── Linked Entity (WorkingDB cross-DB ref by ID) ───
  linkedEntityType    String    @map("linked_entity_type")  // CONTACT, ORGANIZATION, LEDGER
  linkedEntityId      String    @map("linked_entity_id")
  linkedEntityName    String    @map("linked_entity_name")

  // ─── Profile ───
  displayName         String    @map("display_name")
  avatarUrl           String?   @map("avatar_url")
  companyName         String?   @map("company_name")
  gstin               String?

  // ─── Portal Config ───
  menuCategoryId      String?   @map("menu_category_id")
  menuCategory        CustomerMenuCategory? @relation(fields: [menuCategoryId], references: [id])
  pageOverrides       Json      @default("{}") @map("page_overrides")

  // ─── Auth State ───
  isActive            Boolean   @default(true) @map("is_active")
  isFirstLogin        Boolean   @default(true) @map("is_first_login")
  lastLoginAt         DateTime? @map("last_login_at")
  loginCount          Int       @default(0) @map("login_count")
  failedAttempts      Int       @default(0) @map("failed_attempts")
  lockedUntil         DateTime? @map("locked_until")

  // ─── Token Management ───
  refreshToken        String?   @map("refresh_token")
  refreshTokenExp     DateTime? @map("refresh_token_exp")
  passwordResetToken  String?   @map("password_reset_token")
  passwordResetExp    DateTime? @map("password_reset_exp")

  // ─── Soft Delete + Audit ───
  isDeleted           Boolean   @default(false) @map("is_deleted")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdById         String    @map("created_by_id")

  @@unique([tenantId, email])
  @@unique([tenantId, linkedEntityType, linkedEntityId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("gv_usr_customer_users")
}
