// WorkingDB — payments domain
// Generated by scripts/split-schemas.py
// Models: Payment, PaymentReceipt, Refund, PaymentReminder, PaymentRecord

model Payment {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  paymentNo String  @map("payment_no")
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  // ─── PAYMENT INFO ───
  amount   Decimal        @db.Decimal(14, 2)
  currency String         @default("INR")
  status   PaymentStatus  @default(PENDING)
  method   PaymentMethod
  gateway  PaymentGateway @default(MANUAL)

  // ─── GATEWAY DETAILS ───
  gatewayOrderId   String? @map("gateway_order_id")
  gatewayPaymentId String? @map("gateway_payment_id")
  gatewaySignature String? @map("gateway_signature")
  gatewayResponse  Json?   @map("gateway_response")

  // ─── OFFLINE DETAILS ───
  chequeNumber     String?   @map("cheque_number")
  chequeDate       DateTime? @map("cheque_date")
  chequeBankName   String?   @map("cheque_bank_name")
  transactionRef   String?   @map("transaction_ref")
  upiTransactionId String?   @map("upi_transaction_id")

  // ─── META ───
  paidAt        DateTime? @map("paid_at")
  notes         String?
  failureReason String?   @map("failure_reason")

  // ─── AUDIT ───
  recordedById String   @map("recorded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  receipt PaymentReceipt?
  refunds Refund[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, paymentNo])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@index([gatewayPaymentId])
  @@map("gv_pay_payments")
}

model PaymentReceipt {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  receiptNo String  @map("receipt_no")
  paymentId String  @unique @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount        Decimal  @db.Decimal(14, 2)
  amountInWords String?  @map("amount_in_words")
  receivedFrom  String   @map("received_from")
  paidFor       String   @map("paid_for")
  paymentMethod String   @map("payment_method")
  paymentDate   DateTime @map("payment_date")

  notes         String?
  generatedById String   @map("generated_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, receiptNo])
  @@index([tenantId])
  @@map("gv_pay_payment_receipts")
}

model Refund {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  refundNo  String  @map("refund_no")
  paymentId String  @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount Decimal      @db.Decimal(14, 2)
  reason String
  status RefundStatus @default(REFUND_PENDING)

  gatewayRefundId String? @map("gateway_refund_id")
  gatewayResponse Json?   @map("gateway_response")

  processedAt   DateTime? @map("processed_at")
  processedById String?   @map("processed_by_id")
  failureReason String?   @map("failure_reason")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, refundNo])
  @@index([tenantId, paymentId])
  @@index([tenantId, status])
  @@map("gv_pay_refunds")
}

model PaymentReminder {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  level        ReminderLevel
  scheduledAt  DateTime      @map("scheduled_at")
  sentAt       DateTime?     @map("sent_at")
  channel      String        @default("EMAIL")
  isSent       Boolean       @default(false) @map("is_sent")
  responseNote String?       @map("response_note")

  createdAt DateTime @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId, invoiceId])
  @@index([tenantId, isSent, scheduledAt])
  @@map("gv_pay_payment_reminders")
}

model PaymentRecord {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  paymentNumber        String    @map("payment_number")
  paymentType          String    @map("payment_type")
  entityType           String    @map("entity_type")
  entityId             String    @map("entity_id")
  entityName           String?   @map("entity_name")
  referenceType        String?   @map("reference_type")
  referenceId          String?   @map("reference_id")
  amount               Decimal   @db.Decimal(12, 2)
  currency             String    @default("INR")
  paymentMode          String    @map("payment_mode")
  bankAccountId        String?   @map("bank_account_id")
  chequeNumber         String?   @map("cheque_number")
  chequeDate           DateTime? @map("cheque_date")
  transactionRef       String?   @map("transaction_ref")
  upiId                String?   @map("upi_id")
  tdsApplicable        Boolean   @default(false) @map("tds_applicable")
  tdsRate              Decimal?  @map("tds_rate") @db.Decimal(5, 2)
  tdsAmount            Decimal?  @map("tds_amount") @db.Decimal(10, 2)
  tdsSection           String?   @map("tds_section")
  paymentDate          DateTime  @map("payment_date")
  status               String    @default("DRAFT")
  narration            String?
  workflowInstanceId   String?   @map("workflow_instance_id")
  createdById          String    @map("created_by_id")
  approvedById         String?   @map("approved_by_id")
  accountTransactionId String?   @map("account_transaction_id")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, paymentNumber])
  @@index([tenantId, paymentType, paymentDate])
  @@index([tenantId, entityId])
  @@map("gv_pay_records")
}
