model CommunicationLog {
  id        String              @id @default(uuid())
  tenantId  String              @default("") @map("tenant_id")
  channel   NotificationChannel
  direction String              @default("OUTBOUND")

  // ─── WHO ───
  recipientId       String? @map("recipient_id")
  recipientAddr     String? @map("recipient_addr")
  recipientExternal String? @map("recipient_external")

  // ─── CONTENT ───
  subject String? @db.VarChar(500)
  body    String? @db.Text

  // ─── LINKED ───
  entityType     String? @map("entity_type")
  entityId       String? @map("entity_id")
  notificationId String? @map("notification_id")

  // ─── STATUS ───
  status       String  @default("PENDING")
  externalId   String? @map("external_id")
  errorMessage String? @map("error_message")

  // ─── COST (paid channels) ───
  costAmount   Decimal? @map("cost_amount") @db.Decimal(10, 4)
  costCurrency String?  @default("INR") @map("cost_currency")

  // ─── TIMESTAMPS ───
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId, channel, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, recipientId])
  @@index([channel, status])
  @@map("gv_cmn_communication_logs")
}
