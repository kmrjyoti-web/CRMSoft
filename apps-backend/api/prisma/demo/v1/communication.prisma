  @@index([conversationId, createdAt])
  @@index([wabaId, createdAt])
  @@index([status])
  @@index([broadcastId])
  @@index([tenantId])
  @@map("gv_cmn_wa_messages")
}

model WaTemplate {
  id             String                  @id @default(uuid())
  tenantId       String                  @default("") @map("tenant_id")
  wabaId         String                  @map("waba_id")
  waba           WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id])
  metaTemplateId String?                 @map("meta_template_id")
  name           String
  language       String                  @default("en")
  category       WaTemplateCategory
  status         WaTemplateStatus        @default(PENDING)

  // Components
  headerType    String? @map("header_type")
  headerContent String? @map("header_content")
  bodyText      String  @map("body_text")
  footerText    String? @map("footer_text")
  buttons       Json?

  // Variable mapping
  variables    Json?
  sampleValues Json? @map("sample_values")

  // Stats
  sentCount      Int @default(0) @map("sent_count")
  deliveredCount Int @default(0) @map("delivered_count")
  readCount      Int @default(0) @map("read_count")
  repliedCount   Int @default(0) @map("replied_count")

  // Meta sync
  lastSyncedAt    DateTime? @map("last_synced_at")
  rejectionReason String?   @map("rejection_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  broadcasts WaBroadcast[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, wabaId, name, language])
  @@unique([tenantId, metaTemplateId])
  @@index([wabaId, status])
  @@index([tenantId])
  @@map("gv_cmn_wa_templates")
}

model WaBroadcast {
  id         String                  @id @default(uuid())
  tenantId   String                  @default("") @map("tenant_id")
  wabaId     String                  @map("waba_id")
  waba       WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id])
  name       String
  templateId String                  @map("template_id")
  template   WaTemplate              @relation(fields: [templateId], references: [id])
  status     WaBroadcastStatus       @default(DRAFT)

  // Scheduling
  scheduledAt       DateTime? @map("scheduled_at")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  throttlePerSecond Int       @default(10) @map("throttle_per_second")

  // Stats
  totalRecipients Int @default(0) @map("total_recipients")
  sentCount       Int @default(0) @map("sent_count")
  deliveredCount  Int @default(0) @map("delivered_count")
  readCount       Int @default(0) @map("read_count")
  failedCount     Int @default(0) @map("failed_count")
  optOutCount     Int @default(0) @map("opt_out_count")

  // Audit
  createdById   String   @map("created_by_id")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  recipients WaBroadcastRecipient[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([wabaId, status])
  @@index([scheduledAt])
  @@index([tenantId])
  @@map("gv_cmn_wa_broadcasts")
}

model WaBroadcastRecipient {
  id            String                     @id @default(uuid())
  tenantId      String                     @default("") @map("tenant_id")
  broadcastId   String                     @map("broadcast_id")
  broadcast     WaBroadcast                @relation(fields: [broadcastId], references: [id])
  phoneNumber   String                     @map("phone_number")
  contactName   String?                    @map("contact_name")
  variables     Json?
  status        WaBroadcastRecipientStatus @default(PENDING)
  waMessageId   String?                    @map("wa_message_id")
  sentAt        DateTime?                  @map("sent_at")
  deliveredAt   DateTime?                  @map("delivered_at")
  readAt        DateTime?                  @map("read_at")
  failedAt      DateTime?                  @map("failed_at")
  failureReason String?                    @map("failure_reason")
  createdAt     DateTime                   @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([broadcastId, status])
  @@index([tenantId])
  @@map("gv_cmn_wa_broadcast_recipients")
}

