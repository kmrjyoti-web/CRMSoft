// ─── Generator + Datasource ─────────────────────────────────────────────────
// This file is read by Prisma's prismaSchemaFolder feature.
// It declares the generator, datasource, and all shared enums for MarketplaceDB.
// Models live in the sibling domain files.

generator client {
  provider        = "prisma-client-js"
  output          = "../../../node_modules/@prisma/marketplace-client"
  previewFeatures = ["prismaSchemaFolder"]
}

datasource db {
  provider = "postgresql"
  url      = env("MARKETPLACE_DATABASE_URL")
}

