{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@core/*": ["src/core/*"],
      "@modules/*": ["src/modules/*"],
      "@modules/core/*": ["src/modules/core/*"],
      "@modules/customer/*": ["src/modules/customer/*"],
      "@modules/softwarevendor/*": ["src/modules/softwarevendor/*"],
      "@modules/marketplace/*": ["src/modules/marketplace/*"],
      "@modules/plugins/*": ["src/modules/plugins/*"]
    }
  }
}

