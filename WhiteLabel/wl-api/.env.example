# WhiteLabel API — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Master admin credentials (REQUIRED — no defaults, app throws on startup if missing)
ADMIN_EMAIL=admin@crmsoft.in
ADMIN_PASSWORD=              # REQUIRED — set a strong password, no default

# JWT
JWT_SECRET=                  # min 32 chars, random
JWT_EXPIRES_IN=15m

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=                # PostgreSQL connection string
