{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["index.ts", "components/**/*.ts", "components/**/*.tsx"],
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.spec.tsx"]
}
