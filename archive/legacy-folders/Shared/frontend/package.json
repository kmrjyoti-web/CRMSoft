{
  "name": "@crmsoft/ui-kit",
  "version": "1.0.0",
  "description": "CRMSoft UI Kit — Indian-specific AIC shared components (GSTInput, PANInput, StateSelect)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup index.ts --format cjs,esm --dts --tsconfig tsconfig.json --external react --external react-dom",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kmrjyoti-web/CrmProject.git",
    "directory": "Shared/frontend"
  },
  "peerDependencies": {
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
