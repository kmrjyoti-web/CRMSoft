model MasterLookup {
  id          String        @id @default(uuid())
  tenantId    String        @default("") @map("tenant_id")
  category    String
  displayName String        @map("display_name")
  description String?
  isSystem    Boolean       @default(false) @map("is_system")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  values      LookupValue[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, category])
  @@index([tenantId])
  @@map("master_lookups")
}

model LookupValue {
  id         String        @id @default(uuid())
  tenantId   String        @default("") @map("tenant_id")
  lookupId   String        @map("lookup_id")
  value      String
  label      String
  icon       String?
  color      String?
  rowIndex   Int           @default(0) @map("row_index")
  isDefault  Boolean       @default(false) @map("is_default")
  isActive   Boolean       @default(true) @map("is_active")
  parentId   String?       @map("parent_id")
  configJson Json?         @map("config_json")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  lookup     MasterLookup  @relation(fields: [lookupId], references: [id], onDelete: Cascade)
  parent     LookupValue?  @relation("LookupHierarchy", fields: [parentId], references: [id])
  children   LookupValue[] @relation("LookupHierarchy")

  // All filter relations
  // [cross-db removed] rawContactFilters   RawContactFilter[]
  // [cross-db removed] contactFilters      ContactFilter[]
  // [cross-db removed] organizationFilters OrganizationFilter[]
  // [cross-db removed] leadFilters         LeadFilter[]
  // [cross-db removed] productFilters      ProductFilter[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, lookupId, value])
  @@index([tenantId])
  @@map("lookup_values")
}

model Package {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  name        String
  code        String
  description String?
  type        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("packages")
}

model ErrorCatalog {
  id            String        @id @default(uuid())
  code          String        @unique
  layer         ErrorLayer    @default(BE)
  module        String        @db.VarChar(100)
  severity      ErrorSeverity @default(ERROR)
  httpStatus    Int           @map("http_status")
  messageEn     String        @map("message_en") @db.Text
  messageHi     String?       @map("message_hi") @db.Text
  solutionEn    String?       @map("solution_en") @db.Text
  solutionHi    String?       @map("solution_hi") @db.Text
  technicalInfo String?       @map("technical_info") @db.Text
  helpUrl       String?       @map("help_url")
  isRetryable   Boolean       @default(false) @map("is_retryable")
  retryAfterMs  Int?          @map("retry_after_ms")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([layer, module])
  @@index([severity])
  @@index([httpStatus])
  @@map("error_catalog")
}

model ErrorLog {
  id          String        @id @default(uuid())
  requestId   String        @map("request_id")
  errorCode   String        @map("error_code")
  message     String        @db.Text
  statusCode  Int           @map("status_code")
  layer       ErrorLayer    @default(BE)
  severity    ErrorSeverity @default(ERROR)
  path        String
  method      String
  userId      String?       @map("user_id")
  tenantId    String?       @map("tenant_id")
  details     Json?
  stack       String?       @db.Text
  ip          String?
  userAgent   String?       @map("user_agent") @db.VarChar(500)
  module      String?       @db.VarChar(100)
  requestBody Json?         @map("request_body")
  queryParams Json?         @map("query_params")
  metadata    Json?

  // ─── ENHANCED: Request/Response capture ───
  requestHeaders Json? @map("request_headers")
  responseBody   Json? @map("response_body")
  responseTimeMs Int?  @map("response_time_ms")

  // ─── ENHANCED: User/Tenant context ───
  userName     String? @map("user_name")
  userRole     String? @map("user_role")
  tenantName   String? @map("tenant_name")
  industryCode String? @map("industry_code")

  // ─── ENHANCED: Auto-report ───
  isAutoReported Boolean   @default(false) @map("is_auto_reported")
  autoReportedAt DateTime? @map("auto_reported_at")
  autoReportedTo String[]  @default([]) @map("auto_reported_to")

  // ─── ENHANCED: Report to Provider ───
  reportedToProvider     Boolean   @default(false) @map("reported_to_provider")
  reportedToProviderAt   DateTime? @map("reported_to_provider_at")
  reportedToProviderById String?   @map("reported_to_provider_by_id")

  // ─── ENHANCED: Resolution workflow ───
  status         String    @default("OPEN")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedById   String?   @map("resolved_by_id")
  resolution     String?   @db.Text
  assignedToId   String?   @map("assigned_to_id")
  assignedToName String?   @map("assigned_to_name")

  // ─── ENHANCED: Linked support ticket ───
  supportTicketId String? @map("support_ticket_id")

  createdAt DateTime @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([errorCode, createdAt])
  @@index([tenantId, createdAt])
  @@index([requestId])
  @@index([layer, severity, createdAt])
  @@index([createdAt])
  @@index([status, severity])
  @@map("error_logs")
}

model ErrorAutoReportRule {
  id       String  @id @default(uuid())
  tenantId String? @map("tenant_id")

  name     String
  severity ErrorSeverity
  channels String[]      @default([])

