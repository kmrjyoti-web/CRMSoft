model PackageModule {
  id        String @id @default(uuid())
  packageId String @map("package_id")
  moduleId  String @map("module_id")

  // Pricing for this module in this package
  pricingType ModulePricingType @default(INCLUDED)
  addonPrice  Decimal?          @map("addon_price") @db.Decimal(12, 2)
  oneTimeFee  Decimal?          @map("one_time_fee") @db.Decimal(12, 2)

  // Feature toggles (which features of this module are active in this package)
  // Empty = ALL features enabled
  enabledFeatures  String[] @default([]) @map("enabled_features")
  disabledFeatures String[] @default([]) @map("disabled_features")

  // Trial
  trialAllowed Boolean @default(true) @map("trial_allowed")
  trialDays    Int?    @map("trial_days")

  // Module-specific limit overrides JSONB
  moduleLimits Json? @map("module_limits")

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  module  ModuleDefinition    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([packageId, moduleId])
  @@map("package_modules")
}

model PageRegistry {
  id String @id @default(uuid())

  // Route info (auto-discovered)
  routePath     String  @unique @map("route_path")
  routePattern  String  @map("route_pattern")
  portal        String  @default("crm")
  filePath      String  @map("file_path")
  componentName String? @map("component_name")

  // Vendor-configurable
  friendlyName String? @map("friendly_name")
  description  String?
  pageType     String? @map("page_type")
  category     String?

  // Module assignment
  moduleCode String? @map("module_code")

  // Menu linking
  menuKey       String? @map("menu_key")
  menuLabel     String? @map("menu_label")
  menuIcon      String? @map("menu_icon")
  menuParentKey String? @map("menu_parent_key")
  menuSortOrder Int     @default(0) @map("menu_sort_order")
  showInMenu    Boolean @default(true) @map("show_in_menu")

  // Metadata (auto-discovered)
  hasParams   Boolean  @default(false) @map("has_params")
  paramNames  String[] @default([]) @map("param_names")
  isNested    Boolean  @default(false) @map("is_nested")
  parentRoute String?  @map("parent_route")

  // Features + API deps
  featuresCovered String[] @default([]) @map("features_covered")
  apiEndpoints    String[] @default([]) @map("api_endpoints")

  // Preview
  screenshotUrl String? @map("screenshot_url")
  previewUrl    String? @map("preview_url")

  // Industry
  industryCode String? @map("industry_code")

  // Status
  isActive         Boolean   @default(true) @map("is_active")
  isAutoDiscovered Boolean   @default(true) @map("is_auto_discovered")
  lastScannedAt    DateTime? @map("last_scanned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([portal])
  @@index([moduleCode])
  @@index([category])
  @@index([pageType])
  @@index([industryCode])
  @@map("page_registry")
}

model AppVersion {
  id          String        @id @default(uuid())
  version     String        @unique
  codeName    String?       @map("code_name")
  releaseType String        @default("MINOR") @map("release_type") // MAJOR, MINOR, PATCH, HOTFIX
  status      VersionStatus @default(DRAFT)

  // Changelog
  changelog       Json    @default("[]") // [{ category, items[] }]
  breakingChanges Json    @default("[]") @map("breaking_changes")
  migrationNotes  String? @map("migration_notes")

  // Modules included in this version
  modulesUpdated String[] @default([]) @map("modules_updated")
  schemaChanges  Json?    @map("schema_changes") // { added: [], modified: [], removed: [] }

  // Git info
  gitTag        String? @map("git_tag")
  gitBranch     String? @map("git_branch")
  gitCommitHash String? @map("git_commit_hash")

  // Deployment info
  deployedAt     DateTime? @map("deployed_at")
  deployedBy     String?   @map("deployed_by")
  rollbackAt     DateTime? @map("rollback_at")
  rollbackReason String?   @map("rollback_reason")

  // Notion
  notionPageId String? @map("notion_page_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patches        IndustryPatch[]
  // [cross-db removed] tenantVersions TenantVersion[]
  // [cross-db removed] backups        VersionBackup[]

  @@index([status])
  @@index([releaseType])
  @@map("app_versions")
}

model IndustryPatch {
  id           String      @id @default(uuid())
  versionId    String      @map("version_id")
  industryCode String      @map("industry_code")
  patchName    String      @map("patch_name")
  description  String?
  status       PatchStatus @default(PENDING)

  // Patch content
  schemaChanges   Json? @map("schema_changes")
  seedData        Json? @map("seed_data")
  configOverrides Json? @map("config_overrides")
  menuOverrides   Json? @map("menu_overrides")

  // Execution
  appliedAt    DateTime? @map("applied_at")
  appliedBy    String?   @map("applied_by")
  errorLog     String?   @map("error_log")
  rollbackData Json?     @map("rollback_data")

  forceUpdate Boolean @default(false) @map("force_update")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, industryCode, patchName])
  @@index([industryCode])
  @@index([status])
  @@map("industry_patches")
}
// ═══════════════════════════════════════════════════════
// TEST ENVIRONMENT MANAGER  (OPS-1)
// ═══════════════════════════════════════════════════════

enum TestEnvSourceType {
  SEED_DATA
  LIVE_CLONE
  BACKUP_RESTORE
}

enum TestEnvStatus {
  QUEUED
  CREATING
  SEEDING
  READY
  TESTING
  COMPLETED
  FAILED
  CLEANING
  CLEANED
}

model TestEnvironment {
  id          String @id @default(uuid())
  tenantId    String @map("tenant_id")

  name        String
  displayName String @map("display_name")

  sourceType  TestEnvSourceType @map("source_type")
  sourceDbUrl String?           @map("source_db_url")
  backupId    String?           @map("backup_id")

  testDbName  String  @map("test_db_name")
  testDbUrl   String? @map("test_db_url")

  status          TestEnvStatus @default(QUEUED)
  statusMessage   String?       @map("status_message")
  progressPercent Int           @default(0) @map("progress_percent")

  dbSizeBytes  BigInt? @map("db_size_bytes")
  tablesCreated Int?   @map("tables_created")
  seedRecords   Int?   @map("seed_records")

  ttlHours  Int       @default(24) @map("ttl_hours")
  expiresAt DateTime? @map("expires_at")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String    @map("created_by_id")
  completedAt DateTime? @map("completed_at")
  cleanedAt   DateTime? @map("cleaned_at")

  errorMessage String? @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text

  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@map("test_environments")
}

// ═══════════════════════════════════════════════════════
// TEST RUNNER  (OPS-2)
// ═══════════════════════════════════════════════════════

enum TestRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TestType {
  UNIT
  FUNCTIONAL
  SMOKE
  INTEGRATION
  ARCHITECTURE
  PENETRATION
}

enum TestResultStatus {
  PASS
  FAIL
  SKIP
  ERROR
  TIMEOUT
}

model TestRun {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  testEnvId      String?       @map("test_env_id")

  runType        String        @map("run_type")
  testTypes      String[]      @map("test_types")
  targetModules  String[]      @map("target_modules")

  status          TestRunStatus @default(QUEUED)
  progressPercent Int           @default(0) @map("progress_percent")
  currentPhase    String?       @map("current_phase")

  totalTests Int @default(0) @map("total_tests")
  passed     Int @default(0)
  failed     Int @default(0)
  skipped    Int @default(0)
  errors     Int @default(0)
  duration   Int @default(0)

  summary         Json  @default("{}")
  coveragePercent Float? @map("coverage_percent")
  coverageReport  Json?  @map("coverage_report")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdById String    @map("created_by_id")

  results     TestResult[]
  errorLogs   TestErrorLog[]
  report      TestReport?

  @@index([tenantId])
  @@index([status])
  @@index([testEnvId])
  @@map("test_runs")
}

model TestResult {
  id        String  @id @default(uuid())
  testRunId String  @map("test_run_id")
  testRun   TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  testType  TestType @map("test_type")
  suiteName String   @map("suite_name")
  testName  String   @map("test_name")
  filePath  String?  @map("file_path")
  module    String?

  status   TestResultStatus
  duration Int              @default(0)

  errorMessage  String? @map("error_message") @db.Text
  errorStack    String? @map("error_stack") @db.Text
  expectedValue String? @map("expected_value") @db.Text
  actualValue   String? @map("actual_value") @db.Text

  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  errorLogs TestErrorLog[]

  @@index([testRunId])
  @@index([testRunId, testType])
  @@index([testRunId, status])
  @@index([module])
  @@map("test_results")
}

// ═══════════════════════════════════════════════════════
// TEST GROUPS + MANUAL TESTING  (OPS-3)
