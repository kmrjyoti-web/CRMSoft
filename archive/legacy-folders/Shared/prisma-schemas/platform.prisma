}

model TestGroupExecution {
  id          String    @id @default(uuid())
  testGroupId String    @map("test_group_id")
  testGroup   TestGroup @relation(fields: [testGroupId], references: [id])
  testRunId   String?   @map("test_run_id")
  testEnvId   String?   @map("test_env_id")
  tenantId    String    @map("tenant_id")

  status      String @default("RUNNING")
  currentStep Int    @default(0) @map("current_step")
  totalSteps  Int    @map("total_steps")

  stepResults  Json @default("[]") @map("step_results")

  totalPassed Int @default(0) @map("total_passed")
  totalFailed Int @default(0) @map("total_failed")
  totalErrors Int @default(0) @map("total_errors")
  duration    Int @default(0)

  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  executedById String    @map("executed_by_id")

  @@index([testGroupId])
  @@index([tenantId])
  @@map("test_group_executions")
}

model ManualTestLog {
  id          String  @id @default(uuid())
  testRunId   String? @map("test_run_id")
  testGroupId String? @map("test_group_id")
  tenantId    String  @map("tenant_id")
  userId      String  @map("user_id")

  module     String
  pageName   String @map("page_name")
  action     String

  expectedResult String @map("expected_result") @db.Text
  actualResult   String @map("actual_result") @db.Text
  status         String @default("PASS")
  severity       String?

  screenshotUrls Json    @default("[]") @map("screenshot_urls")
  videoUrl       String? @map("video_url")
  notes          String? @db.Text

  browser          String?
  os               String?
  screenResolution String? @map("screen_resolution")

  bugReported Boolean @default(false) @map("bug_reported")
  bugId       String? @map("bug_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([testRunId])
  @@index([module])
  @@index([status])
  @@map("manual_test_logs")
}

// ═══════════════════════════════════════════════════════
// SCHEDULED TESTS  (OPS-4)
// ═══════════════════════════════════════════════════════

model ScheduledTest {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")

  name           String
  description    String?       @db.Text

  cronExpression String        @map("cron_expression")   // e.g. "0 2 * * *"
  targetModules  String[]      @map("target_modules")    // ["invoicing", "payments"]
  testTypes      String[]      @map("test_types")         // TestType values as strings

  dbSourceType   TestEnvSourceType @default(BACKUP_RESTORE) @map("db_source_type")

  isActive       Boolean       @default(true) @map("is_active")
  lastRunAt      DateTime?     @map("last_run_at")
  nextRunAt      DateTime?     @map("next_run_at")
  lastRunStatus  TestRunStatus? @map("last_run_status")

  isDeleted      Boolean       @default(false) @map("is_deleted")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  createdById    String        @map("created_by_id")

  runs ScheduledTestRun[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([nextRunAt])
  @@map("scheduled_tests")
}

model ScheduledTestRun {
  id               String        @id @default(uuid())
  scheduledTestId  String        @map("scheduled_test_id")
  scheduledTest    ScheduledTest @relation(fields: [scheduledTestId], references: [id], onDelete: Cascade)

  testRunId       String?       @map("test_run_id")
  backupRecordId  String?       @map("backup_record_id")
  testEnvId       String?       @map("test_env_id")

  status          TestRunStatus
  errorMessage    String?       @map("error_message") @db.Text

  startedAt       DateTime      @default(now()) @map("started_at")
  completedAt     DateTime?     @map("completed_at")

  @@index([scheduledTestId])
  @@index([scheduledTestId, status])
  @@map("scheduled_test_runs")
}

// ═══════════════════════════════════════════════════════
// DATABASE BACKUP RECORDS  (OPS Safety Protocol)
// ═══════════════════════════════════════════════════════

model DatabaseBackupRecord {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")

  dbName       String    @map("db_name")
  backupUrl    String    @map("backup_url")
  checksum     String                         // SHA-256 of backup file
  sizeBytes    BigInt    @map("size_bytes")
  tableCount   Int?      @map("table_count")
  rowCount     BigInt?   @map("row_count")

  isValidated  Boolean   @default(false) @map("is_validated")
  validatedAt  DateTime? @map("validated_at")
  expiresAt    DateTime? @map("expires_at")

  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([tenantId, isValidated])
  @@index([tenantId, createdAt])
  @@map("database_backup_records")
}

// ═══════════════════════════════════════════════════════
// TEST PLAN  (Structured manual QA checklists)
// ═══════════════════════════════════════════════════════

enum TestPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TestPlanItemStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
  FAILED
  PARTIAL
  BLOCKED
  SKIPPED
}

enum TestPlanItemPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TestPlan {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  name            String
  description     String?         @db.Text
  version         String?                              // e.g. "v2.1.0"
  targetModules   String[]        @map("target_modules")

  status          TestPlanStatus  @default(DRAFT)
  totalItems      Int             @default(0) @map("total_items")
  passedItems     Int             @default(0) @map("passed_items")
  failedItems     Int             @default(0) @map("failed_items")
  completedItems  Int             @default(0) @map("completed_items")
  progress        Float           @default(0)          // 0–100 percentage

  notionPageId    String?         @map("notion_page_id")
  notionSyncedAt  DateTime?       @map("notion_synced_at")

  isActive        Boolean         @default(true) @map("is_active")
  createdById     String          @map("created_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  items           TestPlanItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("test_plans")
}

model TestPlanItem {
  id              String               @id @default(uuid())
  planId          String               @map("plan_id")
  plan            TestPlan             @relation(fields: [planId], references: [id], onDelete: Cascade)

  moduleName      String               @map("module_name")
  componentName   String               @map("component_name")
  functionality   String               @db.Text           // what to test
  layer           String                                   // "UI" | "API" | "DB" | "ARCH"
  priority        TestPlanItemPriority @default(MEDIUM)

  status          TestPlanItemStatus   @default(NOT_STARTED)
  testedById      String?              @map("tested_by_id")
  testedAt        DateTime?            @map("tested_at")
  notes           String?              @db.Text
  errorDetails    String?              @db.Text @map("error_details")

  notionBlockId   String?              @map("notion_block_id")

  sortOrder       Int                  @default(0) @map("sort_order")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  evidences       TestEvidence[]

  @@index([planId])
  @@index([planId, status])
  @@index([moduleName])
  @@map("test_plan_items")
}

model TestEvidence {
  id              String       @id @default(uuid())
  planItemId      String       @map("plan_item_id")
  planItem        TestPlanItem @relation(fields: [planItemId], references: [id], onDelete: Cascade)

  fileType        String       @map("file_type")    // "image" | "document" | "log" | "video"
  fileName        String       @map("file_name")
  filePath        String       @map("file_path")    // R2 storage key
  fileSize        Int?         @map("file_size")    // bytes
  mimeType        String?      @map("mime_type")
  caption         String?

  uploadedById    String?      @map("uploaded_by_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([planItemId])
  @@map("test_evidences")
}

// ═══════════════════════════════════════════════════════════════
// PHASE 2 — TEST ERROR LOG + TEST REPORT
// ═══════════════════════════════════════════════════════════════

enum TestErrorCategory {
  FUNCTIONAL
  VALIDATION
  DATABASE
  UI_RENDER
  API_CONTRACT
  ARCHITECTURE
  SECURITY
  PERFORMANCE
  CONFIGURATION
  OTHER
}

enum TestSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TestErrorLog {
  id              String            @id @default(uuid())
  testRunId       String            @map("test_run_id")
  testRun         TestRun           @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testResultId    String?           @map("test_result_id")
  testResult      TestResult?       @relation(fields: [testResultId], references: [id])

  errorCategory   TestErrorCategory @map("error_category")
  severity        TestSeverity      @default(MEDIUM)
  errorCode       String?           @map("error_code")
  message         String            @db.Text
  details         String?           @db.Text
  stackTrace      String?           @map("stack_trace") @db.Text

  moduleName      String?           @map("module_name")
  componentName   String?           @map("component_name")
  filePath        String?           @map("file_path")

  isReportable    Boolean           @default(false) @map("is_reportable")
  reportedToVendor Boolean          @default(false) @map("reported_to_vendor")
  reportedAt      DateTime?         @map("reported_at")
  vendorResponse  String?           @map("vendor_response") @db.Text

  isResolved      Boolean           @default(false) @map("is_resolved")
  resolvedBy      String?           @map("resolved_by")
  resolvedAt      DateTime?         @map("resolved_at")
  resolution      String?           @db.Text

  createdAt       DateTime          @default(now()) @map("created_at")

  @@index([testRunId])
  @@index([errorCategory])
  @@index([severity])
  @@index([isResolved])
  @@map("test_error_logs")
}

model TestReport {
  id              String    @id @default(uuid())
  testRunId       String    @unique @map("test_run_id")
  testRun         TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)

  summary         Json      @default("{}")
  categoryResults Json      @default("{}") @map("category_results")
  moduleResults   Json      @default("{}") @map("module_results")
  errorSummary    Json      @default("{}") @map("error_summary")
  recommendations Json?

  reportFilePath  String?   @map("report_file_path")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("test_reports")
}
