model ModuleDefinition {
  id           String         @id @default(uuid())
  code         String         @unique
  name         String
  description  String?
  category     ModuleCategory
  version      String         @default("1.0.0")
  moduleStatus ModuleStatus   @default(ACTIVE) @map("module_status")
  isCore       Boolean        @default(false) @map("is_core")
  iconName     String?        @map("icon_name")
  sortOrder    Int            @default(0) @map("sort_order")

  // Dependencies
  dependsOn   String[] @default([]) @map("depends_on")
  autoEnables String[] @default([]) @map("auto_enables")

  // Features (JSONB array of module features)
  // [{ code, name, type (PAGE/WIDGET/REPORT/ACTION), menuKey, isDefault }]
  features Json @default("[]")

  // Menu keys this module controls
  menuKeys String[] @default([]) @map("menu_keys")

  // Config
  applicableTypes Json    @default("[\"ALL\"]") @map("applicable_types")
  source          String  @default("PLATFORM")
  vendorId        String? @map("vendor_id")

  // Pricing
  defaultPricingType ModulePricingType @default(INCLUDED) @map("default_pricing_type")
  isFreeInBase       Boolean           @default(false) @map("is_free_in_base")
  basePrice          Decimal           @default(0) @map("base_price") @db.Decimal(12, 2)
  priceMonthly       Decimal?          @map("price_monthly") @db.Decimal(12, 2)
  priceYearly        Decimal?          @map("price_yearly") @db.Decimal(12, 2)
  oneTimeSetupFee    Decimal?          @map("one_time_setup_fee") @db.Decimal(12, 2)

  // Trial
  trialDays     Int      @default(0) @map("trial_days")
  trialFeatures String[] @default([]) @map("trial_features")

  // Usage pricing (pay-per-extra) JSONB
  // { perLead: 10, perContact: 5, perQuotation: 15 }
  usagePricing Json? @map("usage_pricing")

  // Credentials
  requiresCredentials Boolean @default(false) @map("requires_credentials")
