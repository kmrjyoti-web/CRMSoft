model Coupon {
  id                 String        @id @default(uuid())
  code               String        @unique
  type               CouponType
  value              Int
  maxUses            Int           @default(1) @map("max_uses")
  usedCount          Int           @default(0) @map("used_count")
  minRecharge        Decimal?      @map("min_recharge") @db.Decimal(12, 2)
  expiresAt          DateTime?     @map("expires_at")
  isActive           Boolean       @default(true) @map("is_active")
  // Subscription coupon fields
  industryCode       String?       @map("industry_code")
  description        String?
  discountType       DiscountType? @map("discount_type")
  discountValue      Decimal?      @map("discount_value") @db.Decimal(12, 2)
  maxDiscountInr     Decimal?      @map("max_discount_inr") @db.Decimal(12, 2)
  applicablePackages Json          @default("[\"ALL\"]") @map("applicable_packages")
  applicableTypes    Json          @default("[\"ALL\"]") @map("applicable_types")
  validFrom          DateTime?     @map("valid_from")
  validUntil         DateTime?     @map("valid_until")
  perUserLimit       Int           @default(1) @map("per_user_limit")
  firstTimeOnly      Boolean       @default(false) @map("first_time_only")
  createdBy          String?       @map("created_by")
  packageId          String?       @map("package_id")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  package     SubscriptionPackage? @relation(fields: [packageId], references: [id])
  redemptions CouponRedemption[]

  @@map("coupons")
}

