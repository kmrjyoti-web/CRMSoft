model Wallet {
  id             String   @id @default(uuid())
  tenantId       String   @unique @map("tenant_id")
  balance        Int      @default(0)
  promoBalance   Int      @default(0) @map("promo_balance")
  lifetimeCredit Int      @default(0) @map("lifetime_credit")
  lifetimeDebit  Int      @default(0) @map("lifetime_debit")
  currency       String   @default("INR")
  tokenRate      Int      @default(100) @map("token_rate")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId])
  @@map("wallets")
}

model WalletTransaction {
  id            String          @id @default(uuid())
  walletId      String          @map("wallet_id")
  tenantId      String          @map("tenant_id")
  type          WalletTxnType
  status        WalletTxnStatus @default(WTX_COMPLETED)
  tokens        Int
  balanceBefore Int             @map("balance_before")
  balanceAfter  Int             @map("balance_after")
  description   String
  referenceType String?         @map("reference_type")
  referenceId   String?         @map("reference_id")
  serviceKey    String?         @map("service_key")
  metadata      Json?
  createdById   String?         @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([walletId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@map("wallet_transactions")
}

model RechargePlan {
