{
  "name": "crm-soft",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Shared/common",
    "Shared/frontend",
    "Shared/prisma-schemas",
    "Shared/backend/identity",
    "Shared/backend/tenant",
    "Shared/backend/errors",
    "Shared/backend/notifications",
    "Shared/backend/storage",
    "Shared/backend/audit",
    "Shared/backend/cache",
    "Shared/backend/encryption",
    "Shared/backend/global-data",
    "Shared/backend/prisma",
    "Shared/backend/queue"
  ],
  "scripts": {
    "kill": "npx kill-port 3001 3005 3006 3007 3008 3009 3010 3011 3012",
    "dev:banner": "echo '\n╔══════════════════════════════════════════════════════╗' && echo '║            🚀 CRMSoft Dev Servers Starting           ║' && echo '╠══════════════════════════════════════════════════════╣' && echo '║  APP                 │  PORT   │  URL                ║' && echo '╠══════════════════════════════════════════════════════╣' && echo '║  API (NestJS)        │  3001   │  http://localhost:3001  ║' && echo '║  CRM Admin           │  3005   │  http://localhost:3005  ║' && echo '║  Vendor Panel        │  3006   │  http://localhost:3006  ║' && echo '║  Customer Portal     │  3007   │  http://localhost:3007  ║' && echo '║  Marketplace         │  3008   │  http://localhost:3008  ║' && echo '║  WL API              │  3010   │  http://localhost:3010  ║' && echo '║  WL Admin            │  3009   │  http://localhost:3009  ║' && echo '║  WL Partner          │  3011   │  http://localhost:3011  ║' && echo '║  Platform Console    │  3012   │  http://localhost:3012  ║' && echo '╚══════════════════════════════════════════════════════╝\n'",
    "dev": "npm run kill && npm run dev:banner && concurrently --names \"API,ADMIN,VENDOR,PORTAL,MKT,WL-API,WL-ADMIN,WL-PARTNER,PC\" --prefix-colors \"cyan,magenta,yellow,green,blue,red,white,gray,bright-blue\" \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:vendor\" \"npm run dev:portal\" \"npm run dev:marketplace\" \"npm run dev:wl-api\" \"npm run dev:wl-admin\" \"npm run dev:wl-partner\" \"npm run dev:platform-console\"",
    "dev:crm": "npm run kill && npm run dev:banner:crm && concurrently --names \"API,ADMIN,VENDOR,PORTAL\" --prefix-colors \"cyan,magenta,yellow,green\" \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:vendor\" \"npm run dev:portal\"",
    "dev:banner:crm": "echo '\n╔══════════════════════════════════════════════════════╗' && echo '║            🚀 CRMSoft CRM Dev Servers               ║' && echo '╠══════════════════════════════════════════════════════╣' && echo '║  API (NestJS)        │  3001   │  http://localhost:3001  ║' && echo '║  CRM Admin           │  3005   │  http://localhost:3005  ║' && echo '║  Vendor Panel        │  3006   │  http://localhost:3006  ║' && echo '║  Customer Portal     │  3007   │  http://localhost:3007  ║' && echo '╚══════════════════════════════════════════════════════╝\n'",
    "dev:wl": "npm run dev:banner:wl && concurrently --names \"WL-API,WL-ADMIN,WL-PARTNER\" --prefix-colors \"red,white,gray\" \"npm run dev:wl-api\" \"npm run dev:wl-admin\" \"npm run dev:wl-partner\"",
    "dev:banner:wl": "echo '\n╔══════════════════════════════════════════════════════╗' && echo '║            🚀 CRMSoft WhiteLabel Servers             ║' && echo '╠══════════════════════════════════════════════════════╣' && echo '║  WL API              │  3010   │  http://localhost:3010  ║' && echo '║  WL Admin            │  3009   │  http://localhost:3009  ║' && echo '║  WL Partner          │  3011   │  http://localhost:3011  ║' && echo '╚══════════════════════════════════════════════════════╝\n'",
    "dev:api": "cd Application/backend && npm run start:dev",
    "dev:admin": "cd Customer/frontend/crm-admin && pnpm dev",
    "dev:vendor": "cd Vendor/frontend/vendor-panel && pnpm dev",
    "dev:portal": "cd Application/frontend/customer-portal && pnpm dev",
    "dev:marketplace": "cd Application/frontend/marketplace && npm run dev",
    "dev:wl-api": "cd WhiteLabel/wl-api && npm run start:dev",
    "dev:wl-admin": "cd WhiteLabel/wl-admin && npm run dev",
    "dev:wl-partner": "cd WhiteLabel/wl-partner && npm run dev",
    "dev:platform-console": "cd PlatformConsole/frontend/platform-console && npm run dev",
    "build:platform-console": "cd PlatformConsole/frontend/platform-console && npm run build",
    "build:api": "cd Application/backend && npm run build",
    "build:admin": "cd Customer/frontend/crm-admin && pnpm build",
    "build:vendor": "cd Vendor/frontend/vendor-panel && pnpm build",
    "build:portal": "cd Application/frontend/customer-portal && pnpm build",
    "build:marketplace": "cd Application/frontend/marketplace && npm run build",
    "build:wl-api": "cd WhiteLabel/wl-api && npm run build",
    "build:wl-admin": "cd WhiteLabel/wl-admin && npm run build",
    "build:wl-partner": "cd WhiteLabel/wl-partner && npm run build",
    "test:api": "cd Application/backend && npm run test",
    "test:wl": "cd WhiteLabel/wl-api && npm run test",
    "build:sdk": "npm run build --workspaces --if-present",
    "version:sdk": "npm version patch --workspaces --if-present",
    "publish:sdk": "npm publish --workspaces --if-present --registry https://npm.pkg.github.com",
    "work:close": "node scripts/work-close.js",
    "work:start": "node scripts/work-start.js",
    "work:status": "node scripts/work-status.js",
    "guard": "bash scripts/architecture-guard.sh",
    "guard:full": "bash scripts/weekly-health-check.sh",
    "health": "bash scripts/weekly-health-check.sh",
    "audit": "node scripts/npm-audit.js",
    "audit:fix": "node scripts/npm-audit.js --fix",
    "audit:ci": "node scripts/npm-audit.js --ci",
    "audit:report": "node scripts/npm-audit.js --json",
    "audit:full": "bash scripts/governance/audit-governance.sh",
    "check:demo-sync": "bash scripts/governance/demo-sync-check.sh",
    "check:demo-sync:fix": "bash scripts/governance/demo-sync-check.sh --fix",
    "check:seed": "bash scripts/governance/seed-integrity.sh",
    "check:branch": "bash scripts/governance/branch-check.sh",
    "smoke": "bash scripts/governance/smoke-test.sh",
    "test:backend": "cd Application/backend && npx jest --no-coverage --silent",
    "prepare": "husky",
    "work:pickup": "bash scripts/work/work-pickup.sh",
    "work:pickup:batch": "bash scripts/work/work-pickup.sh --batch",
    "work:shell:start": "bash scripts/work/work-start.sh",
    "work:shell:close": "bash scripts/work/work-close.sh",
    "work:shell:status": "bash scripts/work/work-status.sh",
    "backup": "bash scripts/lib/backup.sh",
    "backup:list": "ls -lah .claude/backups 2>/dev/null || echo 'no backups'",
    "railway:health": "bash scripts/governance/railway-health.sh",
    "db:push:safe": "bash scripts/governance/prisma-safety.sh",
    "db:push:platform": "bash scripts/governance/prisma-safety.sh prisma/platform/v1/ PLATFORM_DATABASE_URL",
    "db:push:identity": "bash scripts/governance/prisma-safety.sh prisma/identity/v1/ IDENTITY_DATABASE_URL",
    "db:push:console": "bash scripts/governance/prisma-safety.sh prisma/platform-console/v1/ PLATFORM_CONSOLE_DATABASE_URL",
    "compliance": "bash scripts/skills/indian-compliance.sh full",
    "compliance:gst": "bash scripts/skills/indian-compliance.sh gst",
    "compliance:pan": "bash scripts/skills/indian-compliance.sh pan",
    "compliance:hsn": "bash scripts/skills/indian-compliance.sh hsn",
    "compliance:currency": "bash scripts/skills/indian-compliance.sh currency",
    "railway:deploy": "bash scripts/cli/railway.sh deploy",
    "railway:env:sync": "bash scripts/cli/railway.sh env-sync",
    "railway:env:pull": "bash scripts/cli/railway.sh env-pull",
    "railway:logs": "bash scripts/cli/railway.sh logs",
    "railway:restart": "bash scripts/cli/railway.sh restart",
    "railway:status": "bash scripts/cli/railway.sh status",
    "docs": "cat .claude/HELP.md 2>/dev/null || echo 'No HELP.md found. Run: pnpm help:generate'",
    "docs:credentials": "grep -A 20 'Login Credentials' .claude/HELP.md 2>/dev/null || echo 'No credentials section in HELP.md'",
    "docs:skills": "ls .claude/skills/ 2>/dev/null || echo 'No skills installed'",
    "help:generate": "bash scripts/skills/help-generator.sh",
    "whoami:git": "git config user.name && git config user.email && git remote -v",
    "security": "bash scripts/skills/security.sh full",
    "security:secrets": "bash scripts/skills/security.sh secrets",
    "security:deps": "bash scripts/skills/security.sh deps",
    "security:env": "bash scripts/skills/security.sh env",
    "security:auth": "bash scripts/skills/security.sh auth",
    "test:generate": "bash scripts/skills/test-generator.sh generate",
    "test:audit": "bash scripts/skills/test-generator.sh audit",
    "test:fix": "bash scripts/skills/test-generator.sh fix",
    "changelog": "bash scripts/skills/changelog.sh generate",
    "changelog:preview": "bash scripts/skills/changelog.sh preview",
    "perf": "bash scripts/skills/performance.sh full",
    "perf:bundle": "bash scripts/skills/performance.sh bundle",
    "perf:build": "bash scripts/skills/performance.sh build",
    "perf:tests": "bash scripts/skills/performance.sh tests",
    "perf:api": "bash scripts/skills/performance.sh api",
    "i18n:scan": "bash scripts/skills/i18n.sh scan",
    "i18n:missing": "bash scripts/skills/i18n.sh missing",
    "i18n:rtl": "bash scripts/skills/i18n.sh rtl",
    "i18n:extract": "bash scripts/skills/i18n.sh extract",
    "cost": "bash scripts/skills/cost.sh analyze",
    "cost:compare": "bash scripts/skills/cost.sh compare",
    "cost:forecast": "bash scripts/skills/cost.sh forecast"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
