// ═══════════════════════════════════════════════════════
// WORKFLOW ENGINE ENUMS
// ═══════════════════════════════════════════════════════

enum WorkflowStateType {
  INITIAL
  INTERMEDIATE
  TERMINAL
}

enum WorkflowStateCategory {
  SUCCESS
  FAILURE
  PAUSED
}

enum WorkflowTriggerType {
  MANUAL
  AUTO
  SCHEDULED
  APPROVAL
}

enum WorkflowApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ═══════════════════════════════════════════════════════
// WORKFLOW DEFINITION
// ═══════════════════════════════════════════════════════

model Workflow {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  name        String
  code        String
  entityType  String   @map("entity_type")
  description String?
  version     Int      @default(1)
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  configJson  Json?    @map("config_json")
  createdById String   @map("created_by_id")
  createdBy   User     @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  states      WorkflowState[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]

  @@unique([tenantId, code])
  @@index([entityType, isDefault])
  @@index([tenantId])
  @@map("workflows")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW STATE
// ═══════════════════════════════════════════════════════

model WorkflowState {
  id         String                 @id @default(uuid())
  tenantId   String                 @default("") @map("tenant_id")
  workflowId String                 @map("workflow_id")
  workflow   Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  name       String
  code       String
  stateType  WorkflowStateType      @map("state_type")
  category   WorkflowStateCategory?
  color      String?
  icon       String?
  sortOrder  Int                    @default(0) @map("sort_order")
  metadata   Json?
  isActive   Boolean                @default(true) @map("is_active")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  fromTransitions   WorkflowTransition[]    @relation("FromState")
  toTransitions     WorkflowTransition[]    @relation("ToState")
  currentInstances  WorkflowInstance[]      @relation("CurrentState")
  previousInstances WorkflowInstance[]      @relation("PreviousState")
  historyFrom       WorkflowHistory[]       @relation("HistoryFromState")
  historyTo         WorkflowHistory[]       @relation("HistoryToState")
  slaEscalations    WorkflowSlaEscalation[]

  @@unique([tenantId, workflowId, code])
  @@index([workflowId, stateType])
  @@index([tenantId])
  @@map("workflow_states")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW TRANSITION
// ═══════════════════════════════════════════════════════

model WorkflowTransition {
  id                 String              @id @default(uuid())
  tenantId           String              @default("") @map("tenant_id")
  workflowId         String              @map("workflow_id")
  workflow           Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStateId        String              @map("from_state_id")
  fromState          WorkflowState       @relation("FromState", fields: [fromStateId], references: [id])
  toStateId          String              @map("to_state_id")
  toState            WorkflowState       @relation("ToState", fields: [toStateId], references: [id])
  name               String
  code               String
  triggerType        WorkflowTriggerType @default(MANUAL) @map("trigger_type")
  conditions         Json?
  actions            Json?
  requiredPermission String?             @map("required_permission")
  requiredRole       String?             @map("required_role")
  sortOrder          Int                 @default(0) @map("sort_order")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  historyEntries WorkflowHistory[]
  approvals      WorkflowApproval[]
  actionLogs     WorkflowActionLog[]

  @@unique([tenantId, workflowId, code])
  @@index([workflowId, fromStateId])
  @@index([tenantId])
  @@map("workflow_transitions")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW INSTANCE (Runtime)
// ═══════════════════════════════════════════════════════

model WorkflowInstance {
  id              String         @id @default(uuid())
  tenantId        String         @default("") @map("tenant_id")
  workflowId      String         @map("workflow_id")
  workflow        Workflow       @relation(fields: [workflowId], references: [id])
  entityType      String         @map("entity_type")
  entityId        String         @map("entity_id")
  currentStateId  String         @map("current_state_id")
  currentState    WorkflowState  @relation("CurrentState", fields: [currentStateId], references: [id])
  previousStateId String?        @map("previous_state_id")
  previousState   WorkflowState? @relation("PreviousState", fields: [previousStateId], references: [id])
  data            Json?
  startedAt       DateTime       @default(now()) @map("started_at")
  completedAt     DateTime?      @map("completed_at")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  history     WorkflowHistory[]
  approvals   WorkflowApproval[]
  actionLogs  WorkflowActionLog[]
  escalations WorkflowSlaEscalation[]

  @@unique([tenantId, entityType, entityId, workflowId])
  @@index([entityType, entityId])
  @@index([workflowId, currentStateId])
  @@index([isActive, currentStateId])
  @@index([tenantId])
  @@map("workflow_instances")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW HISTORY (Audit Trail)
// ═══════════════════════════════════════════════════════

model WorkflowHistory {
  id              String              @id @default(uuid())
  tenantId        String              @default("") @map("tenant_id")
  instanceId      String              @map("instance_id")
  instance        WorkflowInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fromStateId     String?             @map("from_state_id")
  fromState       WorkflowState?      @relation("HistoryFromState", fields: [fromStateId], references: [id])
  toStateId       String              @map("to_state_id")
  toState         WorkflowState       @relation("HistoryToState", fields: [toStateId], references: [id])
  transitionId    String?             @map("transition_id")
  transition      WorkflowTransition? @relation(fields: [transitionId], references: [id])
  action          String
  performedById   String              @map("performed_by_id")
  performedByName String              @map("performed_by_name")
  comment         String?
  metadata        Json?
  duration        Int?
  createdAt       DateTime            @default(now()) @map("created_at")

  @@index([instanceId, createdAt])
  @@index([tenantId])
  @@map("workflow_history")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW APPROVAL
// ═══════════════════════════════════════════════════════

model WorkflowApproval {
  id            String                 @id @default(uuid())
  tenantId      String                 @default("") @map("tenant_id")
  instanceId    String                 @map("instance_id")
  instance      WorkflowInstance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  transitionId  String                 @map("transition_id")
  transition    WorkflowTransition     @relation(fields: [transitionId], references: [id])
  requestedById String                 @map("requested_by_id")
  approvedById  String?                @map("approved_by_id")
  status        WorkflowApprovalStatus @default(PENDING)
  comment       String?
  expiresAt     DateTime?              @map("expires_at")
  decidedAt     DateTime?              @map("decided_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")

  @@index([instanceId, status])
  @@index([requestedById])
  @@index([tenantId])
  @@map("workflow_approvals")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW ACTION LOG
// ═══════════════════════════════════════════════════════

model WorkflowActionLog {
  id           String             @id @default(uuid())
  tenantId     String             @default("") @map("tenant_id")
  instanceId   String             @map("instance_id")
  instance     WorkflowInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  transitionId String             @map("transition_id")
  transition   WorkflowTransition @relation(fields: [transitionId], references: [id])
  actionType   String             @map("action_type")
  actionConfig Json?              @map("action_config")
  result       Json?
  status       String             @default("PENDING")
  errorMessage String?            @map("error_message")
  executedAt   DateTime?          @map("executed_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([instanceId, actionType])
  @@index([tenantId])
  @@map("workflow_action_logs")
}

// ═══════════════════════════════════════════════════════
// WORKFLOW SLA ESCALATION
// ═══════════════════════════════════════════════════════

model WorkflowSlaEscalation {
  id              String           @id @default(uuid())
  tenantId        String           @default("") @map("tenant_id")
  instanceId      String           @map("instance_id")
  instance        WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stateId         String           @map("state_id")
  state           WorkflowState    @relation(fields: [stateId], references: [id])
  slaHours        Int              @map("sla_hours")
  escalatedToId   String?          @map("escalated_to_id")
  escalationLevel Int              @default(1) @map("escalation_level")
  escalatedAt     DateTime         @default(now()) @map("escalated_at")
  resolvedAt      DateTime?        @map("resolved_at")
  isResolved      Boolean          @default(false) @map("is_resolved")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([instanceId, isResolved])
  @@index([tenantId])
  @@map("workflow_sla_escalations")
}

