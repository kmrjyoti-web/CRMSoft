  @@index([recipientId, isSent])
  @@index([tenantId, recipientId, status])
  @@index([tenantId, scheduledAt, status])
  @@index([entityType, entityId])
  @@index([taskId])
  @@index([tenantId])
  @@map("reminders")
}

