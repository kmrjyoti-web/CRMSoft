enum HelpType {
  DEVELOPER
  USER
}

model HelpArticle {
  id              String   @id @default(uuid())
  articleCode     String   @unique @map("article_code")
  title           String
  content         String   @db.Text
  summary         String
  helpType        HelpType @map("help_type")
  moduleCode      String?  @map("module_code")
  screenCode      String?  @map("screen_code")
  fieldCode       String?  @map("field_code")
  applicableTypes Json     @default("[\"ALL\"]") @map("applicable_types")
  usesTerminology Boolean  @default(false) @map("uses_terminology")
  videoUrl        String?  @map("video_url")
  videoThumbnail  String?  @map("video_thumbnail")
