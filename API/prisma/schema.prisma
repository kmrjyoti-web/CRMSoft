// ═══════════════════════════════════════════════════════════════════
// PAYMENT & INVOICE MODULE
// ═══════════════════════════════════════════════════════════════════

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOID
}

enum PaymentMethod {
  CASH
  CHEQUE
  BANK_TRANSFER
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
  WALLET
  RAZORPAY
  STRIPE
  OTHER
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
  MANUAL
}

enum RefundStatus {
  REFUND_PENDING
  REFUND_PROCESSED
  REFUND_FAILED
  REFUND_CANCELLED
}

enum CreditNoteStatus {
  CN_DRAFT
  CN_ISSUED
  CN_APPLIED
  CN_CANCELLED
}

enum ReminderLevel {
  GENTLE
  FIRM
  URGENT
  FINAL
}

// ─── INVOICE ───
model Invoice {
  id        String        @id @default(uuid())
  tenantId  String        @default("") @map("tenant_id")
  invoiceNo String        @map("invoice_no")
  status    InvoiceStatus @default(DRAFT)

  // ─── SOURCE ───
  quotationId       String?    @map("quotation_id")
  quotation         Quotation? @relation(fields: [quotationId], references: [id])
  leadId            String?    @map("lead_id")
  lead              Lead?      @relation(fields: [leadId], references: [id])
  saleOrderId       String?    @map("sale_order_id")
  deliveryChallanId String?    @map("delivery_challan_id")
  inventoryEffect   Boolean    @default(true) @map("inventory_effect")
  accountsEffect    Boolean    @default(true) @map("accounts_effect")

  // ─── CUSTOMER ───
  contactId      String?       @map("contact_id")
  contact        Contact?      @relation(fields: [contactId], references: [id])
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // ─── BILLING INFO ───
  billingName      String  @map("billing_name")
  billingAddress   String? @map("billing_address")
  billingCity      String? @map("billing_city")
  billingState     String? @map("billing_state")
  billingPincode   String? @map("billing_pincode")
  billingGstNumber String? @map("billing_gst_number")
  shippingName     String? @map("shipping_name")
  shippingAddress  String? @map("shipping_address")
  shippingCity     String? @map("shipping_city")
  shippingState    String? @map("shipping_state")
  shippingPincode  String? @map("shipping_pincode")

  // ─── SELLER INFO (snapshot) ───
  sellerName      String  @map("seller_name")
  sellerAddress   String? @map("seller_address")
  sellerCity      String? @map("seller_city")
  sellerState     String? @map("seller_state")
  sellerPincode   String? @map("seller_pincode")
  sellerGstNumber String? @map("seller_gst_number")
  sellerPanNumber String? @map("seller_pan_number")

  // ─── DATES ───
  invoiceDate DateTime  @default(now()) @map("invoice_date")
  dueDate     DateTime  @map("due_date")
  supplyDate  DateTime? @map("supply_date")

  // ─── PRICING ───
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountType   String? @map("discount_type")
  discountValue  Decimal @default(0) @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount  Decimal @default(0) @map("taxable_amount") @db.Decimal(14, 2)
  cgstAmount     Decimal @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount     Decimal @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount     Decimal @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount     Decimal @default(0) @map("cess_amount") @db.Decimal(14, 2)
  totalTax       Decimal @default(0) @map("total_tax") @db.Decimal(14, 2)
  roundOff       Decimal @default(0) @map("round_off") @db.Decimal(14, 2)
  totalAmount    Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)
  amountInWords  String? @map("amount_in_words")

  // ─── PAYMENT TRACKING ───
  paidAmount    Decimal @default(0) @map("paid_amount") @db.Decimal(14, 2)
  balanceAmount Decimal @default(0) @map("balance_amount") @db.Decimal(14, 2)
  isInterState  Boolean @default(false) @map("is_inter_state")

  // ─── BANK DETAILS (snapshot) ───
  bankName      String? @map("bank_name")
  bankBranch    String? @map("bank_branch")
  accountNumber String? @map("account_number")
  ifscCode      String? @map("ifsc_code")
  upiId         String? @map("upi_id")

  // ─── NOTES ───
  notes              String?
  termsAndConditions String? @map("terms_and_conditions") @db.Text
  internalNotes      String? @map("internal_notes")

  // ─── AUDIT ───
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById String?   @map("cancelled_by_id")
  cancelReason  String?   @map("cancel_reason")

  // ─── RELATIONS ───
  lineItems       InvoiceLineItem[]
  payments        Payment[]
  creditNotes     CreditNote[]
  reminders       PaymentReminder[]
  proformaInvoice ProformaInvoice?

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, status])
  @@index([tenantId, contactId])
  @@index([tenantId, organizationId])
  @@index([tenantId, dueDate])
  @@index([quotationId])
  @@index([leadId])
  @@map("invoices")
}

// ─── INVOICE LINE ITEM ───
model InvoiceLineItem {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId   String? @map("product_id")
  productCode String? @map("product_code")
  productName String  @map("product_name")
  description String?
  hsnCode     String? @map("hsn_code")

  quantity Decimal @db.Decimal(10, 2)
  unit     String?

  unitPrice      Decimal  @map("unit_price") @db.Decimal(14, 2)
  mrp            Decimal? @db.Decimal(14, 2)
  discountType   String?  @map("discount_type")
  discountValue  Decimal? @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(14, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(14, 2)

  gstRate      Decimal? @map("gst_rate") @db.Decimal(5, 2)
  cgstAmount   Decimal  @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount   Decimal  @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount   Decimal  @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessRate     Decimal? @map("cess_rate") @db.Decimal(5, 2)
  cessAmount   Decimal  @default(0) @map("cess_amount") @db.Decimal(14, 2)
  taxAmount    Decimal  @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalWithTax Decimal  @map("total_with_tax") @db.Decimal(14, 2)

  sortOrder Int     @default(0) @map("sort_order")
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([invoiceId])
  @@index([tenantId])
  @@map("invoice_line_items")
}

// ─── PROFORMA INVOICE ───

enum ProformaInvoiceStatus {
  PI_DRAFT
  PI_SENT
  PI_ACCEPTED
  PI_REJECTED
  PI_CONVERTED
  PI_CANCELLED
}

model ProformaInvoice {
  id         String                @id @default(uuid())
  tenantId   String                @default("") @map("tenant_id")
  proformaNo String                @map("proforma_no")
  status     ProformaInvoiceStatus @default(PI_DRAFT)

  // ─── SOURCE ───
  quotationId String?    @map("quotation_id")
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  leadId      String?    @map("lead_id")
  lead        Lead?      @relation(fields: [leadId], references: [id])

  // ─── CUSTOMER ───
  contactId      String?       @map("contact_id")
  contact        Contact?      @relation(fields: [contactId], references: [id])
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // ─── BILLING INFO ───
  billingName      String  @map("billing_name")
  billingAddress   String? @map("billing_address")
  billingCity      String? @map("billing_city")
  billingState     String? @map("billing_state")
  billingPincode   String? @map("billing_pincode")
  billingGstNumber String? @map("billing_gst_number")

  // ─── SELLER INFO (snapshot) ───
  sellerName      String  @map("seller_name")
  sellerAddress   String? @map("seller_address")
  sellerCity      String? @map("seller_city")
  sellerState     String? @map("seller_state")
  sellerPincode   String? @map("seller_pincode")
  sellerGstNumber String? @map("seller_gst_number")
  sellerPanNumber String? @map("seller_pan_number")

  // ─── DATES ───
  proformaDate DateTime  @default(now()) @map("proforma_date")
  validUntil   DateTime? @map("valid_until")

  // ─── PRICING ───
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountType   String? @map("discount_type")
  discountValue  Decimal @default(0) @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount  Decimal @default(0) @map("taxable_amount") @db.Decimal(14, 2)
  cgstAmount     Decimal @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount     Decimal @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount     Decimal @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount     Decimal @default(0) @map("cess_amount") @db.Decimal(14, 2)
  totalTax       Decimal @default(0) @map("total_tax") @db.Decimal(14, 2)
  roundOff       Decimal @default(0) @map("round_off") @db.Decimal(14, 2)
  totalAmount    Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)
  amountInWords  String? @map("amount_in_words")
  isInterState   Boolean @default(false) @map("is_inter_state")

  // ─── CONVERTED INVOICE REF ───
  invoiceId String?  @unique @map("invoice_id")
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  // ─── LINE ITEMS ───
  lineItems ProformaLineItem[]

  // ─── NOTES ───
  notes              String?
  termsAndConditions String? @map("terms_and_conditions") @db.Text
  internalNotes      String? @map("internal_notes")

  // ─── AUDIT ───
  createdById   String    @map("created_by_id")
  createdBy     User      @relation("ProformaCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  cancelledAt   DateTime? @map("cancelled_at")
  cancelledById String?   @map("cancelled_by_id")
  cancelReason  String?   @map("cancel_reason")

  @@unique([tenantId, proformaNo])
  @@index([tenantId, status])
  @@index([tenantId, quotationId])
  @@index([tenantId, leadId])
  @@map("proforma_invoices")
}

model ProformaLineItem {
