  @@index([tenantId, productId])
  @@index([tenantId, expiryDate])
  @@map("serial_masters")
}

// ─── BOM MODULE (Phase 2 — tables only) ───

model BOMFormula {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  finishedProductId String @map("finished_product_id")
  formulaName       String @map("formula_name")
  formulaCode       String @map("formula_code")

  yieldQuantity Decimal @default(1) @map("yield_quantity") @db.Decimal(10, 3)
  yieldUnit     String  @default("piece") @map("yield_unit")

  prepTime     Int?    @map("prep_time")
  cookTime     Int?    @map("cook_time")
  instructions String? @db.Text

  industryCode String? @map("industry_code")
  isActive     Boolean @default(true) @map("is_active")
  version      Int     @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  finishedProduct InventoryItem    @relation("FinishedProduct", fields: [finishedProductId], references: [id])
  items           BOMFormulaItem[]
  productions     BOMProduction[]

  @@unique([tenantId, formulaCode])
  @@index([tenantId])
  @@map("bom_formulas")
}

model BOMFormulaItem {
  id        String @id @default(uuid())
  tenantId    String   @map("tenant_id")
  formulaId String @map("formula_id")

  rawMaterialId     String   @map("raw_material_id")
  quantity          Decimal  @db.Decimal(10, 3)
  unit              String   @default("gram")
  wastagePercent    Decimal? @map("wastage_percent") @db.Decimal(5, 2)
  effectiveQuantity Decimal? @map("effective_quantity") @db.Decimal(10, 3)

  isCritical          Boolean @default(true) @map("is_critical")
  substituteProductId String? @map("substitute_product_id")
  sortOrder           Int     @default(0) @map("sort_order")

  formula     BOMFormula    @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  rawMaterial InventoryItem @relation("RawMaterial", fields: [rawMaterialId], references: [id])

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  @@index([tenantId])
  @@map("bom_formula_items")
}

model BOMProduction {
  id        String @id @default(uuid())
  tenantId  String @default("") @map("tenant_id")
  formulaId String @map("formula_id")

  quantityOrdered  Int     @map("quantity_ordered")
  quantityProduced Int     @default(0) @map("quantity_produced")
  scrapQuantity    Int     @default(0) @map("scrap_quantity")
  scrapReason      String? @map("scrap_reason")

  status String @default("PLANNED")

  productionDate DateTime  @default(now()) @map("production_date")
  completedDate  DateTime? @map("completed_date")
  createdById    String?   @map("created_by_id")

  formula BOMFormula @relation(fields: [formulaId], references: [id])

  @@index([tenantId])
  @@map("bom_productions")
}

// ─── SCRAP MODULE ───

model ScrapRecord {
