  @@unique([tenantId, fromProductId, toProductId, relationType])
  @@index([tenantId])
  @@map("product_relations")
}

// ═══════════════════════════════════════════════════════
// PRODUCT FILTER (LookupValue)
// ═══════════════════════════════════════════════════════

model ProductFilter {
