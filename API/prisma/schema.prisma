model MarketplaceVendor {
  id              String       @id @default(uuid())
  companyName     String       @map("company_name")
  contactName     String?      @map("contact_name")
  contactEmail    String       @unique @map("contact_email")
  password        String?
  gstNumber       String?      @map("gst_number")
  bankAccountEnc  String?      @map("bank_account_enc") @db.Text
  revenueSharePct Decimal      @default(70) @map("revenue_share_pct") @db.Decimal(5, 2)
  status          VendorStatus @default(PENDING)
  verifiedAt      DateTime?    @map("verified_at")
  lastLoginAt     DateTime?    @map("last_login_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  modules MarketplaceModule[]

  @@map("marketplace_vendors")
}

model MarketplaceModule {
  id               String                  @id @default(uuid())
  vendorId         String                  @map("vendor_id")
  moduleCode       String                  @unique @map("module_code")
  moduleName       String                  @map("module_name")
  category         String
  shortDescription String                  @map("short_description")
  longDescription  String                  @map("long_description") @db.Text
  screenshots      Json                    @default("[]")
  demoVideoUrl     String?                 @map("demo_video_url")
  documentationUrl String?                 @map("documentation_url")
  changelog        Json                    @default("[]")
  version          String                  @default("1.0.0")
  status           MarketplaceModuleStatus @default(DRAFT)
  publishedAt      DateTime?               @map("published_at")
  launchOfferDays  Int?                    @map("launch_offer_days")
  launchOfferEnds  DateTime?               @map("launch_offer_ends")
  pricingPlans     Json                    @default("[]") @map("pricing_plans")
  usageLimits      Json                    @default("{}") @map("usage_limits")
  targetTypes      Json                    @default("[\"ALL\"]") @map("target_types")
  installCount     Int                     @default(0) @map("install_count")
  avgRating        Decimal                 @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount      Int                     @default(0) @map("review_count")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  vendor        MarketplaceVendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviews       MarketplaceReview[]
  installations TenantMarketplaceModule[]

  @@map("marketplace_modules")
}

model MarketplaceReview {
  id        String   @id @default(uuid())
  moduleId  String   @map("module_id")
  tenantId  String   @map("tenant_id")
  rating    Int
  title     String?
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, tenantId])
  @@index([moduleId])
  @@index([tenantId])
  @@map("marketplace_reviews")
}

model TenantMarketplaceModule {
  id             String                   @id @default(uuid())
  tenantId       String                   @map("tenant_id")
  moduleId       String                   @map("module_id")
  planId         String?                  @map("plan_id")
  status         MarketplaceInstallStatus @default(TRIAL)
  trialEndsAt    DateTime?                @map("trial_ends_at")
  subscriptionId String?                  @map("subscription_id")
  installedAt    DateTime                 @default(now()) @map("installed_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@map("tenant_marketplace_modules")
}

// ═══════════════════════════════════════════════════════
// SUBSCRIPTION PACKAGES & COUPONS
// ═══════════════════════════════════════════════════════

model SubscriptionPackage {
  id          String  @id @default(uuid())
  packageCode String  @unique @map("package_code")
  packageName String  @map("package_name")
  tagline     String?
  description String?
  tier        Int     @default(0) // 0=Free, 1=Basic, 2=Pro, 3=Enterprise

  // Pricing
  priceMonthlyInr   Decimal  @map("price_monthly_inr") @db.Decimal(12, 2)
  quarterlyPrice    Decimal? @map("quarterly_price") @db.Decimal(12, 2)
  priceYearlyInr    Decimal  @map("price_yearly_inr") @db.Decimal(12, 2)
  yearlyDiscountPct Decimal  @default(20) @map("yearly_discount_pct") @db.Decimal(5, 2)
  oneTimeSetupFee   Decimal? @map("one_time_setup_fee") @db.Decimal(12, 2)
  currency          String   @default("INR")

  // Trial
  trialDays Int @default(14) @map("trial_days")

  // Entity limits JSONB { CONTACTS: { limit: 500, extraPricePerUnit: 5 }, ... }
  entityLimits Json @default("{}") @map("entity_limits")

  // Legacy fields kept for compatibility
  applicableTypes Json  @default("[\"ALL\"]") @map("applicable_types")
  includedModules Json  @default("[]") @map("included_modules")
  limits          Json  @default("{}") @map("limits")
  introOfferJson  Json? @map("intro_offer_json")
  featureFlags    Json  @default("{}") @map("feature_flags")
  planLevel       Int   @default(0) @map("plan_level")

  // Database
  hasDedicatedDb Boolean @default(false) @map("has_dedicated_db")
  maxDbSizeMb    Int?    @map("max_db_size_mb")

  // Industry
  industryCode String? @map("industry_code")

  // Display
  isPopular  Boolean  @default(false) @map("is_popular")
  badgeText  String?  @map("badge_text")
  color      String?
  isActive   Boolean  @default(true) @map("is_active")
  isFeatured Boolean  @default(false) @map("is_featured")
  isPublic   Boolean  @default(true) @map("is_public")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  coupons          Coupon[]
  packageModules   PackageModule[]
  industryPackages IndustryPackage[]

  @@index([industryCode, isActive])
  @@map("subscription_packages")
}

enum DiscountType {
  PERCENT
  FLAT_INR
}

model CouponRedemption {
  id              String   @id @default(uuid())
  couponId        String   @map("coupon_id")
  tenantId        String   @map("tenant_id")
  userId          String   @map("user_id")
  discountApplied Decimal  @map("discount_applied") @db.Decimal(12, 2)
  redeemedAt      DateTime @default(now()) @map("redeemed_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, tenantId, userId])
  @@index([couponId])
  @@index([tenantId])
  @@map("coupon_redemptions")
}

