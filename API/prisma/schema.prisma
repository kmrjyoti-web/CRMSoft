// ═══════════════════════════════════════════════════════
// PACKAGE ↔ MODULE JUNCTION (Feature Control per Package)
// ═══════════════════════════════════════════════════════

model PackageModule {
  id        String @id @default(uuid())
  packageId String @map("package_id")
  moduleId  String @map("module_id")

  // Pricing for this module in this package
  pricingType ModulePricingType @default(INCLUDED)
  addonPrice  Decimal?          @map("addon_price") @db.Decimal(12, 2)
  oneTimeFee  Decimal?          @map("one_time_fee") @db.Decimal(12, 2)

  // Feature toggles (which features of this module are active in this package)
  // Empty = ALL features enabled
  enabledFeatures  String[] @default([]) @map("enabled_features")
  disabledFeatures String[] @default([]) @map("disabled_features")

  // Trial
  trialAllowed Boolean @default(true) @map("trial_allowed")
  trialDays    Int?    @map("trial_days")

  // Module-specific limit overrides JSONB
  moduleLimits Json? @map("module_limits")

  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  package SubscriptionPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  module  ModuleDefinition    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([packageId, moduleId])
  @@map("package_modules")
}

// ─── PAGE REGISTRY ────────────────────────────────────────────────────────────

model PageRegistry {
  id String @id @default(uuid())

  // Route info (auto-discovered)
  routePath     String  @unique @map("route_path")
  routePattern  String  @map("route_pattern")
  portal        String  @default("crm")
  filePath      String  @map("file_path")
  componentName String? @map("component_name")

  // Vendor-configurable
  friendlyName String? @map("friendly_name")
  description  String?
  pageType     String? @map("page_type")
  category     String?

  // Module assignment
  moduleCode String? @map("module_code")

  // Menu linking
  menuKey       String? @map("menu_key")
  menuLabel     String? @map("menu_label")
  menuIcon      String? @map("menu_icon")
  menuParentKey String? @map("menu_parent_key")
  menuSortOrder Int     @default(0) @map("menu_sort_order")
  showInMenu    Boolean @default(true) @map("show_in_menu")

  // Metadata (auto-discovered)
  hasParams   Boolean  @default(false) @map("has_params")
  paramNames  String[] @default([]) @map("param_names")
  isNested    Boolean  @default(false) @map("is_nested")
  parentRoute String?  @map("parent_route")

  // Features + API deps
  featuresCovered String[] @default([]) @map("features_covered")
  apiEndpoints    String[] @default([]) @map("api_endpoints")

  // Preview
  screenshotUrl String? @map("screenshot_url")
  previewUrl    String? @map("preview_url")

  // Industry
  industryCode String? @map("industry_code")

  // Status
  isActive         Boolean   @default(true) @map("is_active")
  isAutoDiscovered Boolean   @default(true) @map("is_auto_discovered")
  lastScannedAt    DateTime? @map("last_scanned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([portal])
  @@index([moduleCode])
  @@index([category])
  @@index([pageType])
  @@index([industryCode])
  @@map("page_registry")
}

// ═══════════════════════════════════════════════════════
// VERSION CONTROL SYSTEM
// ═══════════════════════════════════════════════════════

enum VersionStatus {
  DRAFT
  TESTING
  STAGED
  PUBLISHED
  ROLLED_BACK
  DEPRECATED
}

enum PatchStatus {
  PENDING
  APPLIED
  FAILED
  ROLLED_BACK
}

model AppVersion {
  id          String        @id @default(uuid())
  version     String        @unique
  codeName    String?       @map("code_name")
  releaseType String        @default("MINOR") @map("release_type") // MAJOR, MINOR, PATCH, HOTFIX
  status      VersionStatus @default(DRAFT)

  // Changelog
  changelog       Json    @default("[]") // [{ category, items[] }]
  breakingChanges Json    @default("[]") @map("breaking_changes")
  migrationNotes  String? @map("migration_notes")

  // Modules included in this version
  modulesUpdated String[] @default([]) @map("modules_updated")
  schemaChanges  Json?    @map("schema_changes") // { added: [], modified: [], removed: [] }

  // Git info
  gitTag        String? @map("git_tag")
  gitBranch     String? @map("git_branch")
  gitCommitHash String? @map("git_commit_hash")

  // Deployment info
  deployedAt     DateTime? @map("deployed_at")
  deployedBy     String?   @map("deployed_by")
  rollbackAt     DateTime? @map("rollback_at")
  rollbackReason String?   @map("rollback_reason")

  // Notion
  notionPageId String? @map("notion_page_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patches        IndustryPatch[]
  tenantVersions TenantVersion[]
  backups        VersionBackup[]

  @@index([status])
  @@index([releaseType])
  @@map("app_versions")
}

model IndustryPatch {
  id           String      @id @default(uuid())
  versionId    String      @map("version_id")
  industryCode String      @map("industry_code")
  patchName    String      @map("patch_name")
  description  String?
  status       PatchStatus @default(PENDING)

  // Patch content
  schemaChanges   Json? @map("schema_changes")
  seedData        Json? @map("seed_data")
  configOverrides Json? @map("config_overrides")
  menuOverrides   Json? @map("menu_overrides")

  // Execution
  appliedAt    DateTime? @map("applied_at")
  appliedBy    String?   @map("applied_by")
  errorLog     String?   @map("error_log")
  rollbackData Json?     @map("rollback_data")

  forceUpdate Boolean @default(false) @map("force_update")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, industryCode, patchName])
  @@index([industryCode])
  @@index([status])
  @@map("industry_patches")
}

model TenantVersion {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  versionId String @map("version_id")

  currentVersion  String  @map("current_version")
  previousVersion String? @map("previous_version")

  // Update tracking
  updatedAt    DateTime @default(now()) @map("updated_at_time")
  updatedBy    String?  @map("updated_by")
  updateMethod String   @default("AUTO") @map("update_method") // AUTO, MANUAL, FORCE

  // Status
  isActive       Boolean  @default(true) @map("is_active")
  patchesApplied String[] @default([]) @map("patches_applied")

  // Force update
  forceUpdatePending  Boolean   @default(false) @map("force_update_pending")
  forceUpdateMessage  String?   @map("force_update_message")
  forceUpdateDeadline DateTime? @map("force_update_deadline")

  createdAt DateTime @default(now()) @map("created_at")

  version AppVersion @relation(fields: [versionId], references: [id])

  @@unique([tenantId, versionId])
  @@index([tenantId])
  @@index([forceUpdatePending])
  @@map("tenant_versions")
}

model VersionBackup {
  id        String @id @default(uuid())
  versionId String @map("version_id")

  backupType String @default("PRE_DEPLOY") @map("backup_type") // PRE_DEPLOY, MANUAL, SCHEDULED

  // Backup details
  dbDumpPath     String? @map("db_dump_path")
  gitTag         String? @map("git_tag")
  configSnapshot Json?   @map("config_snapshot")
  schemaSnapshot String? @map("schema_snapshot")

  // Status
  status    String  @default("COMPLETED") // COMPLETED, FAILED, RESTORING, RESTORED
  sizeBytes BigInt? @map("size_bytes")

  // Restore info
  restoredAt DateTime? @map("restored_at")
  restoredBy String?   @map("restored_by")

  createdAt DateTime @default(now()) @map("created_at")

  version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([backupType])
  @@map("version_backups")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DOCUMENT TEMPLATE SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

enum DocumentType {
  GST_INVOICE
  PROFORMA_INVOICE
  QUOTATION
  RECEIPT
  PURCHASE_ORDER
  SALE_CHALLAN
  DELIVERY_CHALLAN
  CREDIT_NOTE
  DEBIT_NOTE
  CUSTOMER_STATEMENT
  SALES_REPORT
  STOCK_REPORT
  LEDGER_REPORT
  CUSTOM
}

model DocumentTemplate {
  id String @id @default(uuid())

  // ─── IDENTITY ───
  code         String
  name         String
  description  String?
  documentType DocumentType @map("document_type")

  // ─── TEMPLATE CONTENT ───
  templateVersion Int     @default(1) @map("template_version") // 1=Handlebars HTML, 2=Canvas JSON
  htmlTemplate    String  @map("html_template") @db.Text
  canvasJson      Json?   @map("canvas_json") // v2 canvas designer JSON
  cssStyles       String? @map("css_styles") @db.Text

  // ─── CUSTOMIZABLE SETTINGS (JSON) ───
  defaultSettings Json @default("{}") @map("default_settings")

  // ─── AVAILABLE DATA FIELDS ───
  availableFields Json @default("[]") @map("available_fields")

  // ─── INDUSTRY ───
  industryCode String? @map("industry_code")

  // ─── OWNERSHIP ───
  isSystem Boolean @default(true) @map("is_system")
  tenantId String? @map("tenant_id")

  // ─── DISPLAY ───
  thumbnailUrl String? @map("thumbnail_url")
  sortOrder    Int     @default(0) @map("sort_order")
  isDefault    Boolean @default(false) @map("is_default")
  isActive     Boolean @default(true) @map("is_active")

  // ─── AUDIT ───
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  tenantCustomizations TenantTemplateCustomization[]

  @@unique([code, tenantId])
  @@index([documentType, industryCode, isActive])
  @@index([tenantId])
  @@map("document_templates")
}

model TenantTemplateCustomization {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  templateId String @map("template_id")

  // ─── CUSTOMIZED SETTINGS ───
  customSettings Json @default("{}") @map("custom_settings")

  // ─── CUSTOM CONTENT OVERRIDES ───
  customHeader       String? @map("custom_header") @db.Text
  customFooter       String? @map("custom_footer") @db.Text
  termsAndConditions String? @map("terms_and_conditions") @db.Text
  bankDetails        String? @map("bank_details") @db.Text
  signatureUrl       String? @map("signature_url")
  logoUrl            String? @map("logo_url")

  // ─── STATUS ───
  isDefault Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([tenantId, templateId])
  @@index([tenantId])
  @@map("tenant_template_customizations")
}

// ─── SAVED FORMULAS (Report Designer) ───

model SavedFormula {
  id             String  @id @default(uuid())
  tenantId       String? @map("tenant_id") // null = system formula
  name           String
  category       String // e.g. "tax", "math", "text", "date"
  expression     String  @db.Text
  description    String?
  requiredFields Json    @default("[]") @map("required_fields") // string[]
  outputType     String  @default("number") @map("output_type") // "number" | "string" | "boolean"
  outputFormat   String? @map("output_format") // "currency" | "percentage" | "text"
  isSystem       Boolean @default(false) @map("is_system")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, tenantId])
  @@index([category])
  @@index([tenantId])
  @@map("saved_formulas")
}

// ═══════════════════════════════════════════════════════════════════
// INVENTORY SYSTEM
// ═══════════════════════════════════════════════════════════════════

enum InventoryType {
  SERIAL
  BATCH
  EXPIRY
  BOM
  SIMPLE
}

enum SerialStatus {
  AVAILABLE
  SOLD
  RESERVED
  EXPIRED
  DAMAGED
  RETURNED
  ACTIVATED
  DEACTIVATED
}

enum ExpiryType {
  FIXED_DATE
  DAYS
  MONTHS
  YEARS
  NEVER
}

enum InventoryTaxType {
  INV_GST
  INV_CESS
  INV_TDS
  INV_EXEMPT
  INV_ZERO_RATED
}

enum StockTransactionType {
  PURCHASE_IN
  SALE_OUT
  RETURN_IN
  TRANSFER
  ADJUSTMENT
  OPENING_BALANCE
  DAMAGE
  WRITE_OFF
  PRODUCTION_IN
  PRODUCTION_OUT
  SCRAP
}

enum AdjustmentStatus {
  ADJ_PENDING
  ADJ_APPROVED
  ADJ_REJECTED
}

enum ScrapType {
  SCRAP_EXPIRED
  SCRAP_DAMAGED
  SCRAP_PRODUCTION_WASTE
  SCRAP_RETURNED_DEFECTIVE
  SCRAP_QUALITY_FAILURE
}

// ─── CORE TABLES ───

model InventoryItem {
  id        String @id @default(uuid())
  tenantId  String @default("") @map("tenant_id")
  productId String @map("product_id")

  inventoryType InventoryType @default(SIMPLE) @map("inventory_type")

  currentStock  Int  @default(0) @map("current_stock")
  reservedStock Int  @default(0) @map("reserved_stock")
  minStockLevel Int? @map("min_stock_level")
  reorderLevel  Int? @map("reorder_level")
  maxStockLevel Int? @map("max_stock_level")

  avgCostPrice      Decimal? @map("avg_cost_price") @db.Decimal(10, 2)
  lastPurchasePrice Decimal? @map("last_purchase_price") @db.Decimal(10, 2)
  sellingPrice      Decimal? @map("selling_price") @db.Decimal(10, 2)

  taxType InventoryTaxType? @map("tax_type")
  taxRate Decimal?          @map("tax_rate") @db.Decimal(5, 2)
  hsnCode String?           @map("hsn_code")

  isRawMaterial     Boolean @default(false) @map("is_raw_material")
  isFinishedProduct Boolean @default(false) @map("is_finished_product")
  isScrap           Boolean @default(false) @map("is_scrap")
  defaultUnit       String? @map("default_unit")
  purchaseUnitId    String? @map("purchase_unit_id")
  saleUnitId        String? @map("sale_unit_id")
  stockUnitId       String? @map("stock_unit_id")

  industryCode      String? @map("industry_code")
  defaultLocationId String? @map("default_location_id")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serials               SerialMaster[]
  transactions          StockTransaction[]
  summaries             StockSummary[]
  bomFormulasAsFinished BOMFormula[]       @relation("FinishedProduct")
  bomItemsAsRaw         BOMFormulaItem[]   @relation("RawMaterial")

  @@unique([tenantId, productId])
  @@index([tenantId, inventoryType])
  @@index([tenantId, isRawMaterial])
  @@map("inventory_items")
}

model StockLocation {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  name             String
  code             String
  type             String  @default("WAREHOUSE") // WAREHOUSE, STORE, KITCHEN, EXPIRY_STORE, SCRAP_STORE, VIRTUAL
  parentLocationId String? @map("parent_location_id")

  address       String?
  city          String?
  state         String?
  pincode       String?
  contactPerson String? @map("contact_person")
  phone         String?

  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("stock_locations")
}

model StockTransaction {
  id              String @id @default(uuid())
  tenantId        String @default("") @map("tenant_id")
  inventoryItemId String @map("inventory_item_id")
  productId       String @map("product_id")

  transactionType StockTransactionType @map("transaction_type")
  quantity        Int
  unitPrice       Decimal?             @map("unit_price") @db.Decimal(10, 2)
  totalAmount     Decimal?             @map("total_amount") @db.Decimal(10, 2)

  locationId   String  @map("location_id")
  toLocationId String? @map("to_location_id")

  serialMasterId  String? @map("serial_master_id")
  batchId         String? @map("batch_id")
  bomProductionId String? @map("bom_production_id")

  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")

  transactionDate DateTime @default(now()) @map("transaction_date")
  remarks         String?
  createdById     String?  @map("created_by_id")

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([tenantId, productId, transactionDate])
  @@index([tenantId, transactionType])
  @@map("stock_transactions")
}

model StockSummary {
  id              String @id @default(uuid())
  tenantId        String @default("") @map("tenant_id")
  productId       String @map("product_id")
  locationId      String @map("location_id")
  inventoryItemId String @map("inventory_item_id")

  openingBalance Int @default(0) @map("opening_balance")
  totalIn        Int @default(0) @map("total_in")
  totalOut       Int @default(0) @map("total_out")
  currentStock   Int @default(0) @map("current_stock")
  reservedStock  Int @default(0) @map("reserved_stock")

  avgCostPrice  Decimal? @map("avg_cost_price") @db.Decimal(10, 2)
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")

