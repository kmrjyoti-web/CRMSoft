  totalPrice  Decimal            @map("total_price") @db.Decimal(12, 2)
  taxRate     Decimal?           @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal?           @map("tax_amount") @db.Decimal(12, 2)
  appliedTier String?            @map("applied_tier")

  @@index([orderId])
  @@index([listingId])
