  @@index([proformaInvoiceId])
  @@index([tenantId])
  @@map("proforma_line_items")
}

// ─── PAYMENT ───
model Payment {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  paymentNo String  @map("payment_no")
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  // ─── PAYMENT INFO ───
  amount   Decimal        @db.Decimal(14, 2)
  currency String         @default("INR")
  status   PaymentStatus  @default(PENDING)
  method   PaymentMethod
  gateway  PaymentGateway @default(MANUAL)

  // ─── GATEWAY DETAILS ───
  gatewayOrderId   String? @map("gateway_order_id")
  gatewayPaymentId String? @map("gateway_payment_id")
  gatewaySignature String? @map("gateway_signature")
  gatewayResponse  Json?   @map("gateway_response")

  // ─── OFFLINE DETAILS ───
  chequeNumber     String?   @map("cheque_number")
  chequeDate       DateTime? @map("cheque_date")
  chequeBankName   String?   @map("cheque_bank_name")
  transactionRef   String?   @map("transaction_ref")
  upiTransactionId String?   @map("upi_transaction_id")

  // ─── META ───
  paidAt        DateTime? @map("paid_at")
  notes         String?
  failureReason String?   @map("failure_reason")

  // ─── AUDIT ───
  recordedById String   @map("recorded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  receipt PaymentReceipt?
  refunds Refund[]

  @@unique([tenantId, paymentNo])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─── PAYMENT RECEIPT ───
model PaymentReceipt {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  receiptNo String  @map("receipt_no")
  paymentId String  @unique @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount        Decimal  @db.Decimal(14, 2)
  amountInWords String?  @map("amount_in_words")
  receivedFrom  String   @map("received_from")
  paidFor       String   @map("paid_for")
  paymentMethod String   @map("payment_method")
  paymentDate   DateTime @map("payment_date")

  notes         String?
  generatedById String   @map("generated_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  @@unique([tenantId, receiptNo])
  @@index([tenantId])
  @@map("payment_receipts")
}

// ─── REFUND ───
model Refund {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  refundNo  String  @map("refund_no")
  paymentId String  @map("payment_id")
  payment   Payment @relation(fields: [paymentId], references: [id])

  amount Decimal      @db.Decimal(14, 2)
  reason String
  status RefundStatus @default(REFUND_PENDING)

  gatewayRefundId String? @map("gateway_refund_id")
  gatewayResponse Json?   @map("gateway_response")

  processedAt   DateTime? @map("processed_at")
  processedById String?   @map("processed_by_id")
  failureReason String?   @map("failure_reason")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, refundNo])
  @@index([tenantId, paymentId])
  @@index([tenantId, status])
  @@map("refunds")
}

// ─── CREDIT NOTE ───
model CreditNote {
  id           String  @id @default(uuid())
  tenantId     String  @default("") @map("tenant_id")
  creditNoteNo String  @map("credit_note_no")
  invoiceId    String  @map("invoice_id")
  invoice      Invoice @relation(fields: [invoiceId], references: [id])

  amount Decimal          @db.Decimal(14, 2)
  reason String
  status CreditNoteStatus @default(CN_DRAFT)

  appliedToInvoiceId String?   @map("applied_to_invoice_id")
  appliedAmount      Decimal?  @map("applied_amount") @db.Decimal(14, 2)
  appliedAt          DateTime? @map("applied_at")

  issuedAt   DateTime? @map("issued_at")
  issuedById String?   @map("issued_by_id")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  @@unique([tenantId, creditNoteNo])
  @@index([tenantId, invoiceId])
  @@index([tenantId, status])
  @@map("credit_notes")
}

// ─── PAYMENT REMINDER ───
model PaymentReminder {
  id        String  @id @default(uuid())
  tenantId  String  @default("") @map("tenant_id")
  invoiceId String  @map("invoice_id")
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  level        ReminderLevel
  scheduledAt  DateTime      @map("scheduled_at")
  sentAt       DateTime?     @map("sent_at")
  channel      String        @default("EMAIL")
  isSent       Boolean       @default(false) @map("is_sent")
  responseNote String?       @map("response_note")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, invoiceId])
  @@index([tenantId, isSent, scheduledAt])
  @@map("payment_reminders")
}

