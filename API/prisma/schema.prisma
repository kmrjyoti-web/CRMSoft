// ─── API KEY ───
model ApiKey {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name        String
  description String?

  keyPrefix   String @map("key_prefix")
  keyHash     String @unique @map("key_hash")
  keyLastFour String @map("key_last_four")

  status    ApiKeyStatus @default(API_ACTIVE)
  expiresAt DateTime?    @map("expires_at")

  scopes             String[]
  rateLimitPerHour   Int?     @map("rate_limit_per_hour")
  rateLimitPerDay    Int?     @map("rate_limit_per_day")
  rateLimitPerMinute Int?     @map("rate_limit_per_minute")

  allowedIps  String[] @map("allowed_ips")
  environment String   @default("live")

  lastUsedAt       DateTime? @map("last_used_at")
  totalRequests    Int       @default(0) @map("total_requests")
  requestsToday    Int       @default(0) @map("requests_today")
  requestsThisHour Int       @default(0) @map("requests_this_hour")
  lastResetDate    DateTime? @map("last_reset_date")
  lastResetHour    DateTime? @map("last_reset_hour")

  createdById   String    @map("created_by_id")
  createdByName String    @map("created_by_name")
  revokedAt     DateTime? @map("revoked_at")
  revokedById   String?   @map("revoked_by_id")
  revokedReason String?   @map("revoked_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, status])
  @@index([keyHash])
  @@map("api_keys")
}

// ─── API REQUEST LOG ───
model ApiRequestLog {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  apiKeyId   String @map("api_key_id")
  apiKeyName String @map("api_key_name")

  method         String
  path           String
  queryParams    Json?  @map("query_params")
  requestBody    Json?  @map("request_body")
  requestHeaders Json?  @map("request_headers")

  statusCode     Int   @map("status_code")
  responseBody   Json? @map("response_body")
  responseTimeMs Int   @map("response_time_ms")

  ip        String
  userAgent String? @map("user_agent")
  requestId String  @map("request_id")

  rateLimitRemaining Int?    @map("rate_limit_remaining")
  rateLimitUsed      Int?    @map("rate_limit_used")
  wasRateLimited     Boolean @default(false) @map("was_rate_limited")

  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  level ApiLogLevel @default(API_INFO)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, apiKeyId, createdAt])
  @@index([tenantId, path, createdAt])
  @@index([tenantId, statusCode, createdAt])
  @@map("api_request_logs")
}

// ─── WEBHOOK ENDPOINT ───
model WebhookEndpoint {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  url         String
  description String?
  secret      String
  events      String[]

  status         WebhookStatus @default(WH_ACTIVE)
  apiVersion     String        @default("v1") @map("api_version")
  contentType    String        @default("application/json") @map("content_type")
  timeoutSeconds Int           @default(30) @map("timeout_seconds")
  maxRetries     Int           @default(5) @map("max_retries")
  customHeaders  Json?         @map("custom_headers")

  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastDeliveredAt     DateTime? @map("last_delivered_at")
  lastFailedAt        DateTime? @map("last_failed_at")
  lastError           String?   @map("last_error")
  totalDelivered      Int       @default(0) @map("total_delivered")
  totalFailed         Int       @default(0) @map("total_failed")

  createdById   String   @map("created_by_id")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@index([tenantId, status])
  @@map("webhook_endpoints")
}

// ─── WEBHOOK DELIVERY ───
model WebhookDelivery {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  endpointId String          @map("endpoint_id")
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  eventType String @map("event_type")
  eventId   String @map("event_id")

  payload     Json
  payloadSize Int? @map("payload_size")

  status      WebhookDeliveryStatus @default(WH_PENDING)
  attempt     Int                   @default(1)
  maxAttempts Int                   @default(5) @map("max_attempts")

  httpStatus     Int?    @map("http_status")
  responseBody   String? @map("response_body") @db.Text
  responseTimeMs Int?    @map("response_time_ms")

  error     String?
  signature String

  scheduledAt DateTime  @map("scheduled_at")
  deliveredAt DateTime? @map("delivered_at")
  nextRetryAt DateTime? @map("next_retry_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([endpointId, status, scheduledAt])
  @@index([tenantId, eventType, createdAt])
  @@map("webhook_deliveries")
}

// ─── RATE LIMIT TIER ───
model RateLimitTier {
  id String @id @default(uuid())

  planCode String @unique @map("plan_code")
  planName String @map("plan_name")

  requestsPerMinute   Int @map("requests_per_minute")
  requestsPerHour     Int @map("requests_per_hour")
