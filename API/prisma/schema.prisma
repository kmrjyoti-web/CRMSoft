// AUDIT LOG
// ═══════════════════════════════════════════════════════

model AuditLog {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  // What changed
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id")
  entityLabel String?         @map("entity_label")
  action      AuditAction

  // Summary
  summary     String
  changeCount Int    @default(0) @map("change_count")

  // Snapshots
  beforeSnapshot Json? @map("before_snapshot")
  afterSnapshot  Json? @map("after_snapshot")

  // Who
  performedById    String? @map("performed_by_id")
  performedByName  String? @map("performed_by_name")
  performedByEmail String? @map("performed_by_email")
  performedByRole  String? @map("performed_by_role")

  // Request context
  ipAddress   String? @map("ip_address")
  userAgent   String? @map("user_agent")
  httpMethod  String? @map("http_method")
  requestUrl  String? @map("request_url")
  requestBody Json?   @map("request_body")

  // Source
  source        String?
  module        String?
  correlationId String? @map("correlation_id")

  // Tags
  tags           String[] @default([])
  isSensitive    Boolean  @default(false) @map("is_sensitive")
  isSystemAction Boolean  @default(false) @map("is_system_action")

  // Relations
  fieldChanges AuditFieldChange[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId, createdAt])
  @@index([performedById, createdAt])
  @@index([entityType, action, createdAt])
  @@index([createdAt])
  @@index([correlationId])
  @@index([tenantId])
  @@map("audit_logs")
}

model AuditFieldChange {
  id         String   @id @default(uuid())
  tenantId   String   @default("") @map("tenant_id")
  auditLogId String   @map("audit_log_id")
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  // Field detail
  fieldName  String  @map("field_name")
  fieldLabel String? @map("field_label")
  fieldType  String? @map("field_type")

  // Values
  oldValue        String? @map("old_value")
  newValue        String? @map("new_value")
  oldDisplayValue String? @map("old_display_value")
  newDisplayValue String? @map("new_display_value")

  // Flags
  isSensitive Boolean @default(false) @map("is_sensitive")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([auditLogId])
  @@index([fieldName, createdAt])
  @@index([tenantId])
  @@map("audit_field_changes")
}

model AuditRetentionPolicy {
  id             String          @id @default(uuid())
  tenantId       String          @default("") @map("tenant_id")
  entityType     AuditEntityType @map("entity_type")
  retentionDays  Int             @map("retention_days")
  archiveEnabled Boolean         @default(false) @map("archive_enabled")
  isActive       Boolean         @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, entityType])
  @@index([tenantId])
  @@map("audit_retention_policies")
}

// ═══════════════════════════════════════════════════════
// IMPORT PROFILE (Data Source Profile)
// ═══════════════════════════════════════════════════════

model ImportProfile {
  id           String             @id @default(uuid())
  tenantId     String             @default("") @map("tenant_id")
  name         String
  description  String?
  sourceSystem String?            @map("source_system")
  icon         String?
  color        String?
  targetEntity ImportTargetEntity @map("target_entity")

  expectedHeaders String[] @map("expected_headers")
  headerMatchMode String   @default("FLEXIBLE") @map("header_match_mode")

  fieldMapping    Json  @map("field_mapping")
  defaultValues   Json? @map("default_values")
  validationRules Json? @map("validation_rules")

  duplicateCheckFields String[]          @map("duplicate_check_fields")
  duplicateStrategy    DuplicateStrategy @default(ASK_PER_ROW) @map("duplicate_strategy")
  fuzzyMatchEnabled    Boolean           @default(false) @map("fuzzy_match_enabled")
  fuzzyMatchFields     String[]          @map("fuzzy_match_fields")
  fuzzyThreshold       Decimal           @default(0.85) @map("fuzzy_threshold") @db.Decimal(3, 2)

  usageCount     Int       @default(0) @map("usage_count")
  lastUsedAt     DateTime? @map("last_used_at")
  totalImported  Int       @default(0) @map("total_imported")
  avgSuccessRate Decimal?  @map("avg_success_rate") @db.Decimal(5, 2)

  status        ProfileStatus @default(ACTIVE)
  isDefault     Boolean       @default(false) @map("is_default")
  createdById   String        @map("created_by_id")
  createdByName String        @map("created_by_name")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  importJobs ImportJob[]

  @@unique([tenantId, name])
  @@index([targetEntity, status])
  @@index([tenantId])
  @@map("import_profiles")
}

// ═══════════════════════════════════════════════════════
// IMPORT JOB
// ═══════════════════════════════════════════════════════

model ImportJob {
  id           String             @id @default(uuid())
  tenantId     String             @default("") @map("tenant_id")
  fileName     String             @map("file_name")
  fileType     String             @map("file_type")
  fileSize     Int                @map("file_size")
  fileUrl      String?            @map("file_url")
  targetEntity ImportTargetEntity @map("target_entity")

  profileId         String?        @map("profile_id")
  profile           ImportProfile? @relation(fields: [profileId], references: [id])
  profileMatchScore Decimal?       @map("profile_match_score") @db.Decimal(5, 2)
  usedAutoMapping   Boolean        @default(false) @map("used_auto_mapping")

  status       ImportJobStatus @default(UPLOADING)
  fileHeaders  String[]        @map("file_headers")
  totalRows    Int             @default(0) @map("total_rows")
  sampleData   Json?           @map("sample_data")
  fieldMapping Json?           @map("field_mapping")

  duplicateCheckFields String[]          @map("duplicate_check_fields")
  duplicateStrategy    DuplicateStrategy @default(ASK_PER_ROW) @map("duplicate_strategy")
  fuzzyMatchEnabled    Boolean           @default(false) @map("fuzzy_match_enabled")
  fuzzyMatchFields     String[]          @map("fuzzy_match_fields")
  fuzzyThreshold       Decimal           @default(0.85) @map("fuzzy_threshold") @db.Decimal(3, 2)
  validationRules      Json?             @map("validation_rules")
  defaultValues        Json?             @map("default_values")

  validRows           Int @default(0) @map("valid_rows")
  invalidRows         Int @default(0) @map("invalid_rows")
  duplicateExactRows  Int @default(0) @map("duplicate_exact_rows")
  duplicateFuzzyRows  Int @default(0) @map("duplicate_fuzzy_rows")
  duplicateInFileRows Int @default(0) @map("duplicate_in_file_rows")
  skippedRows         Int @default(0) @map("skipped_rows")
  importedCount       Int @default(0) @map("imported_count")
  updatedCount        Int @default(0) @map("updated_count")
  failedCount         Int @default(0) @map("failed_count")

  resultReportUrl     String? @map("result_report_url")
  failedRowsReportUrl String? @map("failed_rows_report_url")

  createdById   String    @map("created_by_id")
  createdByName String    @map("created_by_name")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  rows ImportRow[]

  @@index([status, createdById])
  @@index([profileId])
  @@index([tenantId])
  @@map("import_jobs")
}

// ═══════════════════════════════════════════════════════
// IMPORT ROW
// ═══════════════════════════════════════════════════════

model ImportRow {
  id          String    @id @default(uuid())
  tenantId    String    @default("") @map("tenant_id")
  importJobId String    @map("import_job_id")
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int       @map("row_number")

  rowData    Json            @map("row_data")
  mappedData Json?           @map("mapped_data")
  rowStatus  ImportRowStatus @default(PENDING) @map("row_status")

  validationErrors   Json? @map("validation_errors")
  validationWarnings Json? @map("validation_warnings")

  isDuplicate          Boolean @default(false) @map("is_duplicate")
  duplicateType        String? @map("duplicate_type")
  duplicateOfEntityId  String? @map("duplicate_of_entity_id")
  duplicateOfRowNumber Int?    @map("duplicate_of_row_number")
  duplicateMatchField  String? @map("duplicate_match_field")
  duplicateMatchValue  String? @map("duplicate_match_value")

  fuzzyMatchScore   Decimal? @map("fuzzy_match_score") @db.Decimal(5, 4)
  fuzzyMatchDetails Json?    @map("fuzzy_match_details")

  patchPreview Json? @map("patch_preview")

  userAction     String? @map("user_action")
  userEditedData Json?   @map("user_edited_data")

  importedEntityId String?   @map("imported_entity_id")
  importAction     String?   @map("import_action")
  importError      String?   @map("import_error")
  importedAt       DateTime? @map("imported_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([importJobId, rowStatus])
  @@index([importJobId, rowNumber])
  @@index([tenantId])
  @@map("import_rows")
}

// ═══════════════════════════════════════════════════════
// EXPORT JOB
// ═══════════════════════════════════════════════════════

model ExportJob {
  id            String       @id @default(uuid())
  tenantId      String       @default("") @map("tenant_id")
  targetEntity  String       @map("target_entity")
  format        String
  filters       Json?
  columns       String[]
  status        ExportStatus @default(PROCESSING)
  recordCount   Int          @default(0) @map("record_count")
  fileUrl       String?      @map("file_url")
  fileSize      Int?         @map("file_size")
  createdById   String       @map("created_by_id")
  createdByName String       @map("created_by_name")
  completedAt   DateTime?    @map("completed_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("export_jobs")
}

// ═══════════════════════════════════════════════════════
// DOCUMENT & FILE MANAGEMENT ENUMS
// ═══════════════════════════════════════════════════════

enum StorageType {
  LOCAL
  S3
  CLOUD_LINK
}

enum StorageProvider {
  NONE
  GOOGLE_DRIVE
  ONEDRIVE
  DROPBOX
}

enum DocumentStatus {
  UPLOADING
  ACTIVE
  ARCHIVED
  DELETED
}

enum DocumentCategory {
  GENERAL
  PROPOSAL
  CONTRACT
  INVOICE
  QUOTATION
  REPORT
  PRESENTATION
  SPREADSHEET
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum CloudConnectionStatus {
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

enum ShareLinkAccess {
  VIEW
  DOWNLOAD
  EDIT
}

// ═══════════════════════════════════════════════════════
// DOCUMENT
// ═══════════════════════════════════════════════════════

model Document {
  id              String           @id @default(uuid())
  tenantId        String           @default("") @map("tenant_id")
  fileName        String           @map("file_name")
  originalName    String           @map("original_name")
  mimeType        String           @map("mime_type")
  fileSize        Int              @map("file_size")
  storageType     StorageType      @map("storage_type")
  storageProvider StorageProvider  @default(NONE) @map("storage_provider")
  storagePath     String?          @map("storage_path")
  storageUrl      String?          @map("storage_url")
  cloudFileId     String?          @map("cloud_file_id")
  thumbnailUrl    String?          @map("thumbnail_url")
  category        DocumentCategory @default(GENERAL)
  status          DocumentStatus   @default(ACTIVE)
  description     String?
  tags            String[]         @default([])
  version         Int              @default(1)
  parentVersionId String?          @map("parent_version_id")
  parentVersion   Document?        @relation("DocumentVersions", fields: [parentVersionId], references: [id])
  childVersions   Document[]       @relation("DocumentVersions")
  folderId        String?          @map("folder_id")
  folder          DocumentFolder?  @relation(fields: [folderId], references: [id])
  isActive        Boolean          @default(true) @map("is_active")

  uploadedById String   @map("uploaded_by_id")
  uploadedBy   User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  attachments  DocumentAttachment[]
  shareLinks   DocumentShareLink[]
  activityLogs DocumentActivity[]

  @@index([uploadedById, status])
  @@index([folderId])
  @@index([category])
  @@index([storageType])
  @@index([tenantId])
  @@map("documents")
}

// ═══════════════════════════════════════════════════════
// DOCUMENT ATTACHMENT (many-to-many: document ↔ entity)
// ═══════════════════════════════════════════════════════

model DocumentAttachment {
  id           String   @id @default(uuid())
  tenantId     String   @default("") @map("tenant_id")
  documentId   String   @map("document_id")
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  attachedById String   @map("attached_by_id")
  attachedBy   User     @relation("AttachmentAttachedBy", fields: [attachedById], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, documentId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([tenantId])
  @@map("document_attachments")
}

// ═══════════════════════════════════════════════════════
// DOCUMENT FOLDER
// ═══════════════════════════════════════════════════════

model DocumentFolder {
  id          String           @id @default(uuid())
  tenantId    String           @default("") @map("tenant_id")
  name        String
  description String?
  parentId    String?          @map("parent_id")
  parent      DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    DocumentFolder[] @relation("FolderHierarchy")
  color       String?
  icon        String?
  sortOrder   Int              @default(0) @map("sort_order")
  isActive    Boolean          @default(true) @map("is_active")
  createdById String           @map("created_by_id")
  createdBy   User             @relation("FolderCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  documents Document[]

  @@index([parentId])
  @@index([createdById])
  @@index([tenantId])
  @@map("document_folders")
}

// ═══════════════════════════════════════════════════════
// CLOUD CONNECTION
// ═══════════════════════════════════════════════════════

model CloudConnection {
  id           String                @id @default(uuid())
  tenantId     String                @default("") @map("tenant_id")
  provider     StorageProvider
  userId       String                @map("user_id")
  user         User                  @relation("CloudConnectionUser", fields: [userId], references: [id])
  accessToken  String                @map("access_token")
  refreshToken String?               @map("refresh_token")
  tokenExpiry  DateTime?             @map("token_expiry")
  accountEmail String?               @map("account_email")
  accountName  String?               @map("account_name")
  status       CloudConnectionStatus @default(CONNECTED)
  lastSyncAt   DateTime?             @map("last_sync_at")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@unique([tenantId, provider, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("cloud_connections")
}

// ═══════════════════════════════════════════════════════
// DOCUMENT SHARE LINK
// ═══════════════════════════════════════════════════════

model DocumentShareLink {
  id          String          @id @default(uuid())
  tenantId    String          @default("") @map("tenant_id")
  documentId  String          @map("document_id")
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token       String          @unique
  access      ShareLinkAccess @default(VIEW)
  password    String?
  expiresAt   DateTime?       @map("expires_at")
  maxViews    Int?            @map("max_views")
  viewCount   Int             @default(0) @map("view_count")
  isActive    Boolean         @default(true) @map("is_active")
  createdById String          @map("created_by_id")
  createdBy   User            @relation("ShareLinkCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([token])
  @@index([documentId])
  @@index([tenantId])
  @@map("document_share_links")
}

// ═══════════════════════════════════════════════════════
// DOCUMENT ACTIVITY LOG
// ═══════════════════════════════════════════════════════

model DocumentActivity {
  id         String   @id @default(uuid())
  tenantId   String   @default("") @map("tenant_id")
  documentId String   @map("document_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  action     String
  details    Json?
  userId     String   @map("user_id")
  user       User     @relation("DocumentActivityUser", fields: [userId], references: [id])
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@index([userId])
  @@index([tenantId])
  @@map("document_activities")
}

// ═══════════════════════════════════════════════════════
// EMAIL INTEGRATION ENUMS
// ═══════════════════════════════════════════════════════

enum EmailProvider {
  GMAIL
  OUTLOOK
  IMAP_SMTP
  ORGANIZATION_SMTP
}

enum EmailAccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
  TOKEN_EXPIRED
  SYNCING
}

enum EmailDirection {
  INBOUND
  OUTBOUND
}

enum EmailStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  CANCELLED
}

enum EmailPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  UNSUBSCRIBED
}

enum TemplateCategory {
  GENERAL
  FOLLOW_UP
  INTRODUCTION
  PROPOSAL
  QUOTATION_MAIL
  MEETING
  THANK_YOU
  REMINDER
  FEEDBACK
  CAMPAIGN
  WELCOME
  ANNOUNCEMENT
  NEWSLETTER
  CUSTOM
}

// ═══════════════════════════════════════════════════════
// EMAIL ACCOUNT
// ═══════════════════════════════════════════════════════

model EmailAccount {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")
  userId   String @map("user_id")
  user     User   @relation("EmailAccountUser", fields: [userId], references: [id])

  provider     EmailProvider
  label        String?
  emailAddress String        @map("email_address")
  displayName  String?       @map("display_name")

  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  oauthScope     String?   @map("oauth_scope")

  imapHost     String?  @map("imap_host")
  imapPort     Int?     @map("imap_port")
  imapSecure   Boolean? @map("imap_secure")
  smtpHost     String?  @map("smtp_host")
  smtpPort     Int?     @map("smtp_port")
  smtpSecure   Boolean? @map("smtp_secure")
  smtpUsername String?  @map("smtp_username")
  smtpPassword String?  @map("smtp_password")

  status        EmailAccountStatus @default(ACTIVE)
  lastSyncAt    DateTime?          @map("last_sync_at")
  lastSyncError String?            @map("last_sync_error")
  syncToken     String?            @map("sync_token")
  syncFromDate  DateTime?          @map("sync_from_date")
  syncEnabled   Boolean            @default(true) @map("sync_enabled")

  isDefault       Boolean @default(false) @map("is_default")
  autoLinkEnabled Boolean @default(true) @map("auto_link_enabled")
  signatureId     String? @map("signature_id")

  totalSent     Int @default(0) @map("total_sent")
  totalReceived Int @default(0) @map("total_received")

  dailySendLimit Int       @default(500) @map("daily_send_limit")
  todaySentCount Int       @default(0) @map("today_sent_count")
  dailyResetAt   DateTime? @map("daily_reset_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  emails Email[]

  @@unique([tenantId, userId, emailAddress])
  @@index([userId, status])
  @@index([tenantId])
  @@map("email_accounts")
}

// ═══════════════════════════════════════════════════════
// EMAIL THREAD
// ═══════════════════════════════════════════════════════

model EmailThread {
  id                 String    @id @default(uuid())
  tenantId           String    @default("") @map("tenant_id")
  subject            String
  participantEmails  Json      @map("participant_emails")
  messageCount       Int       @default(0) @map("message_count")
  lastMessageAt      DateTime? @map("last_message_at")
  lastMessageSnippet String?   @map("last_message_snippet")
  linkedEntityType   String?   @map("linked_entity_type")
  linkedEntityId     String?   @map("linked_entity_id")
  providerThreadId   String?   @map("provider_thread_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  emails Email[]

  @@index([linkedEntityType, linkedEntityId])
  @@index([lastMessageAt])
  @@index([tenantId])
  @@map("email_threads")
}

// ═══════════════════════════════════════════════════════
// EMAIL
// ═══════════════════════════════════════════════════════

model Email {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  accountId String       @map("account_id")
  account   EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  direction    EmailDirection
  fromEmail    String         @map("from_email")
  fromName     String?        @map("from_name")
  toEmails     Json           @map("to_emails")
  ccEmails     Json?          @map("cc_emails")
  bccEmails    Json?          @map("bcc_emails")
  replyToEmail String?        @map("reply_to_email")

  subject  String
  bodyHtml String? @map("body_html")
  bodyText String? @map("body_text")
  snippet  String?

  threadId           String?      @map("thread_id")
  thread             EmailThread? @relation(fields: [threadId], references: [id])
  inReplyToMessageId String?      @map("in_reply_to_message_id")
  references         String[]     @default([])

  providerMessageId String? @map("provider_message_id")
  providerThreadId  String? @map("provider_thread_id")
  internetMessageId String? @map("internet_message_id")

  status   EmailStatus   @default(DRAFT)
  priority EmailPriority @default(NORMAL)

  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")

  trackingEnabled Boolean   @default(true) @map("tracking_enabled")
  trackingPixelId String?   @map("tracking_pixel_id")
  openCount       Int       @default(0) @map("open_count")
  firstOpenedAt   DateTime? @map("first_opened_at")
  lastOpenedAt    DateTime? @map("last_opened_at")
  clickCount      Int       @default(0) @map("click_count")
  firstClickedAt  DateTime? @map("first_clicked_at")
  isReplied       Boolean   @default(false) @map("is_replied")
  repliedAt       DateTime? @map("replied_at")
  isBounced       Boolean   @default(false) @map("is_bounced")
  bounceReason    String?   @map("bounce_reason")

  linkedEntityType String? @map("linked_entity_type")
  linkedEntityId   String? @map("linked_entity_id")
  autoLinked       Boolean @default(false) @map("auto_linked")
  activityId       String? @map("activity_id")

  campaignId          String?        @map("campaign_id")
  campaign            EmailCampaign? @relation(fields: [campaignId], references: [id])
  campaignRecipientId String?        @map("campaign_recipient_id")

  templateId String? @map("template_id")

  hasAttachments  Boolean  @default(false) @map("has_attachments")
  attachmentCount Int      @default(0) @map("attachment_count")
  isStarred       Boolean  @default(false) @map("is_starred")
  isRead          Boolean  @default(false) @map("is_read")
  labels          String[] @default([])

  errorMessage String? @map("error_message")
  retryCount   Int     @default(0) @map("retry_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attachments    EmailAttachment[]
  trackingEvents EmailTrackingEvent[]

  @@unique([tenantId, internetMessageId])
  @@unique([tenantId, trackingPixelId])
  @@index([accountId, direction, createdAt])
  @@index([threadId])
  @@index([linkedEntityType, linkedEntityId])
  @@index([campaignId])
  @@index([status, scheduledAt])
  @@index([trackingPixelId])
  @@index([tenantId])
  @@map("emails")
}

// ═══════════════════════════════════════════════════════
// EMAIL ATTACHMENT
// ═══════════════════════════════════════════════════════

model EmailAttachment {
  id                   String   @id @default(uuid())
  tenantId             String   @default("") @map("tenant_id")
  emailId              String   @map("email_id")
  email                Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  fileName             String   @map("file_name")
  mimeType             String?  @map("mime_type")
  fileSize             Int?     @map("file_size")
  filePath             String?  @map("file_path")
  providerAttachmentId String?  @map("provider_attachment_id")
