// ═══════════════════════════════════════════════════════
// TASK ENGINE
// ═══════════════════════════════════════════════════════

model Task {
  id         String @id @default(uuid())
  tenantId   String @default("") @map("tenant_id")
  taskNumber String @map("task_number")

  // ─── TASK DETAILS ───
  title          String       @db.VarChar(500)
  description    String?      @db.Text
  type           TaskType     @default(GENERAL)
  customTaskType String?      @map("custom_task_type")
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)

  // ─── ASSIGNMENT (WHO) ───
  assignedToId          String?             @map("assigned_to_id")
  assignedTo            User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById           String              @map("created_by_id")
  createdBy             User                @relation("TaskCreatedBy", fields: [createdById], references: [id])
  approvedById          String?             @map("approved_by_id")
  approvedAt            DateTime?           @map("approved_at")
  rejectedReason        String?             @map("rejected_reason")
  assignmentScope       TaskAssignmentScope @default(SPECIFIC_USER) @map("assignment_scope")
  assignedDepartmentId  String?             @map("assigned_department_id")
  assignedDesignationId String?             @map("assigned_designation_id")
  assignedRoleId        String?             @map("assigned_role_id")

  // ─── DATES ───
  dueDate     DateTime? @map("due_date")
  dueTime     String?   @map("due_time")
  startDate   DateTime? @map("start_date")
  completedAt DateTime? @map("completed_at")

  // ─── RECURRENCE ───
  recurrence         TaskRecurrence @default(NONE)
  recurrenceConfig   Json?          @map("recurrence_config")
  nextRecurrenceDate DateTime?      @map("next_recurrence_date")
  parentTaskId       String?        @map("parent_task_id")
  parentTask         Task?          @relation("TaskRecurrence", fields: [parentTaskId], references: [id])
  childTasks         Task[]         @relation("TaskRecurrence")

  // ─── LINKED ENTITY (polymorphic) ───
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")

  // ─── METADATA ───
  tags            Json?
  attachments     Json?
  customFields    Json?   @map("custom_fields")
  completionNotes String? @map("completion_notes") @db.Text

  // ─── TRACKING ───
  estimatedMinutes Int? @map("estimated_minutes")
  actualMinutes    Int? @map("actual_minutes")

  // ─── AUDIT ───
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // ─── RELATIONS ───
  history   TaskHistory[]
  watchers  TaskWatcher[]
  comments  Comment[]     @relation("TaskComments")
  reminders Reminder[]    @relation("TaskReminders")

  @@unique([tenantId, taskNumber])
  @@index([tenantId, assignedToId, status])
  @@index([tenantId, createdById])
  @@index([tenantId, assignedDepartmentId])
  @@index([tenantId, dueDate])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status, priority])
  @@map("tasks")
}

model TaskHistory {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action      String   @default("UPDATED")
  field       String?
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  changedById String   @map("changed_by_id")
  changedBy   User     @relation("TaskHistoryChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([taskId])
  @@index([tenantId, changedById])
  @@map("task_history")
}

model TaskWatcher {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("TaskWatcherUser", fields: [userId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([taskId, userId])
  @@map("task_watchers")
}

// ═══════════════════════════════════════════════════════
// COMMENT ENGINE
// ═══════════════════════════════════════════════════════

model Comment {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  // ─── POLYMORPHIC ENTITY ───
  entityType CommentEntityType @map("entity_type")
  entityId   String            @map("entity_id")

  // ─── CONTENT ───
  content     String            @db.Text
  attachments Json?
  visibility  CommentVisibility @default(PUBLIC)

  // ─── WHO ───
  authorId      String  @map("author_id")
  author        User    @relation("CommentAuthor", fields: [authorId], references: [id])
  createdByRole String? @map("created_by_role")

  // ─── THREAD ───
  taskId   String?   @map("task_id")
  task     Task?     @relation("TaskComments", fields: [taskId], references: [id])
  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentThread", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentThread")

  // ─── MENTIONS ───
  mentionedUserIds Json? @map("mentioned_user_ids")

  // ─── EDIT TRACKING ───
  isEdited Boolean   @default(false) @map("is_edited")
  editedAt DateTime? @map("edited_at")

  // ─── AUDIT ───
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([tenantId, entityType, entityId, visibility])
  @@index([taskId])
  @@index([authorId])
  @@index([tenantId])
  @@map("comments")
}

// ═══════════════════════════════════════════════════════
// NOTIFICATION CONFIG & ESCALATION
// ═══════════════════════════════════════════════════════

model NotificationConfig {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  // ─── WHAT EVENT ───
  eventCode     String                     @default("") @map("event_code")
  eventName     String?                    @map("event_name")
  eventType     NotificationEventType?     @map("event_type")
  eventCategory NotificationEventCategory? @map("event_category")
  eventLabel    String?                    @map("event_label")
  channels      Json                       @default("[]")

  // ─── CHANNEL TOGGLES (admin) ───
  enableEmail      Boolean @default(false) @map("enable_email")
  enableWhatsapp   Boolean @default(false) @map("enable_whatsapp")
  enablePush       Boolean @default(false) @map("enable_push")
  enableInAppAlert Boolean @default(true) @map("enable_in_app_alert")
  enableCall       Boolean @default(false) @map("enable_call")
  enableSms        Boolean @default(false) @map("enable_sms")

  // ─── WHO RECEIVES ───
  notifyAssignee     Boolean @default(true) @map("notify_assignee")
  notifyCreator      Boolean @default(false) @map("notify_creator")
  notifyManager      Boolean @default(false) @map("notify_manager")
  notifyAdmin        Boolean @default(false) @map("notify_admin")
  notifyWatchers     Boolean @default(true) @map("notify_watchers")
  notifyDepartment   Boolean @default(false) @map("notify_department")
  customRecipientIds Json?   @map("custom_recipient_ids")

  // ─── TEMPLATES ───
  templateId         String?               @map("template_id")
  template           NotificationTemplate? @relation(fields: [templateId], references: [id])
  emailTemplateId    String?               @map("email_template_id")
  whatsappTemplateId String?               @map("whatsapp_template_id")
  emailSubject       String?               @map("email_subject")
  customMessage      String?               @map("custom_message")
  pushTitle          String?               @map("push_title")
  pushBody           String?               @map("push_body")
  smsTemplate        String?               @map("sms_template")

  // ─── SCHEDULING ───
  respectQuietHours  Boolean @default(true) @map("respect_quiet_hours")
  isRealtime         Boolean @default(true) @map("is_realtime")
  delayMinutes       Int     @default(0) @map("delay_minutes")
  digestEnabled      Boolean @default(false) @map("digest_enabled")
  digestIntervalMins Int?    @map("digest_interval_mins")

  // ─── ADMIN CONTROL ───
  isEnabled Boolean  @default(true) @map("is_enabled")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, eventCode])
  @@index([tenantId])
  @@index([tenantId, eventCategory])
  @@map("notification_configs")
}

model EscalationRule {
  id       String  @id @default(uuid())
  tenantId String  @default("") @map("tenant_id")
  name     String? @db.VarChar(200)

  // ─── TRIGGER ───
  entityType        String                 @map("entity_type")
  triggerEventType  NotificationEventType? @map("trigger_event_type")
  triggerAfterHours Int                    @map("trigger_after_hours")
  triggerCondition  Json?                  @map("trigger_condition")

  // ─── ACTION ───
  action          EscalationAction
  actionConfig    Json?            @map("action_config")
  targetRoleLevel Int?             @map("target_role_level")

  // ─── LEVELS ───
  escalationLevel  Int     @default(1) @map("escalation_level")
  nextEscalationId String? @map("next_escalation_id")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId, entityType])
  @@index([tenantId, triggerEventType])
  @@map("escalation_rules")
}

// ═══════════════════════════════════════════════════════
// COMMUNICATION LOG
// ═══════════════════════════════════════════════════════

model CommunicationLog {
  id        String              @id @default(uuid())
  tenantId  String              @default("") @map("tenant_id")
  channel   NotificationChannel
  direction String              @default("OUTBOUND")

  // ─── WHO ───
  recipientId       String? @map("recipient_id")
  recipientAddr     String? @map("recipient_addr")
  recipientExternal String? @map("recipient_external")

  // ─── CONTENT ───
  subject String? @db.VarChar(500)
  body    String? @db.Text

  // ─── LINKED ───
  entityType     String? @map("entity_type")
  entityId       String? @map("entity_id")
  notificationId String? @map("notification_id")

  // ─── STATUS ───
  status       String  @default("PENDING")
  externalId   String? @map("external_id")
  errorMessage String? @map("error_message")

  // ─── COST (paid channels) ───
  costAmount   Decimal? @map("cost_amount") @db.Decimal(10, 4)
  costCurrency String?  @default("INR") @map("cost_currency")

  // ─── TIMESTAMPS ───
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tenantId, channel, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, recipientId])
  @@index([channel, status])
  @@map("communication_logs")
}

// ═══════════════════════════════════════════════════════
// TASK LOGIC CONFIG (Dynamic Logic Engine)
