// ═══════════════════════════════════════════════════════
// BUSINESS LOCATION (Country → State → City → Area)
// ═══════════════════════════════════════════════════════

model BusinessLocation {
  id                    String                 @id @default(uuid())
  tenantId              String                 @default("") @map("tenant_id")
  name                  String
  code                  String
  level                 LocationLevel
  parentId              String?                @map("parent_id")
  parent                BusinessLocation?      @relation("LocationHierarchy", fields: [parentId], references: [id])
  children              BusinessLocation[]     @relation("LocationHierarchy")
  latitude              Decimal?               @db.Decimal(10, 7)
  longitude             Decimal?               @db.Decimal(10, 7)
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  organizationLocations OrganizationLocation[]

  @@unique([tenantId, code])
  @@index([level, parentId])
  @@index([tenantId])
  @@map("business_locations")
}

model OrganizationLocation {
  id             String           @id @default(uuid())
  tenantId       String           @default("") @map("tenant_id")
  organizationId String           @map("organization_id")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locationId     String           @map("location_id")
  location       BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  isPrimary      Boolean          @default(false) @map("is_primary")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@unique([tenantId, organizationId, locationId])
  @@index([tenantId])
  @@map("organization_locations")
}

// ═══════════════════════════════════════════════════════
// COMPANY OPERATING LOCATIONS (Country → State → City → Pincode)
// Drives GST inter/intra-state determination
// ═══════════════════════════════════════════════════════

model CompanyCountry {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")

  countryName    String         @map("country_name")
  countryCode    String         @map("country_code")   // ISO 3166-1 alpha-2 e.g. "IN"
  isoCode3       String?        @map("iso_code_3")     // "IND"
  phonecode      String?
  currency       String?        // "INR"
  currencySymbol String?        @map("currency_symbol") // "₹"

  isActive       Boolean        @default(true) @map("is_active")
  isPrimary      Boolean        @default(false) @map("is_primary") // Company HQ country

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  states         CompanyState[]

  @@unique([tenantId, countryCode])
  @@index([tenantId])
  @@map("company_countries")
}

model CompanyState {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  companyCountryId String        @map("company_country_id")

  stateName        String        @map("state_name")    // "Maharashtra"
  stateCode        String        @map("state_code")    // "MH"
  gstStateCode     String?       @map("gst_state_code") // "27" (Indian GST)

  coverageType     String        @default("SPECIFIC") @map("coverage_type")
  // ALL_CITIES = operate in all cities of this state
  // SPECIFIC   = only specific cities listed

  isActive         Boolean       @default(true) @map("is_active")
  isHeadquarter    Boolean       @default(false) @map("is_headquarter")
  stateGstin       String?       @map("state_gstin")  // State GSTIN if multi-state

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  country          CompanyCountry @relation(fields: [companyCountryId], references: [id], onDelete: Cascade)
  cities           CompanyCity[]

  @@unique([tenantId, companyCountryId, stateCode])
  @@index([tenantId])
  @@map("company_states")
}

model CompanyCity {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  companyStateId String          @map("company_state_id")

  cityName       String          @map("city_name")    // "Mumbai"
  district       String?

  coverageType   String          @default("ALL") @map("coverage_type")
  // ALL_PINCODES = operate in all pincodes of this city
  // SPECIFIC     = only specific pincodes listed

  isActive       Boolean         @default(true) @map("is_active")

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  state          CompanyState    @relation(fields: [companyStateId], references: [id], onDelete: Cascade)
  pincodes       CompanyPincode[]

  @@unique([tenantId, companyStateId, cityName])
  @@index([tenantId])
  @@map("company_cities")
}

model CompanyPincode {
  id            String      @id @default(uuid())
  tenantId      String      @map("tenant_id")
  companyCityId String      @map("company_city_id")

  pincode       String
  areaName      String?     @map("area_name")       // "Andheri East"

  isActive      Boolean     @default(true) @map("is_active")

  city          CompanyCity @relation(fields: [companyCityId], references: [id], onDelete: Cascade)

  @@unique([tenantId, companyCityId, pincode])
  @@index([tenantId])
  @@map("company_pincodes")
}

// ═══════════════════════════════════════════════════════
// CUSTOM FIELDS (Dynamic Entity Configuration)
// ═══════════════════════════════════════════════════════

model CustomFieldDefinition {
  id           String              @id @default(uuid())
  tenantId     String              @default("") @map("tenant_id")
  entityType   String              @map("entity_type")
  fieldName    String              @map("field_name")
  fieldLabel   String              @map("field_label")
  fieldType    String              @map("field_type") // TEXT, NUMBER, DATE, BOOLEAN, DROPDOWN, JSON
  isRequired   Boolean             @default(false) @map("is_required")
  defaultValue String?             @map("default_value")
  options      Json? // dropdown options
  sortOrder    Int                 @default(0) @map("sort_order")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  values       EntityConfigValue[]

  @@unique([tenantId, entityType, fieldName])
  @@index([entityType, isActive])
  @@index([tenantId])
  @@map("custom_field_definitions")
}

model EntityConfigValue {
  id            String                @id @default(uuid())
  tenantId      String                @default("") @map("tenant_id")
  definitionId  String                @map("definition_id")
  definition    CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  entityType    String                @map("entity_type")
  entityId      String                @map("entity_id")
  valueText     String?               @map("value_text")
  valueNumber   Float?                @map("value_number")
  valueDate     DateTime?             @map("value_date")
  valueBoolean  Boolean?              @map("value_boolean")
  valueJson     Json?                 @map("value_json")
  valueDropdown String?               @map("value_dropdown")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@unique([tenantId, definitionId, entityId])
  @@index([entityType, entityId])
  @@index([definitionId, valueText])
  @@index([definitionId, valueNumber])
  @@index([definitionId, valueDropdown])
  @@index([tenantId])
  @@map("entity_config_values")
}

// ═══════════════════════════════════════════════════════
// PRODUCT MASTER
// ═══════════════════════════════════════════════════════

model Product {
  id               String  @id @default(uuid())
  tenantId         String  @default("") @map("tenant_id")
  name             String
  code             String
  slug             String
  shortDescription String? @map("short_description")
  description      String?

  // Hierarchy
  parentId String?   @map("parent_id")
  parent   Product?  @relation("ProductHierarchy", fields: [parentId], references: [id])
  children Product[] @relation("ProductHierarchy")
  isMaster Boolean   @default(false) @map("is_master")

  // Media
  image       String?
  images      Json?
  brochureUrl String? @map("brochure_url")
  videoUrl    String? @map("video_url")

  // Pricing (base)
  mrp           Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(12, 2)
  costPrice     Decimal? @map("cost_price") @db.Decimal(12, 2)

  // Tax (Indian GST)
  taxType      TaxType  @default(GST) @map("tax_type")
  hsnCode      String?  @map("hsn_code")
  gstRate      Decimal? @map("gst_rate") @db.Decimal(5, 2)
  cessRate     Decimal? @map("cess_rate") @db.Decimal(5, 2)
  taxInclusive Boolean  @default(false) @map("tax_inclusive")

  // Unit & Packing
  primaryUnit      UnitType  @default(PIECE) @map("primary_unit")
  secondaryUnit    UnitType? @map("secondary_unit")
  conversionFactor Decimal?  @map("conversion_factor") @db.Decimal(10, 4)
  minOrderQty      Decimal?  @map("min_order_qty") @db.Decimal(10, 2)
  maxOrderQty      Decimal?  @map("max_order_qty") @db.Decimal(10, 2)
  weight           Decimal?  @db.Decimal(10, 3)
  dimensions       Json?

  // Packing Detail
  packingSize        Int?      @map("packing_size")
  packingUnit        UnitType? @map("packing_unit")
  packingDescription String?   @map("packing_description")
  barcode            String?
  batchTracking      Boolean   @default(false) @map("batch_tracking")

  // License & Sale Rules
  licenseRequired Boolean @default(false) @map("license_required")
  licenseType     String? @map("license_type")
  licenseNumber   String? @map("license_number")
  individualSale  Boolean @default(true) @map("individual_sale")
  isReturnable    Boolean @default(true) @map("is_returnable")
  warrantyMonths  Int?    @map("warranty_months")
  shelfLifeDays   Int?    @map("shelf_life_days")

  // Brand & Manufacturer Relations
  brandId        String?       @map("brand_id")
  brand          Brand?        @relation(fields: [brandId], references: [id])
  manufacturerId String?       @map("manufacturer_id")
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])

  // Status & Meta
  status      ProductStatus @default(ACTIVE)
  sortOrder   Int           @default(0) @map("sort_order")
  tags        String[]      @default([])
  configJson  Json?         @map("config_json")
  isActive    Boolean       @default(true) @map("is_active")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  prices          ProductPrice[]
  taxDetails      ProductTaxDetail[]
  unitConversions ProductUnitConversion[]
  filters         ProductFilter[]
  relatedFrom     ProductRelation[]       @relation("RelatedFrom")
  relatedTo       ProductRelation[]       @relation("RelatedTo")

  @@unique([tenantId, code])
  @@unique([tenantId, slug])
  @@index([code])
  @@index([parentId])
  @@index([status, isActive])
  @@index([tenantId])
  @@map("products")
}

// ═══════════════════════════════════════════════════════
// PRODUCT PRICING
// ═══════════════════════════════════════════════════════

model ProductPrice {
  id           String              @id @default(uuid())
  tenantId     String              @default("") @map("tenant_id")
  productId    String              @map("product_id")
  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceType    PriceType           @map("price_type")
  priceGroupId String?             @map("price_group_id")
  priceGroup   CustomerPriceGroup? @relation(fields: [priceGroupId], references: [id])
  amount       Decimal             @db.Decimal(12, 2)
  currency     String              @default("INR")
  minQty       Decimal?            @map("min_qty") @db.Decimal(10, 2)
  maxQty       Decimal?            @map("max_qty") @db.Decimal(10, 2)
  validFrom    DateTime?           @map("valid_from")
  validTo      DateTime?           @map("valid_to")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([productId, priceType, priceGroupId])
  @@index([tenantId])
  @@map("product_prices")
}

model CustomerPriceGroup {
  id          String                 @id @default(uuid())
  tenantId    String                 @default("") @map("tenant_id")
  name        String
  code        String
  description String?
  discount    Decimal?               @db.Decimal(5, 2)
  priority    Int                    @default(0)
  isActive    Boolean                @default(true) @map("is_active")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  prices      ProductPrice[]
  customers   CustomerGroupMapping[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("customer_price_groups")
}

model CustomerGroupMapping {
  id             String             @id @default(uuid())
  tenantId       String             @default("") @map("tenant_id")
  priceGroupId   String             @map("price_group_id")
  priceGroup     CustomerPriceGroup @relation(fields: [priceGroupId], references: [id], onDelete: Cascade)
  contactId      String?            @map("contact_id")
  organizationId String?            @map("organization_id")
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")

  @@unique([tenantId, priceGroupId, contactId])
  @@unique([tenantId, priceGroupId, organizationId])
  @@index([tenantId])
  @@map("customer_group_mappings")
}

// ═══════════════════════════════════════════════════════
