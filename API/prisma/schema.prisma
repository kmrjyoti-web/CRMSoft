// ═══════════════════════════════════════════════════════
// OFFLINE SYNC ENGINE
// ═══════════════════════════════════════════════════════

model SyncPolicy {
  id String @id @default(uuid())

  // ─── ENTITY ───
  entityName  String @map("entity_name")
  displayName String @map("display_name")

  // ─── DIRECTION CONTROL ───
  direction SyncDirection @default(BIDIRECTIONAL)

  // ─── FREQUENCY ───
  syncIntervalMinutes Int @map("sync_interval_minutes")

  // ─── DATA LIMITS ───
  maxRowsOffline Int? @map("max_rows_offline")
  maxStorageMb   Int? @map("max_storage_mb")

  // ─── STALENESS ───
  maxDataAgeDays Int? @map("max_data_age_days")

  // ─── CONFLICT RESOLUTION ───
  conflictStrategy ConflictStrategy @default(LATEST_WINS) @map("conflict_strategy")

  // ─── DOWNLOAD SCOPE ───
  downloadScope  String @default("OWNED") @map("download_scope")
  downloadFilter Json?  @map("download_filter")

  // ─── PRIORITY ───
  syncPriority Int @default(5) @map("sync_priority")

  // ─── STATUS ───
  isEnabled Boolean @default(true) @map("is_enabled")

  // ─── AUDIT ───
  updatedById   String? @map("updated_by_id")
  updatedByName String? @map("updated_by_name")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  warningRules SyncWarningRule[]

  @@unique([tenantId, entityName])
  @@index([tenantId])
  @@map("sync_policies")
}

model SyncWarningRule {
  id String @id @default(uuid())

  // ─── LINK ───
  policyId String?     @map("policy_id")
  policy   SyncPolicy? @relation(fields: [policyId], references: [id])

  // ─── RULE ───
  name        String
  description String?

  // ─── TRIGGER CONDITION ───
  trigger        SyncWarningTrigger
  thresholdValue Decimal            @map("threshold_value") @db.Decimal(10, 2)
  thresholdUnit  String             @map("threshold_unit")

  // ─── ESCALATION LEVELS ───
  level1Action    SyncEnforcement @default(WARN_ONLY) @map("level_1_action")
  level1Threshold Decimal?        @map("level_1_threshold") @db.Decimal(10, 2)
  level1Message   String?         @map("level_1_message")

  level2Action       SyncEnforcement? @map("level_2_action")
  level2Threshold    Decimal?         @map("level_2_threshold") @db.Decimal(10, 2)
  level2Message      String?          @map("level_2_message")
  level2DelayMinutes Int?             @map("level_2_delay_minutes")

  level3Action    SyncEnforcement? @map("level_3_action")
  level3Threshold Decimal?         @map("level_3_threshold") @db.Decimal(10, 2)
  level3Message   String?          @map("level_3_message")

  // ─── SCOPE ───
  appliesToRoles String[] @map("applies_to_roles")
  appliesToUsers String[] @map("applies_to_users")

  isEnabled Boolean @default(true) @map("is_enabled")
  priority  Int     @default(5)

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([trigger, isEnabled])
  @@index([tenantId])
  @@map("sync_warning_rules")
}

model SyncDevice {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // ─── DEVICE INFO ───
  deviceId   String  @map("device_id")
  deviceName String? @map("device_name")
  deviceType String? @map("device_type")
  platform   String?
  appVersion String? @map("app_version")

  // ─── STATUS ───
  status DeviceStatus @default(ACTIVE)

  // ─── SYNC STATE ───
  lastSyncAt      DateTime? @map("last_sync_at")
  lastHeartbeatAt DateTime? @map("last_heartbeat_at")
  lastIpAddress   String?   @map("last_ip_address")

  // ─── STORAGE ───
  storageUsedMb Decimal? @map("storage_used_mb") @db.Decimal(10, 2)
  recordCounts  Json?    @map("record_counts")

  // ─── PENDING CHANGES ───
  pendingUploadCount Int       @default(0) @map("pending_upload_count")
  oldestPendingAt    DateTime? @map("oldest_pending_at")

  // ─── ENTITY SYNC TIMESTAMPS ───
  entitySyncState Json? @map("entity_sync_state")

  // ─── FLUSH STATE ───
  pendingFlushId String? @map("pending_flush_id")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId, deviceId])
  @@index([userId, status])
  @@index([tenantId])
  @@map("sync_devices")
}

model SyncConflict {
  id String @id @default(uuid())

  deviceId String @map("device_id")
  userId   String @map("user_id")

  // ─── ENTITY ───
  entityName  String  @map("entity_name")
  entityId    String  @map("entity_id")
  entityLabel String? @map("entity_label")

  // ─── VERSIONS ───
  clientData Json  @map("client_data")
  serverData Json  @map("server_data")
  baseData   Json? @map("base_data")

  clientModifiedAt DateTime @map("client_modified_at")
  serverModifiedAt DateTime @map("server_modified_at")

  // ─── FIELD-LEVEL DIFF ───
  conflictingFields   Json  @map("conflicting_fields")
  nonConflictingMerge Json? @map("non_conflicting_merge")

  // ─── RESOLUTION ───
  status           ConflictStatus @default(PENDING)
  resolvedBy       String?        @map("resolved_by")
  resolvedStrategy String?        @map("resolved_strategy")
  resolvedData     Json?          @map("resolved_data")
  resolvedAt       DateTime?      @map("resolved_at")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, status])
  @@index([entityName, entityId])
  @@index([tenantId])
  @@map("sync_conflicts")
}

model SyncFlushCommand {
  id String @id @default(uuid())

  // ─── TARGET ───
  flushType      FlushType @map("flush_type")
  targetUserId   String?   @map("target_user_id")
  targetDeviceId String?   @map("target_device_id")
  targetEntity   String?   @map("target_entity")

  // ─── INSTRUCTION ───
  reason          String
  redownloadAfter Boolean @default(true) @map("redownload_after")

  // ─── STATUS ───
  status         FlushStatus @default(PENDING)
  acknowledgedAt DateTime?   @map("acknowledged_at")
  executedAt     DateTime?   @map("executed_at")

  issuedById   String @map("issued_by_id")
  issuedByName String @map("issued_by_name")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetUserId, status])
  @@index([tenantId])
  @@map("sync_flush_commands")
}

model SyncChangeLog {
  id String @id @default(uuid())

  deviceId String @map("device_id")
  userId   String @map("user_id")

  // ─── CHANGE ───
  entityName String       @map("entity_name")
  entityId   String       @map("entity_id")
  action     ChangeAction

  changedFields  Json? @map("changed_fields")
  fullRecord     Json? @map("full_record")
  previousValues Json? @map("previous_values")

  clientTimestamp DateTime @map("client_timestamp")
  clientVersion   Int      @default(1) @map("client_version")

  // ─── SYNC STATE ───
  isPushed     Boolean   @default(false) @map("is_pushed")
  pushedAt     DateTime? @map("pushed_at")
  pushResult   String?   @map("push_result")
  conflictId   String?   @map("conflict_id")
  errorMessage String?   @map("error_message")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, deviceId, isPushed])
  @@index([entityName, entityId])
  @@index([tenantId])
  @@map("sync_change_logs")
}

model SyncAuditLog {
  id String @id @default(uuid())

  userId   String @map("user_id")
  deviceId String @map("device_id")

  action     String
  entityName String? @map("entity_name")

  // ─── METRICS ───
  recordsPulled     Int? @map("records_pulled")
  recordsPushed     Int? @map("records_pushed")
  conflictsDetected Int? @map("conflicts_detected")
  conflictsResolved Int? @map("conflicts_resolved")
  durationMs        Int? @map("duration_ms")

  details      Json?
  errorMessage String? @map("error_message")

  tenantId  String   @default("") @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([tenantId])
  @@map("sync_audit_logs")
}

// ═══════════════════════════════════════════════════════
// TENANT CONFIGURATION & CREDENTIAL STORE
// ═══════════════════════════════════════════════════════

enum ConfigCategory {
  GENERAL
  NUMBERING
  BUSINESS_HOURS
  LEAD_SETTINGS
  COMMUNICATION
  NOTIFICATION
  DISPLAY
  SECURITY
  SYNC
  CUSTOM
}

enum ConfigValueType {
  STRING
  INTEGER
  DECIMAL
  BOOLEAN
  JSON
  ENUM
}

enum CredentialProvider {
  GMAIL
  OUTLOOK
  SMTP
  WHATSAPP_BUSINESS
  RAZORPAY
  STRIPE
  AWS_S3
  MINIO
  GOOGLE_DRIVE
  ONEDRIVE
  DROPBOX
  GOOGLE_MAPS
  EXOTEL
  KNOWLARITY
  TWILIO
  FIREBASE
  SENDGRID
  MAILGUN
  CUSTOM
  // AI Providers
  ANTHROPIC_CLAUDE
  OPENAI_GPT
  GOOGLE_GEMINI
  GROQ
}

enum CredentialStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  ERROR
  PENDING_SETUP
  REVOKED
}

model TenantConfig {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  // ─── CATEGORIZATION ───
  category     ConfigCategory
  configKey    String          @map("config_key")
  configValue  String          @map("config_value")
  valueType    ConfigValueType @default(STRING) @map("value_type")
  defaultValue String?         @map("default_value")

  // ─── DISPLAY ───
  displayName String  @map("display_name")
  description String?
  groupName   String? @map("group_name")
  sortOrder   Int     @default(0) @map("sort_order")

  // ─── VALIDATION ───
  isRequired     Boolean  @default(false) @map("is_required")
  validationRule String?  @map("validation_rule")
  minValue       Decimal? @map("min_value") @db.Decimal(10, 2)
  maxValue       Decimal? @map("max_value") @db.Decimal(10, 2)
  enumOptions    Json?    @map("enum_options")

  // ─── ACCESS CONTROL ───
  isReadOnly   Boolean @default(false) @map("is_read_only")
  requiredRole String? @map("required_role")
  isVisible    Boolean @default(true) @map("is_visible")

  // ─── AUDIT ───
  updatedById   String? @map("updated_by_id")
  updatedByName String? @map("updated_by_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, configKey])
  @@index([tenantId, category])
  @@map("tenant_configs")
}

model TenantCredential {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  // ─── PROVIDER ───
  provider     CredentialProvider
  instanceName String?            @map("instance_name")

  // ─── ENCRYPTED DATA ───
  encryptedData     String @map("encrypted_data") @db.Text
  encryptionVersion Int    @default(1) @map("encryption_version")

  // ─── STATUS ───
  status        CredentialStatus @default(PENDING_SETUP)
  statusMessage String?          @map("status_message")

  // ─── VERIFICATION ───
  lastVerifiedAt  DateTime? @map("last_verified_at")
  lastVerifyError String?   @map("last_verify_error")
  verifyCount     Int       @default(0) @map("verify_count")

  // ─── TOKEN REFRESH ───
  tokenExpiresAt   DateTime? @map("token_expires_at")
  lastRefreshedAt  DateTime? @map("last_refreshed_at")
  refreshFailCount Int       @default(0) @map("refresh_fail_count")

  // ─── USAGE TRACKING ───
  lastUsedAt      DateTime? @map("last_used_at")
  usageCount      Int       @default(0) @map("usage_count")
  dailyUsageCount Int       @default(0) @map("daily_usage_count")
  dailyUsageLimit Int?      @map("daily_usage_limit")

  // ─── METADATA ───
  description        String?
  linkedAccountEmail String? @map("linked_account_email")
  webhookUrl         String? @map("webhook_url")
  isPrimary          Boolean @default(true) @map("is_primary")

  // ─── AUDIT ───
  createdById   String  @map("created_by_id")
  createdByName String  @map("created_by_name")
  updatedById   String? @map("updated_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  accessLogs CredentialAccessLog[]

  @@unique([tenantId, provider, instanceName])
  @@index([tenantId, provider, status])
  @@map("tenant_credentials")
}

model CredentialAccessLog {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")

  credentialId String           @map("credential_id")
  credential   TenantCredential @relation(fields: [credentialId], references: [id])

  action         String
  accessedById   String  @map("accessed_by_id")
  accessedByName String  @map("accessed_by_name")
  accessedByIp   String? @map("accessed_by_ip")
  provider       String
  details        String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, credentialId, createdAt])
  @@map("credential_access_logs")
}

model GlobalDefaultCredential {
  id String @id @default(uuid())

  // ─── PROVIDER ───
  provider CredentialProvider @unique

  // ─── ENCRYPTED DATA ───
  encryptedData     String @map("encrypted_data") @db.Text
  encryptionVersion Int    @default(1) @map("encryption_version")

  // ─── STATUS ───
  status      CredentialStatus @default(ACTIVE)
  description String?
  isEnabled   Boolean          @default(false) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("global_default_credentials")
}

// ─── CRON ENGINE ───

enum CronJobStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum CronJobScope {
  GLOBAL
  TENANT
}

enum CronRunStatus {
  SUCCESS
  FAILED
  TIMEOUT
  SKIPPED
  RUNNING
}

enum CronAlertChannel {
  EMAIL
  IN_APP
  BOTH
}

model CronJobConfig {
  id String @id @default(uuid())

  // ─── IDENTITY ───
  jobCode     String  @unique @map("job_code")
  jobName     String  @map("job_name")
  description String?
  moduleName  String  @map("module_name")

  // ─── SCHEDULE ───
  cronExpression  String  @map("cron_expression")
  cronDescription String? @map("cron_description")
  timezone        String  @default("Asia/Kolkata")

  // ─── SCOPE ───
  scope CronJobScope @default(GLOBAL)

  // ─── STATUS ───
  status CronJobStatus @default(ACTIVE)

  // ─── EXECUTION CONTROL ───
  timeoutSeconds    Int     @default(300) @map("timeout_seconds")
  maxRetries        Int     @default(0) @map("max_retries")
  retryDelaySeconds Int     @default(60) @map("retry_delay_seconds")
  allowConcurrent   Boolean @default(false) @map("allow_concurrent")

  // ─── LAST RUN STATE ───
  isRunning         Boolean        @default(false) @map("is_running")
  lastRunAt         DateTime?      @map("last_run_at")
  lastRunStatus     CronRunStatus? @map("last_run_status")
  lastRunDurationMs Int?           @map("last_run_duration_ms")
  lastRunError      String?        @map("last_run_error")
  lastRunRecords    Int?           @map("last_run_records")
  nextRunAt         DateTime?      @map("next_run_at")

  // ─── STATS ───
  totalRunCount  Int      @default(0) @map("total_run_count")
  totalFailCount Int      @default(0) @map("total_fail_count")
  avgDurationMs  Int?     @map("avg_duration_ms")
  successRate    Decimal? @map("success_rate") @db.Decimal(5, 2)

  // ─── ALERTING ───
  alertOnFailure                Boolean          @default(true) @map("alert_on_failure")
  alertOnTimeout                Boolean          @default(true) @map("alert_on_timeout")
  alertAfterConsecutiveFailures Int              @default(3) @map("alert_after_consecutive_failures")
  consecutiveFailures           Int              @default(0) @map("consecutive_failures")
  alertChannel                  CronAlertChannel @default(BOTH) @map("alert_channel")
  alertRecipientEmails          String[]         @map("alert_recipient_emails")
  alertRecipientUserIds         String[]         @map("alert_recipient_user_ids")

  // ─── JOB-SPECIFIC CONFIG ───
  jobParams Json? @map("job_params")

  // ─── AUDIT ───
  updatedById   String?  @map("updated_by_id")
  updatedByName String?  @map("updated_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  runLogs CronJobRunLog[]

  @@index([status])
  @@map("cron_job_configs")
}

model CronJobRunLog {
  id String @id @default(uuid())

  jobId   String        @map("job_id")
  job     CronJobConfig @relation(fields: [jobId], references: [id])
  jobCode String        @map("job_code")

  // ─── EXECUTION ───
  startedAt  DateTime      @map("started_at")
  finishedAt DateTime?     @map("finished_at")
  durationMs Int?          @map("duration_ms")
  status     CronRunStatus

  // ─── RESULTS ───
  recordsProcessed Int? @map("records_processed")
  recordsSucceeded Int? @map("records_succeeded")
  recordsFailed    Int? @map("records_failed")

  // ─── SCOPE ───
  tenantId   String? @map("tenant_id")
  tenantName String? @map("tenant_name")

  // ─── ERROR ───
  errorMessage String? @map("error_message") @db.Text
  errorStack   String? @map("error_stack") @db.Text
  retryAttempt Int     @default(0) @map("retry_attempt")

  // ─── DETAILS ───
  details     Json?
  triggeredBy String @default("SCHEDULER") @map("triggered_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobCode, createdAt])
  @@index([status, createdAt])
  @@index([tenantId])
  @@map("cron_job_run_logs")
}

// ═══════════════════════════════════════════════════════
// ERROR CATALOG & LOGGING
// ═══════════════════════════════════════════════════════

enum ErrorLayer {
  BE
  FE
  DB
  MOB
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model ErrorCatalog {
  id            String        @id @default(uuid())
  code          String        @unique
  layer         ErrorLayer    @default(BE)
  module        String        @db.VarChar(100)
  severity      ErrorSeverity @default(ERROR)
  httpStatus    Int           @map("http_status")
  messageEn     String        @map("message_en") @db.Text
  messageHi     String?       @map("message_hi") @db.Text
  solutionEn    String?       @map("solution_en") @db.Text
  solutionHi    String?       @map("solution_hi") @db.Text
  technicalInfo String?       @map("technical_info") @db.Text
  helpUrl       String?       @map("help_url")
  isRetryable   Boolean       @default(false) @map("is_retryable")
  retryAfterMs  Int?          @map("retry_after_ms")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([layer, module])
  @@index([severity])
  @@index([httpStatus])
  @@map("error_catalog")
}

model ErrorLog {
  id          String        @id @default(uuid())
  requestId   String        @map("request_id")
  errorCode   String        @map("error_code")
  message     String        @db.Text
  statusCode  Int           @map("status_code")
  layer       ErrorLayer    @default(BE)
  severity    ErrorSeverity @default(ERROR)
  path        String
  method      String
  userId      String?       @map("user_id")
  tenantId    String?       @map("tenant_id")
  details     Json?
  stack       String?       @db.Text
  ip          String?
  userAgent   String?       @map("user_agent") @db.VarChar(500)
  module      String?       @db.VarChar(100)
  requestBody Json?         @map("request_body")
  queryParams Json?         @map("query_params")
  metadata    Json?

  // ─── ENHANCED: Request/Response capture ───
  requestHeaders Json? @map("request_headers")
  responseBody   Json? @map("response_body")
  responseTimeMs Int?  @map("response_time_ms")

  // ─── ENHANCED: User/Tenant context ───
  userName     String? @map("user_name")
  userRole     String? @map("user_role")
  tenantName   String? @map("tenant_name")
  industryCode String? @map("industry_code")

  // ─── ENHANCED: Auto-report ───
  isAutoReported Boolean   @default(false) @map("is_auto_reported")
  autoReportedAt DateTime? @map("auto_reported_at")
  autoReportedTo String[]  @default([]) @map("auto_reported_to")

  // ─── ENHANCED: Resolution workflow ───
  status         String    @default("OPEN")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedById   String?   @map("resolved_by_id")
  resolution     String?   @db.Text
  assignedToId   String?   @map("assigned_to_id")
  assignedToName String?   @map("assigned_to_name")

  // ─── ENHANCED: Linked support ticket ───
  supportTicketId String? @map("support_ticket_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([errorCode, createdAt])
  @@index([tenantId, createdAt])
  @@index([requestId])
  @@index([layer, severity, createdAt])
  @@index([createdAt])
  @@index([status, severity])
  @@map("error_logs")
}

// ─── ERROR AUTO-REPORT RULES ───

model ErrorAutoReportRule {
  id       String  @id @default(uuid())
  tenantId String? @map("tenant_id")

  name     String
  severity ErrorSeverity
  channels String[]      @default([])

  emailRecipients String[] @default([]) @map("email_recipients")
  slackWebhookUrl String?  @map("slack_webhook_url")
  whatsappNumbers String[] @default([]) @map("whatsapp_numbers")

  throttleMinutes Int       @default(15) @map("throttle_minutes")
  lastTriggeredAt DateTime? @map("last_triggered_at")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("error_auto_report_rules")
}

