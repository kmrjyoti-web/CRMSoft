// ─── USER & AUTH ───

model User {
  id            String       @id @default(uuid())
  tenantId      String       @default("") @map("tenant_id")
  email         String
  password      String
  firstName     String       @map("first_name")
  lastName      String       @map("last_name")
  phone         String?
  avatar        String?
  status        UserStatus   @default(ACTIVE)
  userType      UserType     @default(EMPLOYEE) @map("user_type")
  lastLoginAt   DateTime?    @map("last_login_at")
  roleId        String       @map("role_id")
  role          Role         @relation(fields: [roleId], references: [id])
  departmentId  String?      @map("department_id")
  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  designationId String?      @map("designation_id")
  designation   Designation? @relation(fields: [designationId], references: [id])
  reportingToId String?      @map("reporting_to_id")
  reportingTo   User?        @relation("UserReporting", fields: [reportingToId], references: [id])
  reportees     User[]       @relation("UserReporting")
  employeeCode  String?      @map("employee_code")
  joiningDate   DateTime?    @map("joining_date")
  isDeleted     Boolean      @default(false) @map("is_deleted")
  deletedAt     DateTime?    @map("deleted_at")
  deletedById   String?      @map("deleted_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  createdBy     String?      @map("created_by")

  // ─── VERIFICATION STATUS ───
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  emailVerified      Boolean            @default(false) @map("email_verified")
  emailVerifiedAt    DateTime?          @map("email_verified_at")
  mobileVerified     Boolean            @default(false) @map("mobile_verified")
  mobileVerifiedAt   DateTime?          @map("mobile_verified_at")

  // ─── REGISTRATION TYPE ───
  registrationType RegistrationType @default(INDIVIDUAL) @map("registration_type")

  // ─── BUSINESS VERIFICATION (for B2B pricing) ───
  companyName           String?   @map("company_name")
  gstNumber             String?   @map("gst_number")
  gstVerified           Boolean   @default(false) @map("gst_verified")
  gstVerifiedAt         DateTime? @map("gst_verified_at")
  gstVerificationMethod String?   @map("gst_verification_method")

  // ─── BUSINESS DETAILS ───
  panNumber      String? @map("pan_number")
  businessType   String? @map("business_type")
  annualTurnover String? @map("annual_turnover")

  rawContactsCreated      RawContact[]             @relation("RawContactCreatedBy")
  rawContactsVerified     RawContact[]             @relation("RawContactVerifiedBy")
  contactsCreated         Contact[]                @relation("ContactCreatedBy")
  organizationsCreated    Organization[]           @relation("OrgCreatedBy")
  leadsAllocated          Lead[]                   @relation("LeadAllocatedTo")
  leadsCreated            Lead[]                   @relation("LeadCreatedBy")
  activities              Activity[]
  demos                   Demo[]
  tourPlans               TourPlan[]
  quotations              Quotation[]
  entityOwners            EntityOwner[]            @relation("OwnerUser")
  assignedOwners          EntityOwner[]            @relation("AssignedByUser")
  transfersFrom           OwnershipLog[]           @relation("TransferFrom")
  transfersTo             OwnershipLog[]           @relation("TransferTo")
  transfersBy             OwnershipLog[]           @relation("ChangedBy")
  customerProfile         CustomerProfile?
  referralPartner         ReferralPartner?
  permissionOverrides     UserPermissionOverride[]
  approvalsMade           ApprovalRequest[]        @relation("ApprovalMaker")
  approvalsChecked        ApprovalRequest[]        @relation("ApprovalChecker")
  departmentsHeaded       Department[]             @relation("DepartmentHead")
  workflowsCreated        Workflow[]               @relation("WorkflowCreatedBy")
  proformaInvoicesCreated ProformaInvoice[]        @relation("ProformaCreatedBy")

  // Scheduler & Calendar relations
  followUpsAssigned FollowUp[]       @relation("FollowUpAssignedTo")
  followUpsCreated  FollowUp[]       @relation("FollowUpCreatedBy")
  remindersReceived Reminder[]       @relation("ReminderRecipient")
  remindersCreated  Reminder[]       @relation("ReminderCreatedBy")
  recurringEvents   RecurringEvent[] @relation("RecurringEventCreatedBy")
  calendarEvents    CalendarEvent[]  @relation("CalendarEventUser")

  // Ownership & Assignment relations
  userCapacity UserCapacity? @relation("UserCapacity")

  // Notification relations
  notifications          Notification[]          @relation("NotificationRecipient")
  notificationsSent      Notification[]          @relation("NotificationSender")
  notificationPreference NotificationPreference?
  pushSubscriptions      PushSubscription[]

  // Document & File Management relations
  documentsUploaded   Document[]           @relation("DocumentUploadedBy")
  documentAttachments DocumentAttachment[] @relation("AttachmentAttachedBy")
  foldersCreated      DocumentFolder[]     @relation("FolderCreatedBy")
  cloudConnections    CloudConnection[]    @relation("CloudConnectionUser")
  shareLinksCreated   DocumentShareLink[]  @relation("ShareLinkCreatedBy")
  documentActivities  DocumentActivity[]   @relation("DocumentActivityUser")

  // Email Integration relations
  emailAccounts   EmailAccount[]   @relation("EmailAccountUser")
  emailSignatures EmailSignature[] @relation("EmailSignatureUser")

  // WhatsApp Integration relations
  waConversationsAssigned WaConversation[] @relation("WaConversationAssignedTo")

  // Task & Comment relations
  tasksAssigned Task[]            @relation("TaskAssignedTo")
  tasksCreated  Task[]            @relation("TaskCreatedBy")
  taskChanges   TaskHistory[]     @relation("TaskHistoryChangedBy")
  taskWatches   TaskWatcher[]     @relation("TaskWatcherUser")
  comments      Comment[]         @relation("CommentAuthor")
  quietHours    QuietHourConfig[] @relation("QuietHourUser")

  // Calendar & Scheduling relations
  scheduledEventsOrganized ScheduledEvent[]   @relation("ScheduledEventOrganizer")
  scheduledEventsCreated   ScheduledEvent[]   @relation("ScheduledEventCreatedBy")
  eventParticipants        EventParticipant[] @relation("EventParticipantUser")
  eventHistoryChanges      EventHistory[]     @relation("EventHistoryChangedBy")
  calendarSyncs            UserCalendarSync[] @relation("UserCalendarSyncUser")
  userAvailability         UserAvailability[] @relation("UserAvailabilityUser")
  blockedSlots             BlockedSlot[]      @relation("BlockedSlotUser")

  // Table Config & Data Masking relations
  tableConfigs        TableConfig[]       @relation("TableConfigUser")
  dataMaskingPolicies DataMaskingPolicy[] @relation("DataMaskingPolicyUser")
  unmaskAuditLogs     UnmaskAuditLog[]    @relation("UnmaskAuditLogUser")

  @@unique([tenantId, email])
  @@unique([tenantId, employeeCode])
  @@index([userType, status])
  @@index([tenantId])
  @@index([isDeleted])
  @@map("users")
}

model CustomerProfile {
  id             String   @id @default(uuid())
  tenantId       String   @default("") @map("tenant_id")
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String?  @map("company_name")
  gstNumber      String?  @map("gst_number")
  billingAddress String?  @map("billing_address")
  city           String?
  state          String?
  country        String?
  pincode        String?
  industry       String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("customer_profiles")
}

model ReferralPartner {
  id             String   @id @default(uuid())
  tenantId       String   @default("") @map("tenant_id")
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCode   String   @map("referral_code")
  commissionRate Decimal  @default(10) @map("commission_rate") @db.Decimal(5, 2)
  totalReferrals Int      @default(0) @map("total_referrals")
  totalEarnings  Decimal  @default(0) @map("total_earnings") @db.Decimal(12, 2)
  bankName       String?  @map("bank_name")
  bankAccount    String?  @map("bank_account")
  ifscCode       String?  @map("ifsc_code")
  panNumber      String?  @map("pan_number")
  isActive       Boolean  @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, userId])
  @@unique([tenantId, referralCode])
  @@index([tenantId])
  @@map("referral_partners")
}

model Department {
  id           String        @id @default(uuid())
  tenantId     String        @default("") @map("tenant_id")
  name         String
  displayName  String        @map("display_name")
  code         String
  description  String?
  level        Int           @default(0)
  path         String? // materialized path like "/COMPANY/SALES/NORTH"
  parentId     String?       @map("parent_id")
  parent       Department?   @relation("DeptHierarchy", fields: [parentId], references: [id])
  children     Department[]  @relation("DeptHierarchy")
  headUserId   String?       @map("head_user_id")
  headUser     User?         @relation("DepartmentHead", fields: [headUserId], references: [id])
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  users        User[]        @relation("UserDepartment")
  designations Designation[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Designation {
  id           String        @id @default(uuid())
  tenantId     String        @default("") @map("tenant_id")
  name         String
  code         String
  description  String?
  level        Int           @default(0)
  grade        String?
  departmentId String?       @map("department_id")
  department   Department?   @relation(fields: [departmentId], references: [id])
  parentId     String?       @map("parent_id")
  parent       Designation?  @relation("DesigHierarchy", fields: [parentId], references: [id])
  children     Designation[] @relation("DesigHierarchy")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  users        User[]

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("designations")
}

model Role {
  id                  String               @id @default(uuid())
  tenantId            String               @default("") @map("tenant_id")
  name                String
  displayName         String               @map("display_name")
  description         String?
  isSystem            Boolean              @default(false) @map("is_system")
  level               Int                  @default(5)
  parentRoleName      String?              @map("parent_role_name")
  canManageLevels     Int[]                @default([]) @map("can_manage_levels")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  users               User[]
  permissions         RolePermission[]
  menuPermissions     RoleMenuPermission[]
  dataMaskingPolicies DataMaskingPolicy[]  @relation("DataMaskingPolicyRole")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  tenantId     String     @default("") @map("tenant_id")
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
  @@map("role_permissions")
}

// ─── ROLE MENU PERMISSIONS (per-menu CRUD granularity) ───

model RoleMenuPermission {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  roleId   String @map("role_id")
  menuId   String @map("menu_id")

  // ─── CRUD PERMISSIONS ───
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")

  // ─── DATA OPERATIONS ───
  canExport     Boolean @default(false) @map("can_export")
  canImport     Boolean @default(false) @map("can_import")
  canBulkUpdate Boolean @default(false) @map("can_bulk_update")
  canBulkDelete Boolean @default(false) @map("can_bulk_delete")

  // ─── WORKFLOW PERMISSIONS ───
  canApprove  Boolean @default(false) @map("can_approve")
  canAssign   Boolean @default(false) @map("can_assign")
  canTransfer Boolean @default(false) @map("can_transfer")

  // ─── SCOPE PERMISSIONS ───
  canViewAll   Boolean @default(false) @map("can_view_all")
  canEditAll   Boolean @default(false) @map("can_edit_all")
  canDeleteAll Boolean @default(false) @map("can_delete_all")

  // ─── FIELD-LEVEL RESTRICTIONS ───
  restrictedFields Json? @map("restricted_fields")

  // ─── INHERITANCE ───
  inheritFromParent Boolean @default(true) @map("inherit_from_parent")

  // ─── RELATIONS ───
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  // ─── AUDIT ───
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")

  @@unique([tenantId, roleId, menuId])
  @@index([tenantId, roleId])
  @@index([menuId])
  @@map("role_menu_permissions")
}

model PermissionTemplate {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?
  tenantId    String? @map("tenant_id")
  isSystem    Boolean @default(false) @map("is_system")
  isDefault   Boolean @default(false) @map("is_default")

  // ─── PER-MENU PERMISSIONS (JSON map: { menuCode: { canView, canCreate, ... } }) ───
  permissions Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("permission_templates")
}

// ─── LOOKUP ───

model MasterLookup {
  id          String        @id @default(uuid())
  tenantId    String        @default("") @map("tenant_id")
  category    String
  displayName String        @map("display_name")
  description String?
  isSystem    Boolean       @default(false) @map("is_system")
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  values      LookupValue[]

  @@unique([tenantId, category])
  @@index([tenantId])
  @@map("master_lookups")
}

model LookupValue {
  id         String        @id @default(uuid())
  tenantId   String        @default("") @map("tenant_id")
  lookupId   String        @map("lookup_id")
  value      String
  label      String
  icon       String?
  color      String?
  rowIndex   Int           @default(0) @map("row_index")
  isDefault  Boolean       @default(false) @map("is_default")
  isActive   Boolean       @default(true) @map("is_active")
  parentId   String?       @map("parent_id")
  configJson Json?         @map("config_json")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  lookup     MasterLookup  @relation(fields: [lookupId], references: [id], onDelete: Cascade)
  parent     LookupValue?  @relation("LookupHierarchy", fields: [parentId], references: [id])
  children   LookupValue[] @relation("LookupHierarchy")

  // All filter relations
  rawContactFilters   RawContactFilter[]
  contactFilters      ContactFilter[]
  organizationFilters OrganizationFilter[]
  leadFilters         LeadFilter[]
  productFilters      ProductFilter[]

  @@unique([tenantId, lookupId, value])
  @@index([tenantId])
  @@map("lookup_values")
}

// ═══════════════════════════════════════════════════════
// RAW CONTACT (Unverified — entry point)
// ═══════════════════════════════════════════════════════

model RawContact {
  id            String           @id @default(uuid())
  tenantId      String           @default("") @map("tenant_id")
  source        RawContactSource @default(MANUAL)
  status        RawContactStatus @default(RAW)
  firstName     String           @map("first_name")
  lastName      String           @map("last_name")
  designation   String?
  department    String?
  companyName   String?          @map("company_name")
  notes         String?
  isActive      Boolean          @default(true) @map("is_active")
  isDeleted                 Boolean          @default(false) @map("is_deleted")
  entityVerificationStatus  String           @default("UNVERIFIED") @map("entity_verification_status")
  entityVerifiedVia         String?          @map("entity_verified_via")
  deletedAt     DateTime?        @map("deleted_at")
  deletedById   String?          @map("deleted_by_id")
  verifiedAt    DateTime?        @map("verified_at")
  verifiedById  String?          @map("verified_by_id")
  verifiedBy    User?            @relation("RawContactVerifiedBy", fields: [verifiedById], references: [id])
  contactId     String?          @map("contact_id")
  contact       Contact?         @relation(fields: [contactId], references: [id])
  createdById   String           @map("created_by_id")
  createdByUser User             @relation("RawContactCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  filters        RawContactFilter[]
  communications Communication[]    @relation("CommRawContact")

  @@index([status])
  @@index([firstName, lastName])
  @@index([tenantId])
  @@index([isDeleted])
  @@map("raw_contacts")
}

model RawContactFilter {
  id            String      @id @default(uuid())
  tenantId      String      @default("") @map("tenant_id")
  rawContactId  String      @map("raw_contact_id")
  lookupValueId String      @map("lookup_value_id")
  rawContact    RawContact  @relation(fields: [rawContactId], references: [id], onDelete: Cascade)
  lookupValue   LookupValue @relation(fields: [lookupValueId], references: [id], onDelete: Cascade)

  @@unique([tenantId, rawContactId, lookupValueId])
  @@index([tenantId])
  @@map("raw_contact_filters")
}

// ═══════════════════════════════════════════════════════
// CONTACT (Verified — Contact Master)
// ═══════════════════════════════════════════════════════

model Contact {
  id             String        @id @default(uuid())
  tenantId       String        @default("") @map("tenant_id")
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  designation    String?
  department     String?
  notes          String?
  dataStatus     DataStatus    @default(COMPLETE) @map("data_status")
  isActive       Boolean       @default(true) @map("is_active")
  isDeleted                 Boolean       @default(false) @map("is_deleted")
  entityVerificationStatus  String        @default("UNVERIFIED") @map("entity_verification_status")
  entityVerifiedAt          DateTime?     @map("entity_verified_at")
  entityVerifiedVia         String?       @map("entity_verified_via")
  deletedAt      DateTime?     @map("deleted_at")
  deletedById    String?       @map("deleted_by_id")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdById    String        @map("created_by_id")
  createdByUser  User          @relation("ContactCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  leads                Lead[]
  filters              ContactFilter[]
  activities           Activity[]
  communications       Communication[]       @relation("CommContact")
  contactOrganizations ContactOrganization[]
  rawContacts          RawContact[]
  brandContacts        BrandContact[]
  manufacturerContacts ManufacturerContact[]
  tourPlanVisits       TourPlanVisit[]
  invoices             Invoice[]
  proformaInvoices     ProformaInvoice[]
  quotations           Quotation[] @relation("QuotationContactPerson")

  @@index([firstName, lastName])
  @@index([tenantId])
  @@index([isDeleted])
  @@map("contacts")
}

model ContactFilter {
  id            String      @id @default(uuid())
  tenantId      String      @default("") @map("tenant_id")
  contactId     String      @map("contact_id")
  lookupValueId String      @map("lookup_value_id")
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lookupValue   LookupValue @relation(fields: [lookupValueId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactId, lookupValueId])
  @@index([tenantId])
  @@map("contact_filters")
}

// ═══════════════════════════════════════════════════════
// ORGANIZATION
// ═══════════════════════════════════════════════════════

model Organization {
  id            String     @id @default(uuid())
  tenantId      String     @default("") @map("tenant_id")
  name          String
  email         String?
  phone         String?
  website       String?
  gstNumber     String?    @map("gst_number")
  industry      String?
  annualRevenue Float?     @map("annual_revenue")
  orgType       OrgType    @default(GENERAL) @map("org_type")
  address       String?
  city          String?
  state         String?
  country       String?
  pincode       String?
  notes         String?
  dataStatus    DataStatus @default(COMPLETE) @map("data_status")
  isActive      Boolean    @default(true) @map("is_active")
  isDeleted                 Boolean    @default(false) @map("is_deleted")
  entityVerificationStatus  String     @default("UNVERIFIED") @map("entity_verification_status")
  entityVerifiedAt          DateTime?  @map("entity_verified_at")
  entityVerifiedVia         String?    @map("entity_verified_via")
  deletedAt     DateTime?  @map("deleted_at")
  deletedById   String?    @map("deleted_by_id")
  createdById   String     @map("created_by_id")
  createdByUser User       @relation("OrgCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  filters            OrganizationFilter[]
  communications     Communication[]            @relation("CommOrganization")
  contacts           ContactOrganization[]
  leads              Lead[]
  contactMasters     Contact[]
  brandOrganizations BrandOrganization[]
  manufacturerOrgs   ManufacturerOrganization[]
  locations          OrganizationLocation[]
  invoices           Invoice[]
  proformaInvoices   ProformaInvoice[]
  quotations         Quotation[] @relation("QuotationOrganization")

  @@index([tenantId])
  @@index([isDeleted])
  @@map("organizations")
}

model OrganizationFilter {
  id             String       @id @default(uuid())
  tenantId       String       @default("") @map("tenant_id")
  organizationId String       @map("organization_id")
  lookupValueId  String       @map("lookup_value_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lookupValue    LookupValue  @relation(fields: [lookupValueId], references: [id], onDelete: Cascade)

  @@unique([tenantId, organizationId, lookupValueId])
  @@index([tenantId])
  @@map("organization_filters")
}

// ═══════════════════════════════════════════════════════
// CONTACT ↔ ORGANIZATION MAPPING
// ═══════════════════════════════════════════════════════

model ContactOrganization {
  id             String                 @id @default(uuid())
  tenantId       String                 @default("") @map("tenant_id")
  contactId      String                 @map("contact_id")
  organizationId String                 @map("organization_id")
  relationType   ContactOrgRelationType @default(EMPLOYEE) @map("relation_type")
  isPrimary      Boolean                @default(false) @map("is_primary")
  designation    String?
  department     String?
  startDate      DateTime?              @map("start_date")
  endDate        DateTime?              @map("end_date")
  isActive       Boolean                @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contactId, organizationId, relationType])
  @@index([organizationId, isActive])
  @@index([contactId, isActive])
  @@index([tenantId])
  @@map("contact_organizations")
}

// ═══════════════════════════════════════════════════════
// COMMUNICATION TABLE
// ═══════════════════════════════════════════════════════

model Communication {
  id           String            @id @default(uuid())
  tenantId     String            @default("") @map("tenant_id")
  type         CommunicationType
  value        String
  label        String?
  priorityType PriorityType      @default(PRIMARY) @map("priority_type")
  isPrimary    Boolean           @default(false) @map("is_primary")
  isVerified   Boolean           @default(false) @map("is_verified")

  rawContactId String?     @map("raw_contact_id")
  rawContact   RawContact? @relation("CommRawContact", fields: [rawContactId], references: [id], onDelete: SetNull)

  contactId String?  @map("contact_id")
  contact   Contact? @relation("CommContact", fields: [contactId], references: [id], onDelete: SetNull)

  organizationId String?       @map("organization_id")
  organization   Organization? @relation("CommOrganization", fields: [organizationId], references: [id], onDelete: SetNull)

  leadId String? @map("lead_id")
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([rawContactId])
  @@index([contactId])
  @@index([organizationId])
  @@index([leadId])
  @@index([type, value])
  @@index([tenantId])
  @@map("communications")
}

// ─── LEAD ───

model Lead {
  id                String            @id @default(uuid())
  tenantId          String            @default("") @map("tenant_id")
  leadNumber        String            @map("lead_number")
  status            LeadStatus        @default(NEW)
  priority          LeadPriority      @default(MEDIUM)
  expectedValue     Decimal?          @map("expected_value") @db.Decimal(12, 2)
  expectedCloseDate DateTime?         @map("expected_close_date")
  lostReason        String?           @map("lost_reason")
  notes             String?
  isActive          Boolean           @default(true) @map("is_active")
  isDeleted         Boolean           @default(false) @map("is_deleted")
  deletedAt         DateTime?         @map("deleted_at")
  deletedById       String?           @map("deleted_by_id")
  contactId         String            @map("contact_id")
  contact           Contact           @relation(fields: [contactId], references: [id])
  organizationId    String?           @map("organization_id")
  organization      Organization?     @relation(fields: [organizationId], references: [id])
  allocatedToId     String?           @map("allocated_to_id")
  allocatedTo       User?             @relation("LeadAllocatedTo", fields: [allocatedToId], references: [id])
  allocatedAt       DateTime?         @map("allocated_at")
  createdById       String            @map("created_by_id")
  createdByUser     User              @relation("LeadCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  activities        Activity[]
  demos             Demo[]
  tourPlans         TourPlan[]
  quotations        Quotation[]
  invoices          Invoice[]
  proformaInvoices  ProformaInvoice[]
  filters           LeadFilter[]
  communications    Communication[]
  tourPlanVisits    TourPlanVisit[]

  @@unique([tenantId, leadNumber])
  @@index([status, allocatedToId])
  @@index([tenantId])
  @@index([isDeleted])
  @@map("leads")
}

model LeadFilter {
  id            String      @id @default(uuid())
  tenantId      String      @default("") @map("tenant_id")
  leadId        String      @map("lead_id")
  lookupValueId String      @map("lookup_value_id")
  lead          Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  lookupValue   LookupValue @relation(fields: [lookupValueId], references: [id], onDelete: Cascade)

  @@unique([tenantId, leadId, lookupValueId])
  @@index([tenantId])
  @@map("lead_filters")
}

// ─── ACTIVITY ───

model Activity {
  id            String       @id @default(uuid())
  tenantId      String       @default("") @map("tenant_id")
  type          ActivityType
  subject       String
  description   String?
  outcome       String?
  duration      Int?
  scheduledAt   DateTime?    @map("scheduled_at")
  endTime       DateTime?    @map("end_time")
  completedAt   DateTime?    @map("completed_at")
  latitude      Decimal?     @db.Decimal(10, 7)
  longitude     Decimal?     @db.Decimal(10, 7)
  locationName  String?      @map("location_name")
  isActive      Boolean      @default(true) @map("is_active")
  isDeleted     Boolean      @default(false) @map("is_deleted")
  deletedAt     DateTime?    @map("deleted_at")
  deletedById   String?      @map("deleted_by_id")
  leadId        String?      @map("lead_id")
  lead          Lead?        @relation(fields: [leadId], references: [id])
  contactId     String?      @map("contact_id")
  contact       Contact?     @relation(fields: [contactId], references: [id])
  createdById   String       @map("created_by_id")
  createdByUser User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([leadId, type])
  @@index([tenantId])
  @@index([isDeleted])
  @@map("activities")
}

// ─── DEMO ───

model Demo {
  id              String      @id @default(uuid())
  tenantId        String      @default("") @map("tenant_id")
  mode            DemoMode
  status          DemoStatus  @default(SCHEDULED)
  scheduledAt     DateTime    @map("scheduled_at")
  completedAt     DateTime?   @map("completed_at")
  duration        Int?
  meetingLink     String?     @map("meeting_link")
  location        String?
  notes           String?
  outcome         String?
  result          DemoResult?
  rescheduleCount Int         @default(0) @map("reschedule_count")
  cancelReason    String?     @map("cancel_reason")
  noShowReason    String?     @map("no_show_reason")
  leadId          String      @map("lead_id")
  lead            Lead        @relation(fields: [leadId], references: [id])
  conductedById   String      @map("conducted_by_id")
  conductedBy     User        @relation(fields: [conductedById], references: [id])
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@index([leadId, status])
  @@index([tenantId])
  @@map("demos")
}

// ─── TOUR PLAN ───

model TourPlan {
  id             String         @id @default(uuid())
  tenantId       String         @default("") @map("tenant_id")
  title          String
  description    String?
  planDate       DateTime       @map("plan_date")
  status         TourPlanStatus @default(DRAFT)
  approvedById   String?        @map("approved_by_id")
  approvedAt     DateTime?      @map("approved_at")
  rejectedReason String?        @map("rejected_reason")
  checkInTime    DateTime?      @map("check_in_time")
  checkOutTime   DateTime?      @map("check_out_time")
  checkInLat     Decimal?       @map("check_in_lat") @db.Decimal(10, 7)
  checkInLng     Decimal?       @map("check_in_lng") @db.Decimal(10, 7)
  checkOutLat    Decimal?       @map("check_out_lat") @db.Decimal(10, 7)
  checkOutLng    Decimal?       @map("check_out_lng") @db.Decimal(10, 7)
  checkInPhoto   String?        @map("check_in_photo")
  startLocation  String?        @map("start_location")
  endLocation    String?        @map("end_location")
  leadId         String         @map("lead_id")
  lead           Lead           @relation(fields: [leadId], references: [id])
  salesPersonId  String         @map("sales_person_id")
  salesPerson    User           @relation(fields: [salesPersonId], references: [id])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  visits TourPlanVisit[]

  @@index([salesPersonId, planDate])
  @@index([tenantId])
  @@map("tour_plans")
}

// ─── QUOTATION (Enhanced) ───

model Quotation {
  id          String          @id @default(uuid())
  tenantId    String          @default("") @map("tenant_id")
  quotationNo String          @map("quotation_no")
  status      QuotationStatus @default(DRAFT)
  version     Int             @default(1)

  // ─── BUSINESS INFO ───
  title     String?
  summary   String?
  coverNote String? @map("cover_note")

  // ─── PRICING ───
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountType   String? @map("discount_type")
  discountValue  Decimal @default(0) @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount  Decimal @default(0) @map("taxable_amount") @db.Decimal(14, 2)
  cgstAmount     Decimal @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount     Decimal @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount     Decimal @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount     Decimal @default(0) @map("cess_amount") @db.Decimal(14, 2)
  totalTax       Decimal @default(0) @map("total_tax") @db.Decimal(14, 2)
  roundOff       Decimal @default(0) @map("round_off") @db.Decimal(14, 2)
  totalAmount    Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)

  // ─── PRICE FLEXIBILITY ───
  priceType        QuotationPriceType @default(FIXED) @map("price_type")
  minAmount        Decimal?           @map("min_amount") @db.Decimal(14, 2)
  maxAmount        Decimal?           @map("max_amount") @db.Decimal(14, 2)
  plusMinusPercent Decimal?           @map("plus_minus_percent") @db.Decimal(5, 2)

  // ─── VALIDITY & TERMS ───
  validFrom       DateTime? @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  paymentTerms    String?   @map("payment_terms")
  deliveryTerms   String?   @map("delivery_terms")
  warrantyTerms   String?   @map("warranty_terms")
  termsConditions String?   @map("terms_conditions")

  // ─── RELATIONS ───
  leadId          String  @map("lead_id")
  lead            Lead    @relation(fields: [leadId], references: [id])
  contactPersonId String?       @map("contact_person_id")
  contactPerson   Contact?      @relation("QuotationContactPerson", fields: [contactPersonId], references: [id])
  organizationId  String?       @map("organization_id")
  organization    Organization? @relation("QuotationOrganization", fields: [organizationId], references: [id])

  // ─── REVISION CHAIN ───
  parentQuotationId String?     @map("parent_quotation_id")
  parentQuotation   Quotation?  @relation("QuotationRevision", fields: [parentQuotationId], references: [id])
  revisions         Quotation[] @relation("QuotationRevision")

  // ─── ACCEPTANCE ───
  acceptedAt     DateTime? @map("accepted_at")
  acceptedNote   String?   @map("accepted_note")
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason")

  // ─── AI PREDICTION ───
  aiScore       Int?  @map("ai_score")
  aiSuggestions Json? @map("ai_suggestions")

  // ─── META ───
  tags          String[] @default([])
  configJson    Json?    @map("config_json")
  internalNotes String?  @map("internal_notes")

  // ─── AUDIT ───
  createdById   String   @map("created_by_id")
  createdByUser User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  // ─── CHILD TABLES ───
  lineItems        QuotationLineItem[]
  sendLogs         QuotationSendLog[]
  negotiations     QuotationNegotiationLog[]
  activities       QuotationActivity[]
  invoices         Invoice[]
  proformaInvoices ProformaInvoice[]

  @@unique([tenantId, quotationNo])
  @@index([leadId, status])
  @@index([status, createdAt])
  @@index([contactPersonId])
  @@index([organizationId])
  @@index([createdById, status])
  @@index([tenantId])
  @@map("quotations")
}

// ─── QUOTATION LINE ITEM ───

model QuotationLineItem {
  id          String    @id @default(uuid())
  tenantId    String    @default("") @map("tenant_id")
  quotationId String    @map("quotation_id")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  productId   String? @map("product_id")
  productCode String? @map("product_code")
  productName String  @map("product_name")
  description String?
  hsnCode     String? @map("hsn_code")

  quantity Decimal @db.Decimal(10, 2)
  unit     String?

  unitPrice      Decimal  @map("unit_price") @db.Decimal(14, 2)
  mrp            Decimal? @db.Decimal(14, 2)
  discountType   String?  @map("discount_type")
  discountValue  Decimal? @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(14, 2)
  lineTotal      Decimal  @map("line_total") @db.Decimal(14, 2)

  gstRate      Decimal? @map("gst_rate") @db.Decimal(5, 2)
  cgstAmount   Decimal  @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount   Decimal  @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount   Decimal  @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessRate     Decimal? @map("cess_rate") @db.Decimal(5, 2)
  cessAmount   Decimal  @default(0) @map("cess_amount") @db.Decimal(14, 2)
  taxAmount    Decimal  @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalWithTax Decimal  @map("total_with_tax") @db.Decimal(14, 2)

  sortOrder  Int     @default(0) @map("sort_order")
  notes      String?
  isOptional Boolean @default(false) @map("is_optional")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([quotationId])
  @@index([tenantId])
  @@map("quotation_line_items")
}

// ─── QUOTATION SEND LOG ───

model QuotationSendLog {
  id          String    @id @default(uuid())
  tenantId    String    @default("") @map("tenant_id")
  quotationId String    @map("quotation_id")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  sentAt     DateTime             @map("sent_at")
  sentById   String               @map("sent_by_id")
  sentByName String               @map("sent_by_name")
  channel    QuotationSendChannel

  receiverContactId String? @map("receiver_contact_id")
  receiverName      String? @map("receiver_name")
  receiverEmail     String? @map("receiver_email")
  receiverPhone     String? @map("receiver_phone")
  organizationId    String? @map("organization_id")
  organizationName  String? @map("organization_name")

  viewedAt     DateTime? @map("viewed_at")
  viewCount    Int       @default(0) @map("view_count")
  downloadedAt DateTime? @map("downloaded_at")

  quotationValue   Decimal            @map("quotation_value") @db.Decimal(14, 2)
  priceType        QuotationPriceType @map("price_type")
  minValue         Decimal?           @map("min_value") @db.Decimal(14, 2)
  maxValue         Decimal?           @map("max_value") @db.Decimal(14, 2)
  plusMinusPercent Decimal?           @map("plus_minus_percent") @db.Decimal(5, 2)

  message String?
  pdfUrl  String? @map("pdf_url")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([quotationId])
  @@index([sentById])
  @@index([tenantId])
  @@map("quotation_send_logs")
}

// ─── QUOTATION NEGOTIATION LOG ───

model QuotationNegotiationLog {
  id          String    @id @default(uuid())
  tenantId    String    @default("") @map("tenant_id")
  quotationId String    @map("quotation_id")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  negotiationType NegotiationType @map("negotiation_type")

  customerRequirement   String?  @map("customer_requirement")
  customerBudget        Decimal? @map("customer_budget") @db.Decimal(14, 2)
  customerPriceExpected Decimal? @map("customer_price_expected") @db.Decimal(14, 2)

  ourPrice           Decimal? @map("our_price") @db.Decimal(14, 2)
  proposedDiscount   Decimal? @map("proposed_discount") @db.Decimal(5, 2)
  counterOfferAmount Decimal? @map("counter_offer_amount") @db.Decimal(14, 2)

  itemsAdded    Json? @map("items_added")
  itemsRemoved  Json? @map("items_removed")
  itemsModified Json? @map("items_modified")

  termsChanged String? @map("terms_changed")

  note    String?
  outcome String?

  loggedById        String   @map("logged_by_id")
  loggedByName      String   @map("logged_by_name")
  contactPersonId   String?  @map("contact_person_id")
  contactPersonName String?  @map("contact_person_name")
  loggedAt          DateTime @map("logged_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([quotationId, loggedAt])
  @@index([tenantId])
  @@map("quotation_negotiation_logs")
}

// ─── QUOTATION ACTIVITY ───

model QuotationActivity {
  id          String    @id @default(uuid())
  tenantId    String    @default("") @map("tenant_id")
  quotationId String    @map("quotation_id")
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  action      String
  description String

  previousValue String? @map("previous_value")
  newValue      String? @map("new_value")
  changedField  String? @map("changed_field")

  performedById   String   @map("performed_by_id")
  performedByName String   @map("performed_by_name")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([quotationId, createdAt])
  @@index([tenantId])
  @@map("quotation_activities")
}

// ─── QUOTATION TEMPLATE ───

model QuotationTemplate {
  id          String  @id @default(uuid())
  tenantId    String  @default("") @map("tenant_id")
  name        String
  description String?

  industry        String?
  defaultItems    Json?   @map("default_items")
  defaultTerms    String? @map("default_terms")
  defaultPayment  String? @map("default_payment")
  defaultDelivery String? @map("default_delivery")
  defaultWarranty String? @map("default_warranty")
  coverNote       String? @map("cover_note")

  isActive   Boolean  @default(true) @map("is_active")
  usageCount Int      @default(0) @map("usage_count")
