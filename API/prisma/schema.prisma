// SUPPORT TICKET MODULE
// ═══════════════════════════════════════════════════════

enum TicketCategory {
  BUG
  FEATURE_REQUEST
  BILLING
  PERFORMANCE
  DATA_ISSUE
  SECURITY
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  WAITING_ON_VENDOR
  RESOLVED
  CLOSED
}

model SupportTicket {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  reportedById String @map("reported_by_id")

  ticketNo    String         @unique @map("ticket_no")
  subject     String
  description String         @db.Text
