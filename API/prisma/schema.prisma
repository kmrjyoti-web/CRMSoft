  CLOUD
}

enum AiModelStatus {
  AVAILABLE
  DOWNLOADING
  NOT_INSTALLED
  ERROR
}

enum AiDatasetStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
}

enum AiTrainingJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
