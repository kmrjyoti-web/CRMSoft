// ═══════════════════════════════════════════════════
// CALENDAR & SCHEDULING MODELS
// ═══════════════════════════════════════════════════

model ScheduledEvent {
  id          String             @id @default(uuid())
  tenantId    String             @map("tenant_id")
  eventNumber String             @unique @map("event_number")
  type        ScheduledEventType
  status      EventStatus        @default(SCHEDULED)
  title       String             @db.VarChar(500)
  description String?            @db.Text
  location    String?            @db.VarChar(500)
  meetingLink String?            @map("meeting_link")
  startTime   DateTime           @map("start_time")
  endTime     DateTime           @map("end_time")
  allDay      Boolean            @default(false) @map("all_day")
  timezone    String             @default("Asia/Kolkata")
  color       String?            @db.VarChar(7)

  // Recurrence
  recurrencePattern RecurrencePattern @default(NONE) @map("recurrence_pattern")
  recurrenceConfig  Json?             @map("recurrence_config")
  parentEventId     String?           @map("parent_event_id")
  parentEvent       ScheduledEvent?   @relation("EventRecurrence", fields: [parentEventId], references: [id])
  childEvents       ScheduledEvent[]  @relation("EventRecurrence")

  // Reminder
  reminderMinutes Json? @map("reminder_minutes")

  // Linked entity (polymorphic)
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")

  // Ownership
  organizerId String @map("organizer_id")
  organizer   User   @relation("ScheduledEventOrganizer", fields: [organizerId], references: [id])
  createdById String @map("created_by_id")
  createdBy   User   @relation("ScheduledEventCreatedBy", fields: [createdById], references: [id])

  // External sync
  externalEventId String?               @map("external_event_id")
  syncProvider    CalendarSyncProvider? @map("sync_provider")

  // Audit
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  // Relations
  participants EventParticipant[]
  history      EventHistory[]

  @@index([tenantId, organizerId, startTime])
  @@index([tenantId, startTime, endTime])
  @@index([tenantId, entityType, entityId])
  @@index([externalEventId, syncProvider])
  @@index([status])
  @@map("scheduled_events")
}

model EventParticipant {
  id         String         @id @default(uuid())
  tenantId   String         @default("") @map("tenant_id")
  eventId    String         @map("event_id")
  event      ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String?        @map("user_id")
  user       User?          @relation("EventParticipantUser", fields: [userId], references: [id])
  email      String?
  name       String?
  role       String         @default("ATTENDEE")
  rsvpStatus RSVPStatus     @default(PENDING) @map("rsvp_status")
  rsvpAt     DateTime?      @map("rsvp_at")
  isExternal Boolean        @default(false) @map("is_external")
  notified   Boolean        @default(false)
  notifiedAt DateTime?      @map("notified_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  @@unique([eventId, userId])
  @@index([tenantId, userId])
  @@map("event_participants")
}

model EventHistory {
  id          String         @id @default(uuid())
  tenantId    String         @default("") @map("tenant_id")
  eventId     String         @map("event_id")
  event       ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action      String
  field       String?
  oldValue    String?        @map("old_value")
  newValue    String?        @map("new_value")
  changedById String         @map("changed_by_id")
  changedBy   User           @relation("EventHistoryChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([eventId])
  @@index([tenantId, changedById])
  @@map("event_history")
}

model UserCalendarSync {
  id             String                @id @default(uuid())
  tenantId       String                @map("tenant_id")
  userId         String                @map("user_id")
  user           User                  @relation("UserCalendarSyncUser", fields: [userId], references: [id])
  provider       CalendarSyncProvider
  direction      CalendarSyncDirection @default(TWO_WAY)
  status         CalendarSyncStatus    @default(DISCONNECTED)
  accessToken    String?               @map("access_token") @db.Text
  refreshToken   String?               @map("refresh_token") @db.Text
