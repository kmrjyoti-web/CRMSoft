model User {
  id            String       @id @default(uuid())
  tenantId      String       @default("") @map("tenant_id")
  email         String
  password      String
  firstName     String       @map("first_name")
  lastName      String       @map("last_name")
  phone         String?
  avatar        String?
  status        UserStatus   @default(ACTIVE)
  userType      UserType     @default(EMPLOYEE) @map("user_type")
  lastLoginAt   DateTime?    @map("last_login_at")
  roleId        String       @map("role_id")
  role          Role         @relation(fields: [roleId], references: [id])
  departmentId  String?      @map("department_id")
  department    Department?  @relation("UserDepartment", fields: [departmentId], references: [id])
  designationId String?      @map("designation_id")
  designation   Designation? @relation(fields: [designationId], references: [id])
  reportingToId String?      @map("reporting_to_id")
  reportingTo   User?        @relation("UserReporting", fields: [reportingToId], references: [id])
  reportees     User[]       @relation("UserReporting")
  employeeCode  String?      @map("employee_code")
  joiningDate   DateTime?    @map("joining_date")
  isDeleted     Boolean      @default(false) @map("is_deleted")
  deletedAt     DateTime?    @map("deleted_at")
  deletedById   String?      @map("deleted_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  createdBy     String?      @map("created_by")

  // ─── VERIFICATION STATUS ───
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  emailVerified      Boolean            @default(false) @map("email_verified")
  emailVerifiedAt    DateTime?          @map("email_verified_at")
  mobileVerified     Boolean            @default(false) @map("mobile_verified")
  mobileVerifiedAt   DateTime?          @map("mobile_verified_at")

  // ─── REGISTRATION TYPE ───
  registrationType RegistrationType @default(INDIVIDUAL) @map("registration_type")

  // ─── BUSINESS VERIFICATION (for B2B pricing) ───
  companyName           String?   @map("company_name")
  gstNumber             String?   @map("gst_number")
  gstVerified           Boolean   @default(false) @map("gst_verified")
  gstVerifiedAt         DateTime? @map("gst_verified_at")
  gstVerificationMethod String?   @map("gst_verification_method")

  // ─── BUSINESS DETAILS ───
  panNumber      String? @map("pan_number")
  businessType   String? @map("business_type")
  annualTurnover String? @map("annual_turnover")

  // [cross-db removed] rawContactsCreated      RawContact[]             @relation("RawContactCreatedBy")
  // [cross-db removed] rawContactsVerified     RawContact[]             @relation("RawContactVerifiedBy")
  // [cross-db removed] contactsCreated         Contact[]                @relation("ContactCreatedBy")
  // [cross-db removed] organizationsCreated    Organization[]           @relation("OrgCreatedBy")
  // [cross-db removed] leadsAllocated          Lead[]                   @relation("LeadAllocatedTo")
  // [cross-db removed] leadsCreated            Lead[]                   @relation("LeadCreatedBy")
  // [cross-db removed] activities              Activity[]
  // [cross-db removed] demos                   Demo[]
  // [cross-db removed] tourPlans               TourPlan[]
  // [cross-db removed] quotations              Quotation[]
  // [cross-db removed] entityOwners            EntityOwner[]            @relation("OwnerUser")
  // [cross-db removed] assignedOwners          EntityOwner[]            @relation("AssignedByUser")
  // [cross-db removed] transfersFrom           OwnershipLog[]           @relation("TransferFrom")
  // [cross-db removed] transfersTo             OwnershipLog[]           @relation("TransferTo")
  // [cross-db removed] transfersBy             OwnershipLog[]           @relation("ChangedBy")
  customerProfile         CustomerProfile?
  referralPartner         ReferralPartner?
  permissionOverrides     UserPermissionOverride[]
  // [cross-db removed] approvalsMade           ApprovalRequest[]        @relation("ApprovalMaker")
  // [cross-db removed] approvalsChecked        ApprovalRequest[]        @relation("ApprovalChecker")
  departmentsHeaded       Department[]             @relation("DepartmentHead")
  // [cross-db removed] workflowsCreated        Workflow[]               @relation("WorkflowCreatedBy")
  // [cross-db removed] proformaInvoicesCreated ProformaInvoice[]        @relation("ProformaCreatedBy")

  // Scheduler & Calendar relations
  // [cross-db removed] followUpsAssigned FollowUp[]       @relation("FollowUpAssignedTo")
  // [cross-db removed] followUpsCreated  FollowUp[]       @relation("FollowUpCreatedBy")
  // [cross-db removed] remindersReceived Reminder[]       @relation("ReminderRecipient")
  // [cross-db removed] remindersCreated  Reminder[]       @relation("ReminderCreatedBy")
  // [cross-db removed] recurringEvents   RecurringEvent[] @relation("RecurringEventCreatedBy")
  // [cross-db removed] calendarEvents    CalendarEvent[]  @relation("CalendarEventUser")

  // Ownership & Assignment relations
  userCapacity UserCapacity? @relation("UserCapacity")

  // Notification relations
  // [cross-db removed] notifications          Notification[]          @relation("NotificationRecipient")
  // [cross-db removed] notificationsSent      Notification[]          @relation("NotificationSender")
  // [cross-db removed] notificationPreference NotificationPreference?
