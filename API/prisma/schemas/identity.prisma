model CustomerProfile {
  id             String   @id @default(uuid())
  tenantId       String   @default("") @map("tenant_id")
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String?  @map("company_name")
  gstNumber      String?  @map("gst_number")
  billingAddress String?  @map("billing_address")
  city           String?
  state          String?
  country        String?
  pincode        String?
  industry       String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("customer_profiles")
}

model ReferralPartner {
  id             String   @id @default(uuid())
  tenantId       String   @default("") @map("tenant_id")
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCode   String   @map("referral_code")
  commissionRate Decimal  @default(10) @map("commission_rate") @db.Decimal(5, 2)
  totalReferrals Int      @default(0) @map("total_referrals")
  totalEarnings  Decimal  @default(0) @map("total_earnings") @db.Decimal(12, 2)
  bankName       String?  @map("bank_name")
  bankAccount    String?  @map("bank_account")
  ifscCode       String?  @map("ifsc_code")
  panNumber      String?  @map("pan_number")
  isActive       Boolean  @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, userId])
  @@unique([tenantId, referralCode])
  @@index([tenantId])
  @@map("referral_partners")
}

model Department {
  id           String        @id @default(uuid())
  tenantId     String        @default("") @map("tenant_id")
  name         String
  displayName  String        @map("display_name")
  code         String
  description  String?
  level        Int           @default(0)
  path         String? // materialized path like "/COMPANY/SALES/NORTH"
  parentId     String?       @map("parent_id")
  parent       Department?   @relation("DeptHierarchy", fields: [parentId], references: [id])
  children     Department[]  @relation("DeptHierarchy")
  headUserId   String?       @map("head_user_id")
  headUser     User?         @relation("DepartmentHead", fields: [headUserId], references: [id])
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  users        User[]        @relation("UserDepartment")
  designations Designation[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("departments")
}

model Designation {
  id           String        @id @default(uuid())
  tenantId     String        @default("") @map("tenant_id")
  name         String
  code         String
  description  String?
  level        Int           @default(0)
  grade        String?
  departmentId String?       @map("department_id")
  department   Department?   @relation(fields: [departmentId], references: [id])
  parentId     String?       @map("parent_id")
  parent       Designation?  @relation("DesigHierarchy", fields: [parentId], references: [id])
  children     Designation[] @relation("DesigHierarchy")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  users        User[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("designations")
}

model Role {
  id                  String               @id @default(uuid())
  tenantId            String               @default("") @map("tenant_id")
  name                String
  displayName         String               @map("display_name")
  description         String?
  isSystem            Boolean              @default(false) @map("is_system")
  level               Int                  @default(5)
  parentRoleName      String?              @map("parent_role_name")
  canManageLevels     Int[]                @default([]) @map("can_manage_levels")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  users               User[]
  permissions         RolePermission[]
  menuPermissions     RoleMenuPermission[]
  // [cross-db removed] dataMaskingPolicies DataMaskingPolicy[]  @relation("DataMaskingPolicyRole")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  roles       RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  tenantId     String     @default("") @map("tenant_id")
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
  @@map("role_permissions")
}

model RoleMenuPermission {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  roleId   String @map("role_id")
  menuId   String @map("menu_id")

  // ─── CRUD PERMISSIONS ───
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canEdit   Boolean @default(false) @map("can_edit")
  canDelete Boolean @default(false) @map("can_delete")

  // ─── DATA OPERATIONS ───
  canExport     Boolean @default(false) @map("can_export")
  canImport     Boolean @default(false) @map("can_import")
  canBulkUpdate Boolean @default(false) @map("can_bulk_update")
  canBulkDelete Boolean @default(false) @map("can_bulk_delete")

  // ─── WORKFLOW PERMISSIONS ───
  canApprove  Boolean @default(false) @map("can_approve")
  canAssign   Boolean @default(false) @map("can_assign")
  canTransfer Boolean @default(false) @map("can_transfer")

  // ─── SCOPE PERMISSIONS ───
  canViewAll   Boolean @default(false) @map("can_view_all")
  canEditAll   Boolean @default(false) @map("can_edit_all")
  canDeleteAll Boolean @default(false) @map("can_delete_all")

  // ─── FIELD-LEVEL RESTRICTIONS ───
  restrictedFields Json? @map("restricted_fields")

  // ─── INHERITANCE ───
  inheritFromParent Boolean @default(true) @map("inherit_from_parent")

  // ─── RELATIONS ───
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  // ─── AUDIT ───
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")

  @@index([isDeleted])
  @@unique([tenantId, roleId, menuId])
  @@index([tenantId, roleId])
  @@index([menuId])
  @@map("role_menu_permissions")
}

model PermissionTemplate {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?
  tenantId    String? @map("tenant_id")
  isSystem    Boolean @default(false) @map("is_system")
  isDefault   Boolean @default(false) @map("is_default")

  // ─── PER-MENU PERMISSIONS (JSON map: { menuCode: { canView, canCreate, ... } }) ───
  permissions Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("permission_templates")
}

model UserCapacity {
  id       String @id @default(uuid())
  tenantId String @default("") @map("tenant_id")
  userId   String @unique @map("user_id")
  user     User   @relation("UserCapacity", fields: [userId], references: [id])

  maxLeads         Int @default(50) @map("max_leads")
  maxContacts      Int @default(100) @map("max_contacts")
  maxOrganizations Int @default(30) @map("max_organizations")
  maxQuotations    Int @default(20) @map("max_quotations")
  maxTotal         Int @default(200) @map("max_total")

  activeLeads         Int @default(0) @map("active_leads")
  activeContacts      Int @default(0) @map("active_contacts")
  activeOrganizations Int @default(0) @map("active_organizations")
  activeQuotations    Int @default(0) @map("active_quotations")
  activeTotal         Int @default(0) @map("active_total")

  isAvailable     Boolean   @default(true) @map("is_available")
  unavailableFrom DateTime? @map("unavailable_from")
  unavailableTo   DateTime? @map("unavailable_to")
  delegateToId    String?   @map("delegate_to_id")

  avgResponseHours Decimal?  @map("avg_response_hours") @db.Decimal(6, 2)
  conversionRate   Decimal?  @map("conversion_rate") @db.Decimal(5, 2)
  lastActivityAt   DateTime? @map("last_activity_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("user_capacities")
}

model DelegationRecord {
  id          String      @id @default(uuid())
  tenantId    String      @default("") @map("tenant_id")
  fromUserId  String      @map("from_user_id")
  toUserId    String      @map("to_user_id")
  entityType  EntityType? @map("entity_type")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  isActive    Boolean     @default(true) @map("is_active")
  isReverted  Boolean     @default(false) @map("is_reverted")
  revertedAt  DateTime?   @map("reverted_at")
  reason      String
  createdById String      @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([fromUserId, isActive])
  @@index([toUserId, isActive])
  @@index([endDate, isActive])
  @@index([tenantId])
  @@map("delegation_records")
}

