  // [cross-db removed] shareLinksCreated   DocumentShareLink[]  @relation("ShareLinkCreatedBy")
  // [cross-db removed] documentActivities  DocumentActivity[]   @relation("DocumentActivityUser")

  // Email Integration relations
  // [cross-db removed] emailAccounts   EmailAccount[]   @relation("EmailAccountUser")
  // [cross-db removed] emailSignatures EmailSignature[] @relation("EmailSignatureUser")

