  passwordExpiryDays       Int?           @map("password_expiry_days")
  preventReuseCount        Int            @default(3) @map("prevent_reuse_count")
  maxLoginAttempts         Int            @default(5) @map("max_login_attempts")
  lockoutDurationMinutes   Int            @default(30) @map("lockout_duration_minutes")
  requireCaptchaAfter      Int?           @map("require_captcha_after")
  sessionTimeoutMinutes    Int            @default(480) @map("session_timeout_minutes")
  maxConcurrentSessions    Int            @default(3) @map("max_concurrent_sessions")
  singleSessionPerUser     Boolean        @default(false) @map("single_session_per_user")
  sessionExtendOnActivity  Boolean        @default(true) @map("session_extend_on_activity")
  twoFactorEnabled         Boolean        @default(false) @map("two_factor_enabled")
