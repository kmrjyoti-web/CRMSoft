  // [cross-db removed] userAvailability         UserAvailability[] @relation("UserAvailabilityUser")
  // [cross-db removed] blockedSlots             BlockedSlot[]      @relation("BlockedSlotUser")

  // Table Config & Data Masking relations
  // [cross-db removed] tableConfigs        TableConfig[]       @relation("TableConfigUser")
