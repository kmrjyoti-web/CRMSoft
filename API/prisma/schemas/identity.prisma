model TenantVersion {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  versionId String @map("version_id")

  currentVersion  String  @map("current_version")
  previousVersion String? @map("previous_version")

  // Update tracking
  updatedAt    DateTime @default(now()) @map("updated_at_time")
  updatedBy    String?  @map("updated_by")
  updateMethod String   @default("AUTO") @map("update_method") // AUTO, MANUAL, FORCE

  // Status
  isActive       Boolean  @default(true) @map("is_active")
  patchesApplied String[] @default([]) @map("patches_applied")

  // Force update
  forceUpdatePending  Boolean   @default(false) @map("force_update_pending")
  forceUpdateMessage  String?   @map("force_update_message")
  forceUpdateDeadline DateTime? @map("force_update_deadline")

  createdAt DateTime @default(now()) @map("created_at")

  // [cross-db removed] version AppVersion @relation(fields: [versionId], references: [id])

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, versionId])
  @@index([tenantId])
  @@index([forceUpdatePending])
  @@map("tenant_versions")
}

model VersionBackup {
  id        String @id @default(uuid())
  versionId String @map("version_id")

  backupType String @default("PRE_DEPLOY") @map("backup_type") // PRE_DEPLOY, MANUAL, SCHEDULED

  // Backup details
  dbDumpPath     String? @map("db_dump_path")
  gitTag         String? @map("git_tag")
  configSnapshot Json?   @map("config_snapshot")
  schemaSnapshot String? @map("schema_snapshot")

  // Status
  status    String  @default("COMPLETED") // COMPLETED, FAILED, RESTORING, RESTORED
  sizeBytes BigInt? @map("size_bytes")

  // Restore info
  restoredAt DateTime? @map("restored_at")
  restoredBy String?   @map("restored_by")

  createdAt DateTime @default(now()) @map("created_at")

  // [cross-db removed] version AppVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([backupType])
  @@map("version_backups")
}