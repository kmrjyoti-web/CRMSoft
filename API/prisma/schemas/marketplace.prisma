// prisma/schemas/marketplace.prisma
// 5th Database: Social Commerce Marketplace
// Separate DB for marketplace listings, offers, posts, reviews, analytics

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/marketplace-client"
}

datasource db {
  provider = "postgresql"
  url      = env("MARKETPLACE_DATABASE_URL")
}

enum ListingType {
  PRODUCT
  SERVICE
  REQUIREMENT
  JOB
}

enum ListingStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  SOLD_OUT
  EXPIRED
  ARCHIVED
  REJECTED
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  PRODUCT_SHARE
  CUSTOMER_FEEDBACK
  PRODUCT_LAUNCH
  POLL
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  HIDDEN
  ARCHIVED
  DELETED
}

enum EngagementAction {
  LIKE
  UNLIKE
  SAVE
  UNSAVE
  SHARE
  VIEW
  CLICK
  REPORT
}

enum OfferType {
  ONE_TIME
  DAILY_RECURRING
  WEEKLY_RECURRING
  FIRST_N_ORDERS
  LAUNCH
  CUSTOM
}

enum DiscountType {
  PERCENTAGE
  FLAT_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  BUNDLE_PRICE
}

enum OfferStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  EXPIRED
  CLOSED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum VisibilityType {
  PUBLIC
  GEO_TARGETED
  VERIFIED_ONLY
  MY_CONTACTS
  SELECTED_CONTACTS
  CATEGORY_BASED
  GRADE_BASED
}

enum ExpiryAction {
  DEACTIVATE
  ARCHIVE
  DELETE
  NOTIFY_OWNER
}

enum AnalyticsEventType {
  IMPRESSION
  CLICK
  ENQUIRY
  LEAD
  CUSTOMER
  ORDER
  SHARE
  SAVE
}

enum AnalyticsEntityType {
  POST
  LISTING
  OFFER
}

enum AnalyticsSource {
  FEED
  SEARCH
  SHARE_LINK
  DIRECT
  NOTIFICATION
  QR_CODE
  EXTERNAL
}

model MktListing {
  id                  String          @id @default(uuid())
  tenantId            String          @map("tenant_id")
  authorId            String          @map("author_id")
  listingType         ListingType     @map("listing_type")
  categoryId          String?         @map("category_id")
  subcategoryId       String?         @map("subcategory_id")
  title               String
  description         String?         @db.Text
  shortDescription    String?         @map("short_description")
  mediaUrls           Json            @default("[]") @map("media_urls")
  currency            String          @default("INR")
  basePrice           Int             @default(0) @map("base_price")
  mrp                 Int?
  minOrderQty         Int             @default(1) @map("min_order_qty")
  maxOrderQty         Int?            @map("max_order_qty")
  hsnCode             String?         @map("hsn_code")
  gstRate             Float?          @map("gst_rate")
  trackInventory      Boolean         @default(true) @map("track_inventory")
  stockAvailable      Int             @default(0) @map("stock_available")
  stockReserved       Int             @default(0) @map("stock_reserved")
  visibility          VisibilityType  @default(PUBLIC)
  visibilityConfig    Json?           @map("visibility_config")
  status              ListingStatus   @default(DRAFT)
  publishAt           DateTime?       @map("publish_at")
  expiresAt           DateTime?       @map("expires_at")
  expiryAction        ExpiryAction    @default(DEACTIVATE) @map("expiry_action")
  publishedAt         DateTime?       @map("published_at")
  requirementConfig   Json?           @map("requirement_config")
  shippingConfig      Json?           @map("shipping_config")
  attributes          Json            @default("{}") @map("attributes")
  viewCount           Int             @default(0) @map("view_count")
  enquiryCount        Int             @default(0) @map("enquiry_count")
  orderCount          Int             @default(0) @map("order_count")
  reviewCount         Int             @default(0) @map("review_count")
  avgRating           Float?          @map("avg_rating")
  isFeatured          Boolean         @default(false) @map("is_featured")
  featuredUntil       DateTime?       @map("featured_until")
  slug                String?         @unique
  keywords            String[]        @default([])
  isActive            Boolean         @default(true) @map("is_active")
  isDeleted           Boolean         @default(false) @map("is_deleted")
  deletedAt           DateTime?       @map("deleted_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  createdById         String          @map("created_by_id")
  updatedById         String?         @map("updated_by_id")
  priceTiers          MktListingPriceTier[]
  offers              MktOffer[]      @relation("ListingOffers")
  reviews             MktReview[]
  enquiries           MktEnquiry[]
  analyticsSummary    MktAnalyticsSummary?

  @@index([tenantId])
  @@index([tenantId, status, listingType])
  @@index([tenantId, categoryId])
  @@index([status, publishAt])
  @@index([status, expiresAt])
  @@map("mkt_listings")
}

model MktListingPriceTier {
  id                   String      @id @default(uuid())
  listingId            String      @map("listing_id")
  listing              MktListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  label                String
  minQty               Int         @map("min_qty")
  maxQty               Int?        @map("max_qty")
  pricePerUnit         Int         @map("price_per_unit")
  requiresVerification Boolean     @default(false) @map("requires_verification")
  createdAt            DateTime    @default(now()) @map("created_at")

  @@index([listingId])
  @@map("mkt_listing_price_tiers")
}

model MktPost {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  authorId         String          @map("author_id")
  postType         PostType        @map("post_type")
  content          String?         @db.Text
  mediaUrls        Json            @default("[]") @map("media_urls")
  linkedListingId  String?         @map("linked_listing_id")
  linkedOfferId    String?         @map("linked_offer_id")
  rating           Int?
  productId        String?         @map("product_id")
  visibility       VisibilityType  @default(PUBLIC)
  visibilityConfig Json?           @map("visibility_config")
  status           PostStatus      @default(DRAFT)
  publishAt        DateTime?       @map("publish_at")
  expiresAt        DateTime?       @map("expires_at")
  expiryAction     ExpiryAction    @default(DEACTIVATE) @map("expiry_action")
  publishedAt      DateTime?       @map("published_at")
  viewCount        Int             @default(0) @map("view_count")
  likeCount        Int             @default(0) @map("like_count")
  commentCount     Int             @default(0) @map("comment_count")
  shareCount       Int             @default(0) @map("share_count")
  saveCount        Int             @default(0) @map("save_count")
  hashtags         String[]        @default([])
  mentions         String[]        @default([])
  pollConfig       Json?           @map("poll_config")
  isActive         Boolean         @default(true) @map("is_active")
  isDeleted        Boolean         @default(false) @map("is_deleted")
  deletedAt        DateTime?       @map("deleted_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  createdById      String          @map("created_by_id")
  engagements      MktPostEngagement[]
  comments         MktPostComment[]
  analyticsSummary MktAnalyticsSummary? @relation("PostAnalytics")

  @@index([tenantId, status, createdAt])
  @@index([authorId])
  @@index([status, publishAt])
  @@map("mkt_posts")
}

model MktPostEngagement {
  id         String           @id @default(uuid())
  tenantId   String           @map("tenant_id")
  postId     String           @map("post_id")
  post       MktPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId     String           @map("user_id")
  action     EngagementAction
  sharedTo   String?          @map("shared_to")
  city       String?
  state      String?
  deviceType String?          @map("device_type")
  createdAt  DateTime         @default(now()) @map("created_at")

  @@unique([postId, userId, action])
  @@index([postId])
  @@index([userId])
  @@map("mkt_post_engagements")
}

model MktPostComment {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  postId    String   @map("post_id")
  post      MktPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String   @db.Text
  mediaUrl  String?  @map("media_url")
  likeCount Int      @default(0) @map("like_count")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([postId, createdAt])
  @@map("mkt_post_comments")
}

model MktOffer {
  id                  String       @id @default(uuid())
  tenantId            String       @map("tenant_id")
  authorId            String       @map("author_id")
  title               String
  description         String?      @db.Text
  mediaUrls           Json         @default("[]") @map("media_urls")
  offerType           OfferType    @map("offer_type")
  discountType        DiscountType @map("discount_type")
  discountValue       Float        @map("discount_value")
  linkedListingIds    String[]     @map("linked_listing_ids")
  linkedCategoryIds   String[]     @map("linked_category_ids")
  listing             MktListing?  @relation("ListingOffers", fields: [primaryListingId], references: [id])
  primaryListingId    String?      @map("primary_listing_id")
  conditions          Json         @default("{}") @map("conditions")
  maxRedemptions      Int?         @map("max_redemptions")
  currentRedemptions  Int          @default(0) @map("current_redemptions")
  autoCloseOnLimit    Boolean      @default(true) @map("auto_close_on_limit")
  resetTime           String?      @map("reset_time")
  lastResetAt         DateTime?    @map("last_reset_at")
  status              OfferStatus  @default(DRAFT)
  publishAt           DateTime?    @map("publish_at")
  expiresAt           DateTime?    @map("expires_at")
  publishedAt         DateTime?    @map("published_at")
  closedAt            DateTime?    @map("closed_at")
  closedReason        String?      @map("closed_reason")
  impressionCount     Int          @default(0) @map("impression_count")
  clickCount          Int          @default(0) @map("click_count")
  enquiryCount        Int          @default(0) @map("enquiry_count")
  leadCount           Int          @default(0) @map("lead_count")
  orderCount          Int          @default(0) @map("order_count")
  totalOrderValue     Int          @default(0) @map("total_order_value")
  isActive            Boolean      @default(true) @map("is_active")
  isDeleted           Boolean      @default(false) @map("is_deleted")
  deletedAt           DateTime?    @map("deleted_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  createdById         String       @map("created_by_id")
  redemptions         MktOfferRedemption[]
  analyticsSummary    MktAnalyticsSummary? @relation("OfferAnalytics")

  @@index([tenantId, status])
  @@index([status, publishAt])
  @@index([status, expiresAt])
  @@index([tenantId, offerType, status])
  @@map("mkt_offers")
}

model MktOfferRedemption {
  id              String   @id @default(uuid())
  offerId         String   @map("offer_id")
  offer           MktOffer @relation(fields: [offerId], references: [id])
  userId          String   @map("user_id")
  tenantId        String   @map("tenant_id")
  orderId         String?  @map("order_id")
  discountApplied Int      @map("discount_applied")
  orderValue      Int?     @map("order_value")
  city            String?
  state           String?
  deviceType      String?  @map("device_type")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([offerId])
  @@index([userId])
  @@index([offerId, userId])
  @@map("mkt_offer_redemptions")
}

model MktReview {
  id                  String       @id @default(uuid())
  tenantId            String       @map("tenant_id")
  listingId           String       @map("listing_id")
  listing             MktListing   @relation(fields: [listingId], references: [id])
  reviewerId          String       @map("reviewer_id")
  rating              Int
  title               String?
  body                String?      @db.Text
  mediaUrls           Json         @default("[]") @map("media_urls")
  isVerifiedPurchase  Boolean      @default(false) @map("is_verified_purchase")
  orderId             String?      @map("order_id")
  status              ReviewStatus @default(PENDING)
  moderatorId         String?      @map("moderator_id")
  moderationNote      String?      @map("moderation_note")
  helpfulCount        Int          @default(0) @map("helpful_count")
  reportCount         Int          @default(0) @map("report_count")
  sellerResponse      String?      @map("seller_response") @db.Text
  sellerRespondedAt   DateTime?    @map("seller_responded_at")
  isDeleted           Boolean      @default(false) @map("is_deleted")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([listingId, status])
  @@index([reviewerId])
  @@index([status])
  @@map("mkt_reviews")
}

model MktEnquiry {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  listingId        String     @map("listing_id")
  listing          MktListing @relation(fields: [listingId], references: [id])
  enquirerId       String     @map("enquirer_id")
  message          String     @db.Text
  quantity         Int?
  expectedPrice    Int?       @map("expected_price")
  deliveryPincode  String?    @map("delivery_pincode")
  crmLeadId        String?    @map("crm_lead_id")
  status           String     @default("OPEN")
  isDeleted        Boolean    @default(false) @map("is_deleted")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([listingId])
  @@index([enquirerId])
  @@index([tenantId, status])
  @@map("mkt_enquiries")
}

model MktAnalyticsEvent {
  id          String              @id @default(uuid())
  tenantId    String              @map("tenant_id")
  entityType  AnalyticsEntityType @map("entity_type")
  entityId    String              @map("entity_id")
  eventType   AnalyticsEventType  @map("event_type")
  userId      String?             @map("user_id")
  source      AnalyticsSource     @default(FEED)
  deviceType  String?             @map("device_type")
  city        String?
  state       String?
  pincode     String?
  orderValue  Int?                @map("order_value")
  metadata    Json?               @default("{}")
  timestamp   DateTime            @default(now())

  @@index([entityType, entityId, eventType])
  @@index([tenantId, timestamp])
  @@index([entityId, eventType, timestamp])
  @@map("mkt_analytics_events")
}

model MktAnalyticsSummary {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  entityType          AnalyticsEntityType @map("entity_type")
  entityId            String              @map("entity_id")
  impressions         Int                 @default(0)
  uniqueImpressions   Int                 @default(0) @map("unique_impressions")
  clicks              Int                 @default(0)
  uniqueClicks        Int                 @default(0) @map("unique_clicks")
  ctr                 Float               @default(0)
  enquiries           Int                 @default(0)
  enquiryRate         Float               @default(0) @map("enquiry_rate")
  leads               Int                 @default(0)
  leadConversionRate  Float               @default(0) @map("lead_conversion_rate")
  orders              Int                 @default(0)
  orderConversionRate Float               @default(0) @map("order_conversion_rate")
  totalOrderValue     Int                 @default(0) @map("total_order_value")
  topCities           Json                @default("[]") @map("top_cities")
  topStates           Json                @default("[]") @map("top_states")
  peakHours           Json                @default("[]") @map("peak_hours")
  deviceBreakdown     Json                @default("{}") @map("device_breakdown")
  sourceBreakdown     Json                @default("{}") @map("source_breakdown")
  listingId           String?             @unique @map("listing_id")
  listing             MktListing?         @relation(fields: [listingId], references: [id])
  postId              String?             @unique @map("post_id")
  post                MktPost?            @relation("PostAnalytics", fields: [postId], references: [id])
  offerId             String?             @unique @map("offer_id")
  offer               MktOffer?           @relation("OfferAnalytics", fields: [offerId], references: [id])
  lastComputedAt      DateTime            @default(now()) @map("last_computed_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@index([entityType, entityId])
  @@index([tenantId])
  @@map("mkt_analytics_summaries")
}
