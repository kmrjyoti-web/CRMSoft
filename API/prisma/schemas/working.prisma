model EmailCampaign {
  id                    String         @id @default(uuid())
  tenantId              String         @default("") @map("tenant_id")
  name                  String
  description           String?
  templateId            String?        @map("template_id")
  subject               String
  bodyHtml              String         @map("body_html")
  bodyText              String?        @map("body_text")
  accountId             String         @map("account_id")
  fromName              String?        @map("from_name")
  replyToEmail          String?        @map("reply_to_email")
  totalRecipients       Int            @default(0) @map("total_recipients")
  recipientSource       String?        @map("recipient_source")
  recipientFilter       Json?          @map("recipient_filter")
  status                CampaignStatus @default(DRAFT)
  scheduledAt           DateTime?      @map("scheduled_at")
  startedAt             DateTime?      @map("started_at")
  completedAt           DateTime?      @map("completed_at")
  sendRatePerMinute     Int            @default(30) @map("send_rate_per_minute")
  batchSize             Int            @default(50) @map("batch_size")
  delayBetweenBatchesMs Int            @default(60000) @map("delay_between_batches_ms")
  trackOpens            Boolean        @default(true) @map("track_opens")
  trackClicks           Boolean        @default(true) @map("track_clicks")
  includeUnsubscribe    Boolean        @default(true) @map("include_unsubscribe")
  unsubscribeUrl        String?        @map("unsubscribe_url")
  sentCount             Int            @default(0) @map("sent_count")
  deliveredCount        Int            @default(0) @map("delivered_count")
  openedCount           Int            @default(0) @map("opened_count")
  clickedCount          Int            @default(0) @map("clicked_count")
  repliedCount          Int            @default(0) @map("replied_count")
  bouncedCount          Int            @default(0) @map("bounced_count")
  failedCount           Int            @default(0) @map("failed_count")
  unsubscribedCount     Int            @default(0) @map("unsubscribed_count")
  openRate              Decimal?       @map("open_rate") @db.Decimal(5, 2)
  clickRate             Decimal?       @map("click_rate") @db.Decimal(5, 2)
  createdById           String         @map("created_by_id")
  createdByName         String         @map("created_by_name")
  errorMessage          String?        @map("error_message")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  emails     Email[]
  recipients CampaignRecipient[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([status, scheduledAt])
  @@index([tenantId])
  @@map("email_campaigns")
}

model CampaignRecipient {
  id             String                  @id @default(uuid())
  tenantId       String                  @default("") @map("tenant_id")
  campaignId     String                  @map("campaign_id")
  campaign       EmailCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId      String?                 @map("contact_id")
  email          String
  firstName      String?                 @map("first_name")
  lastName       String?                 @map("last_name")
  companyName    String?                 @map("company_name")
  mergeData      Json?                   @map("merge_data")
  status         CampaignRecipientStatus @default(PENDING)
  sentAt         DateTime?               @map("sent_at")
  openedAt       DateTime?               @map("opened_at")
  clickedAt      DateTime?               @map("clicked_at")
  repliedAt      DateTime?               @map("replied_at")
  bouncedAt      DateTime?               @map("bounced_at")
  unsubscribedAt DateTime?               @map("unsubscribed_at")
  failedAt       DateTime?               @map("failed_at")
  openCount      Int                     @default(0) @map("open_count")
  clickCount     Int                     @default(0) @map("click_count")
  errorMessage   String?                 @map("error_message")
  emailId        String?                 @map("email_id")
  createdAt      DateTime                @default(now()) @map("created_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, campaignId, email])
  @@index([campaignId, status])
  @@index([tenantId])
  @@map("campaign_recipients")
}

