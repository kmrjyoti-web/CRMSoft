}

model AiDataset {
  id            String          @id @default(uuid())
  tenantId      String          @default("") @map("tenant_id")
  name          String
  description   String?
  sourceType    String          @default("MANUAL") @map("source_type")
  entityType    String?         @map("entity_type")
  status        AiDatasetStatus @default(DRAFT)
  documentCount Int             @default(0) @map("document_count")
  totalChunks   Int             @default(0) @map("total_chunks")
  totalTokens   Int             @default(0) @map("total_tokens")
  configJson    Json?           @map("config_json")
  createdBy     String?         @map("created_by")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  documents     AiDocument[]
  trainingJobs  AiTrainingJob[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId, status])
  @@map("ai_datasets")
}

model AiDocument {
  id            String   @id @default(uuid())
  tenantId      String   @default("") @map("tenant_id")
  datasetId     String   @map("dataset_id")
  title         String
  content       String   @db.Text
  contentType   String   @default("text") @map("content_type")
  sourceUrl     String?  @map("source_url")
  chunkCount    Int      @default(0) @map("chunk_count")
  tokenCount    Int      @default(0) @map("token_count")
  metadata      Json?
  isProcessed   Boolean  @default(false) @map("is_processed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dataset       AiDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@index([tenantId, datasetId])
  @@map("ai_documents")
}

model AiTrainingJob {
