model Product {
  id               String  @id @default(uuid())
  tenantId         String  @default("") @map("tenant_id")
  name             String
  code             String
  slug             String
  shortDescription String? @map("short_description")
  description      String?

  // Hierarchy
  parentId String?   @map("parent_id")
  parent   Product?  @relation("ProductHierarchy", fields: [parentId], references: [id])
  children Product[] @relation("ProductHierarchy")
  isMaster Boolean   @default(false) @map("is_master")

  // Media
  image       String?
  images      Json?
  brochureUrl String? @map("brochure_url")
  videoUrl    String? @map("video_url")

  // Pricing (base)
  mrp           Decimal? @db.Decimal(12, 2)
  salePrice     Decimal? @map("sale_price") @db.Decimal(12, 2)
  purchasePrice Decimal? @map("purchase_price") @db.Decimal(12, 2)
  costPrice     Decimal? @map("cost_price") @db.Decimal(12, 2)

  // Tax (Indian GST)
  taxType      TaxType  @default(GST) @map("tax_type")
  hsnCode      String?  @map("hsn_code")
  gstRate      Decimal? @map("gst_rate") @db.Decimal(5, 2)
  cessRate     Decimal? @map("cess_rate") @db.Decimal(5, 2)
  taxInclusive Boolean  @default(false) @map("tax_inclusive")

  // Unit & Packing
  primaryUnit      UnitType  @default(PIECE) @map("primary_unit")
  secondaryUnit    UnitType? @map("secondary_unit")
  conversionFactor Decimal?  @map("conversion_factor") @db.Decimal(10, 4)
  minOrderQty      Decimal?  @map("min_order_qty") @db.Decimal(10, 2)
  maxOrderQty      Decimal?  @map("max_order_qty") @db.Decimal(10, 2)
  weight           Decimal?  @db.Decimal(10, 3)
  dimensions       Json?

  // Packing Detail
  packingSize        Int?      @map("packing_size")
  packingUnit        UnitType? @map("packing_unit")
  packingDescription String?   @map("packing_description")
  barcode            String?
  batchTracking      Boolean   @default(false) @map("batch_tracking")

  // License & Sale Rules
  licenseRequired Boolean @default(false) @map("license_required")
  licenseType     String? @map("license_type")
  licenseNumber   String? @map("license_number")
  individualSale  Boolean @default(true) @map("individual_sale")
  isReturnable    Boolean @default(true) @map("is_returnable")
  warrantyMonths  Int?    @map("warranty_months")
  shelfLifeDays   Int?    @map("shelf_life_days")

  // Brand & Manufacturer Relations
  brandId        String?       @map("brand_id")
  brand          Brand?        @relation(fields: [brandId], references: [id])
  manufacturerId String?       @map("manufacturer_id")
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])

  // Status & Meta
  status      ProductStatus @default(ACTIVE)
  sortOrder   Int           @default(0) @map("sort_order")
  tags        String[]      @default([])
  configJson  Json?         @map("config_json")
  isActive    Boolean       @default(true) @map("is_active")
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  prices          ProductPrice[]
  taxDetails      ProductTaxDetail[]
  unitConversions ProductUnitConversion[]
  filters         ProductFilter[]
  relatedFrom     ProductRelation[]       @relation("RelatedFrom")
  relatedTo       ProductRelation[]       @relation("RelatedTo")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, code])
  @@unique([tenantId, slug])
  @@index([code])
  @@index([parentId])
  @@index([status, isActive])
  @@index([tenantId])
  @@map("products")
}

