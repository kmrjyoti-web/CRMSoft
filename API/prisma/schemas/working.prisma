model WhatsAppBusinessAccount {
  id                 String               @id @default(uuid())
  tenantId           String               @default("") @map("tenant_id")
  wabaId             String               @map("waba_id")
  phoneNumberId      String               @map("phone_number_id")
  phoneNumber        String               @map("phone_number")
  displayName        String               @map("display_name")
  accessToken        String               @map("access_token")
  webhookVerifyToken String               @map("webhook_verify_token")
  apiVersion         String               @default("v21.0") @map("api_version")
  connectionStatus   WabaConnectionStatus @default(PENDING_VERIFICATION) @map("connection_status")
  lastConnectedAt    DateTime?            @map("last_connected_at")

  // Business profile
  businessProfilePhoto String? @map("business_profile_photo")
  aboutText            String? @map("about_text")
  address              String?
  verticalIndustry     String? @map("vertical_industry")
  websiteUrl           String? @map("website_url")

  // Settings
  autoReplyEnabled      Boolean @default(false) @map("auto_reply_enabled")
  autoReplyMessage      String? @map("auto_reply_message")
  businessHoursEnabled  Boolean @default(false) @map("business_hours_enabled")
  businessHoursConfig   Json?   @map("business_hours_config")
  welcomeMessageEnabled Boolean @default(false) @map("welcome_message_enabled")
  welcomeMessage        String? @map("welcome_message")

  // Stats
  totalConversations    Int @default(0) @map("total_conversations")
  totalMessagesSent     Int @default(0) @map("total_messages_sent")
  totalMessagesReceived Int @default(0) @map("total_messages_received")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  conversations WaConversation[]
  messages      WaMessage[]
  templates     WaTemplate[]
  broadcasts    WaBroadcast[]
  chatbotFlows  WaChatbotFlow[]
  quickReplies  WaQuickReply[]
  optOuts       WaOptOut[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, wabaId])
  @@unique([tenantId, phoneNumberId])
  @@index([tenantId])
  @@map("whatsapp_business_accounts")
}

model WaConversation {
  id              String                  @id @default(uuid())
  tenantId        String                  @default("") @map("tenant_id")
  wabaId          String                  @map("waba_id")
  waba            WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id])
  contactPhone    String                  @map("contact_phone")
  contactName     String?                 @map("contact_name")
  contactPushName String?                 @map("contact_push_name")

  // CRM linking
  linkedEntityType String? @map("linked_entity_type")
  linkedEntityId   String? @map("linked_entity_id")

  // Conversation state
  status       WaConversationStatus @default(OPEN)
  assignedToId String?              @map("assigned_to_id")
  // [cross-db removed] assignedTo   User?                @relation("WaConversationAssignedTo", fields: [assignedToId], references: [id])

  // 24-hour messaging window
  windowExpiresAt DateTime? @map("window_expires_at")
  isWindowOpen    Boolean   @default(false) @map("is_window_open")

  // Metadata
  lastMessageAt        DateTime?           @map("last_message_at")
  lastMessageSnippet   String?             @map("last_message_snippet")
  lastMessageDirection WaMessageDirection? @map("last_message_direction")
  unreadCount          Int                 @default(0) @map("unread_count")
  messageCount         Int                 @default(0) @map("message_count")
  tags                 String[]            @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  messages WaMessage[]

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, wabaId, contactPhone])
  @@index([wabaId, status])
  @@index([wabaId, lastMessageAt])
  @@index([assignedToId])
  @@index([linkedEntityType, linkedEntityId])
  @@index([tenantId])
  @@map("wa_conversations")
}

model WaMessage {
  id             String                  @id @default(uuid())
  tenantId       String                  @default("") @map("tenant_id")
  wabaId         String                  @map("waba_id")
  waba           WhatsAppBusinessAccount @relation(fields: [wabaId], references: [id])
  conversationId String                  @map("conversation_id")
  conversation   WaConversation          @relation(fields: [conversationId], references: [id])

  // Message identity
  waMessageId String?            @map("wa_message_id")
  direction   WaMessageDirection
  messageType WaMessageType      @map("message_type")
  status      WaMessageStatus    @default(PENDING)

  // Content
  textBody      String? @map("text_body")
  mediaUrl      String? @map("media_url")
  mediaId       String? @map("media_id")
  mediaMimeType String? @map("media_mime_type")
  mediaCaption  String? @map("media_caption")
  mediaFileName String? @map("media_file_name")

  // Template
  templateId        String? @map("template_id")
  templateName      String? @map("template_name")
  templateVariables Json?   @map("template_variables")

  // Interactive
  interactiveType  String? @map("interactive_type")
  interactiveData  Json?   @map("interactive_data")
  buttonReplyId    String? @map("button_reply_id")
  buttonReplyTitle String? @map("button_reply_title")
  listReplyId      String? @map("list_reply_id")
  listReplyTitle   String? @map("list_reply_title")

  // Location
  latitude        Float?
  longitude       Float?
  locationName    String? @map("location_name")
  locationAddress String? @map("location_address")

  // Reaction
  reactionEmoji     String? @map("reaction_emoji")
  reactionMessageId String? @map("reaction_message_id")

  // Contact card
  contactCardData Json? @map("contact_card_data")

  // Status tracking
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  readAt        DateTime? @map("read_at")
  failedAt      DateTime? @map("failed_at")
  failureReason String?   @map("failure_reason")

  // Context
  contextMessageId String? @map("context_message_id")
  isForwarded      Boolean @default(false) @map("is_forwarded")
  senderUserId     String? @map("sender_user_id")

  // Broadcast / Chatbot flags
  broadcastId          String? @map("broadcast_id")
  broadcastRecipientId String? @map("broadcast_recipient_id")
  isChatbotReply       Boolean @default(false) @map("is_chatbot_reply")
  chatbotFlowId        String? @map("chatbot_flow_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")
  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([isDeleted])
  @@unique([tenantId, waMessageId])
  @@index([conversationId, createdAt])
  @@index([wabaId, createdAt])
  @@index([status])
  @@index([broadcastId])
  @@index([tenantId])
  @@map("wa_messages")
}

model WaTemplate {
