model Quotation {
  id          String          @id @default(uuid())
  tenantId    String          @default("") @map("tenant_id")
  quotationNo String          @map("quotation_no")
  status      QuotationStatus @default(DRAFT)
  version     Int             @default(1)

  // ─── BUSINESS INFO ───
  title     String?
  summary   String?
  coverNote String? @map("cover_note")

  // ─── PRICING ───
  subtotal       Decimal @default(0) @db.Decimal(14, 2)
  discountType   String? @map("discount_type")
  discountValue  Decimal @default(0) @map("discount_value") @db.Decimal(14, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxableAmount  Decimal @default(0) @map("taxable_amount") @db.Decimal(14, 2)
  cgstAmount     Decimal @default(0) @map("cgst_amount") @db.Decimal(14, 2)
  sgstAmount     Decimal @default(0) @map("sgst_amount") @db.Decimal(14, 2)
  igstAmount     Decimal @default(0) @map("igst_amount") @db.Decimal(14, 2)
  cessAmount     Decimal @default(0) @map("cess_amount") @db.Decimal(14, 2)
  totalTax       Decimal @default(0) @map("total_tax") @db.Decimal(14, 2)
  roundOff       Decimal @default(0) @map("round_off") @db.Decimal(14, 2)
  totalAmount    Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)

  // ─── PRICE FLEXIBILITY ───
  priceType        QuotationPriceType @default(FIXED) @map("price_type")
  minAmount        Decimal?           @map("min_amount") @db.Decimal(14, 2)
  maxAmount        Decimal?           @map("max_amount") @db.Decimal(14, 2)
  plusMinusPercent Decimal?           @map("plus_minus_percent") @db.Decimal(5, 2)

  // ─── VALIDITY & TERMS ───
  validFrom       DateTime? @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  paymentTerms    String?   @map("payment_terms")
  deliveryTerms   String?   @map("delivery_terms")
  warrantyTerms   String?   @map("warranty_terms")
  termsConditions String?   @map("terms_conditions")

  // ─── RELATIONS ───
  leadId          String  @map("lead_id")
  lead            Lead    @relation(fields: [leadId], references: [id])
  contactPersonId String?       @map("contact_person_id")
  contactPerson   Contact?      @relation("QuotationContactPerson", fields: [contactPersonId], references: [id])
  organizationId  String?       @map("organization_id")
  organization    Organization? @relation("QuotationOrganization", fields: [organizationId], references: [id])

  // ─── REVISION CHAIN ───
  parentQuotationId String?     @map("parent_quotation_id")
  parentQuotation   Quotation?  @relation("QuotationRevision", fields: [parentQuotationId], references: [id])
  revisions         Quotation[] @relation("QuotationRevision")

  // ─── ACCEPTANCE ───
  acceptedAt     DateTime? @map("accepted_at")
  acceptedNote   String?   @map("accepted_note")
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason")

  // ─── AI PREDICTION ───
  aiScore       Int?  @map("ai_score")
  aiSuggestions Json? @map("ai_suggestions")

  // ─── META ───
  tags          String[] @default([])
  configJson    Json?    @map("config_json")
  internalNotes String?  @map("internal_notes")

  // ─── AUDIT ───
  createdById   String   @map("created_by_id")
  // [cross-db removed] createdByUser User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  // ─── CHILD TABLES ───
  lineItems        QuotationLineItem[]
  sendLogs         QuotationSendLog[]
  negotiations     QuotationNegotiationLog[]
  activities       QuotationActivity[]
  invoices         Invoice[]
  proformaInvoices ProformaInvoice[]

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@unique([tenantId, quotationNo])
  @@index([leadId, status])
  @@index([status, createdAt])
  @@index([contactPersonId])
  @@index([organizationId])
  @@index([createdById, status])
  @@index([tenantId])
  @@map("quotations")
}

