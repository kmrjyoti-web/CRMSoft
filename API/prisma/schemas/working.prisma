  @@map("control_room_drafts")
}
// ─── P1 Features: SavedFilter, PriceList, PriceListItem ────────────────────

model SavedFilter {
  id            String   @id @default(uuid())
  tenantId      String   @default("") @map("tenant_id")
  entityType    String   @map("entity_type")
  name          String
  description   String?
  filterConfig  Json     @map("filter_config")
  isDefault     Boolean  @default(false) @map("is_default")
  isShared      Boolean  @default(false) @map("is_shared")
  sharedWithRoles Json?  @map("shared_with_roles")
  usageCount    Int      @default(0) @map("usage_count")
  lastUsedAt    DateTime? @map("last_used_at")
  createdById   String   @map("created_by_id")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("saved_filters")
  @@index([tenantId, entityType])
  @@index([tenantId, createdById])
  @@index([isDeleted])
}

model PriceList {
  id          String   @id @default(uuid())
  tenantId    String   @default("") @map("tenant_id")
  name        String
  description String?
  currency    String   @default("INR")
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0)
  isDeleted   Boolean  @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdById String   @default("") @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       PriceListItem[]

  @@map("price_lists")
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([isDeleted])
}

model PriceListItem {
  id             String   @id @default(uuid())
  priceListId    String   @map("price_list_id")
  productId      String   @map("product_id")
  sellingPrice   Decimal  @map("selling_price") @db.Decimal(14,2)
  minQuantity    Int      @default(1) @map("min_quantity")
  maxQuantity    Int?     @map("max_quantity")
  marginPercent  Decimal? @map("margin_percent") @db.Decimal(5,2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  priceList      PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@map("price_list_items")
  @@index([priceListId])
  @@index([productId])
  @@unique([priceListId, productId, minQuantity])
}
