model RawContact {
  id            String           @id @default(uuid())
  tenantId      String           @default("") @map("tenant_id")
  source        RawContactSource @default(MANUAL)
  status        RawContactStatus @default(RAW)
  firstName     String           @map("first_name")
  lastName      String           @map("last_name")
  designation   String?
  department    String?
  companyName   String?          @map("company_name")
  notes         String?
  isActive      Boolean          @default(true) @map("is_active")
  isDeleted                 Boolean          @default(false) @map("is_deleted")
  entityVerificationStatus  String           @default("UNVERIFIED") @map("entity_verification_status")
  entityVerifiedVia         String?          @map("entity_verified_via")
  deletedAt     DateTime?        @map("deleted_at")
  deletedById   String?          @map("deleted_by_id")
  verifiedAt    DateTime?        @map("verified_at")
  verifiedById  String?          @map("verified_by_id")
  // [cross-db removed] verifiedBy    User?            @relation("RawContactVerifiedBy", fields: [verifiedById], references: [id])
  contactId     String?          @map("contact_id")
  contact       Contact?         @relation(fields: [contactId], references: [id])
  createdById   String           @map("created_by_id")
  // [cross-db removed] createdByUser User             @relation("RawContactCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  filters        RawContactFilter[]
  communications Communication[]    @relation("CommRawContact")

  updatedById   String?   @map("updated_by_id")
  updatedByName String?   @map("updated_by_name")

  @@index([status])
